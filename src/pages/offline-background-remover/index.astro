---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import dsLogo from "../../assets/images/DavantSystems-logo-1000.png";
import heroBg from "../../assets/images/obr/hero-bg.jpg";
import screenshotOffline from "../../assets/images/obr/screenshot-offline-2up.png";
import screenshotModels from "../../assets/images/obr/screenshot-models.png";
import screenshot4up from "../../assets/images/obr/screenshot-4up-views.png";
import screenshotMask from "../../assets/images/obr/screenshot-mask-controls.png";

const pageTitle = "Offline Background Remover | Davant Systems";
const pageDescription =
  "Instant background removal with on-device AI. No uploads, no subscription. Pay once, use forever.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main id="main-content" class="font-['DM_Sans']">
    <!-- Hero -->
    <section class="relative overflow-hidden z-10">
      <div class="absolute inset-0">
        <Image
          src={heroBg}
          alt=""
          class="object-cover w-full h-full blur-xs"
          widths={[640, 1024, 1920, 3840]}
          sizes="100vw"
          loading="eager"
        />
        <div class="absolute inset-0 bg-black/60"></div>
        <div
          class="absolute inset-0 opacity-100 mix-blend-overlay"
          style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;"
        >
        </div>
      </div>
      <div
        class="relative z-10 flex flex-col items-center gap-8 px-6 pt-12 pb-0 lg:flex-row lg:items-center lg:gap-12 max-w-8xl mx-auto"
      >
        <div class="lg:w-2/5 text-center lg:text-left pb-12 flex justify-center">
          <div class="w-min">
            <h1
              class="mb-4 text-5xl font-bold tracking-tight text-white sm:text-6xl lg:text-7xl"
            >
              Offline Background Remover
            </h1>
            <p class="mb-0 text-xl font-light text-white/80 sm:text-2xl">
              Instant background removal.
            </p>
            <p class="mb-6 text-xl font-light text-white/80 sm:text-2xl">
              No login, subscription.
            </p>
            <a
              href="#"
              class="inline-flex items-center gap-2 px-8 py-4 text-lg font-semibold text-white transition-all duration-300 bg-white/10 border border-white/20 rounded-xl hover:bg-white/20 hover:scale-[1.02] backdrop-blur-sm"
            >
              <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
                <path
                  d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
                ></path>
              </svg>
              Download on the Mac App Store
            </a>
          </div>
        </div>
        <div class="lg:w-3/5 self-end">
          <div
            class="overflow-hidden shadow-2xl shadow-black/50 rounded-t-[3.5%]"
          >
            <video
              autoplay
              muted
              loop
              playsinline
              preload="auto"
              class="w-full h-auto"
            >
              <source src="/video/obr/app-preview.mov" type="video/mp4" />
            </video>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-indigo -950 shadow-xl z-20 relative">
      <div class="max-w-6xl text-center w-full ml-auto mr-auto px-8 py-8">
        <p class="text-lg text-white">
          On-device AI removes backgrounds in seconds. Your images never leave
          your Mac. Pay once, use forever.
        </p>
      </div>
    </section>

    <!-- Feature: Drag and Drop -->
    <section class="px-6 py-20 bg-neutral-950">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-16">
          <div class="lg:w-2/3">
            <Image
              src={screenshotOffline}
              alt="Offline Background Remover showing before and after side-by-side view"
              class="w-full h-auto rounded-lg"
              widths={[400, 800, 1200]}
              sizes="(max-width: 1024px) 100vw, 66vw"
              loading="lazy"
            />
          </div>
          <div class="lg:w-1/3">
            <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl">
              Drag. Drop. Done.
            </h2>
            <p class="mb-4 text-lg text-white/60">
              Drop an image in, get a clean cutout back. Done in seconds.
            </p>
            <p class="text-lg text-white/60">
              Your images stay on your Mac. No uploads, no cloud processing, no
              internet required.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature: 13 AI Models -->
    <section class="px-6 py-20 bg-neutral-900">
      <div class="max-w-6xl mx-auto">
        <div
          class="flex flex-col items-center gap-10 lg:flex-row-reverse lg:gap-16"
        >
          <div class="lg:w-2/3">
            <Image
              src={screenshotModels}
              alt="Model manager showing 13 available AI models"
              class="w-full h-auto rounded-lg"
              widths={[400, 800, 1200]}
              sizes="(max-width: 1024px) 100vw, 66vw"
              loading="lazy"
            />
          </div>
          <div class="lg:w-1/3">
            <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl">
              13 AI Models
            </h2>
            <p class="mb-4 text-lg text-white/60">
              Pick the right model for the job. Two ship with the app. Eleven
              more are free to download.
            </p>
            <p class="text-lg text-white/60">
              Some are built for speed, others for accuracy or specific subjects
              like portraits or products.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature: Multiple Views -->
    <section class="px-6 py-20 bg-neutral-950">
      <div class="max-w-6xl mx-auto">
        <div class="flex flex-col items-center gap-10 lg:flex-row lg:gap-16">
          <div class="lg:w-2/3">
            <Image
              src={screenshot4up}
              alt="Four-up view comparing original, output, mask, and removed views"
              class="w-full h-auto rounded-lg"
              widths={[400, 800, 1200]}
              sizes="(max-width: 1024px) 100vw, 66vw"
              loading="lazy"
            />
          </div>
          <div class="lg:w-1/3">
            <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl">
              Evaluate Every Edge
            </h2>
            <p class="mb-4 text-lg text-white/60">
              Compare the original, output, mask, and inverse side by side. Swap
              background fill colors to check edges against any surface.
            </p>
            <p class="text-lg text-white/60">
              Export just the mask for compositing in Photoshop, Affinity, or
              whatever you use.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature: Professional Controls -->
    <section class="px-6 py-20 bg-neutral-900">
      <div class="max-w-6xl mx-auto">
        <div
          class="flex flex-col items-center gap-10 lg:flex-row-reverse lg:gap-16"
        >
          <div class="lg:w-2/3">
            <Image
              src={screenshotMask}
              alt="Advanced mask controls for professional fine-grained adjustments"
              class="w-full h-auto rounded-lg"
              widths={[400, 800, 1200]}
              sizes="(max-width: 1024px) 100vw, 66vw"
              loading="lazy"
            />
          </div>
          <div class="lg:w-1/3">
            <h2 class="mb-4 text-3xl font-bold text-white sm:text-4xl">
              Built for Professionals
            </h2>
            <p class="mb-6 text-lg text-white/60">
              One-click removal is the starting point. After that, you get real
              control.
            </p>
            <ul class="mb-6 space-y-3 text-white/60">
              <li class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 mt-0.5 text-blue-400 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.5 12.75l6 6 9-13.5"></path>
                </svg>
                Adjustable foreground and background thresholds
              </li>
              <li class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 mt-0.5 text-blue-400 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.5 12.75l6 6 9-13.5"></path>
                </svg>
                Erode and smooth sliders for clean edges
              </li>
              <li class="flex items-start gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-5 h-5 mt-0.5 text-blue-400 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4.5 12.75l6 6 9-13.5"></path>
                </svg>
                Live preview as you adjust
              </li>
            </ul>
            <p class="text-lg font-medium text-white/80">
              This is precision, not guesswork.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Privacy -->
    <section class="px-6 py-20 bg-neutral-900">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6 text-3xl font-bold text-white sm:text-4xl">
          Your Images Stay Private
        </h2>
        <p class="mb-4 text-lg text-white/60">
          All processing happens on your device. Nothing is uploaded. Nothing is
          tracked. Nothing is logged.
        </p>
        <p class="text-lg text-white/60">
          Client photos, confidential documents, sensitive creative work. None
          of it leaves your machine.
        </p>
      </div>
    </section>

    <!-- Pricing CTA -->
    <section class="px-6 py-24 bg-neutral-950">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6 text-3xl font-bold text-white sm:text-4xl">
          One-Time Purchase
        </h2>
        <p class="mb-10 text-lg text-white/60">
          No subscriptions. No recurring fees. No limits.
        </p>
        <a
          href="#"
          class="inline-flex items-center gap-2 px-8 py-4 text-lg font-semibold text-white transition-all duration-300 bg-white/10 border border-white/20 rounded-xl hover:bg-white/20 hover:scale-[1.02] backdrop-blur-sm"
        >
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"
            ></path>
          </svg>
          Download on the Mac App Store
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-8 bg-neutral-950 border-t border-white/5">
      <div class="flex items-center justify-between max-w-6xl mx-auto">
        <a href="/">
          <Image
            src={dsLogo}
            alt="Davant Systems"
            width={100}
            height={40}
            class="object-contain"
          />
        </a>
        <div class="flex gap-6 text-sm text-white/40">
          <a
            href="/offline-background-remover/support"
            class="hover:text-white/70 transition-colors">Support</a
          >
          <a
            href="/offline-background-remover/privacy-policy"
            class="hover:text-white/70 transition-colors">Privacy Policy</a
          >
        </div>
      </div>
    </footer>
  </main>
</Layout>
