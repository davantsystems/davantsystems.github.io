---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import dsLogo from "../../assets/images/DavantSystems-logo-1000.png";

const pageTitle = "Support | Offline Background Remover | Davant Systems";
const pageDescription = "Get help with Offline Background Remover. FAQ, troubleshooting, and contact information.";

const faqs = [
  {
    question: "Does the app require an internet connection?",
    answer: "No. All processing happens on your Mac. The only time the app goes online is when you download optional AI models. Eleven of the thirteen models are free downloads; two come bundled with the app. Once you have the models, everything runs offline.",
  },
  {
    question: "How do I get the best results?",
    answer: "Experiment with different AI models. Some are built for speed, others for accuracy or specific subjects like portraits or products. Use the advanced mask controls (thresholds, erode, smooth, feather) to clean up edges. The 4-up view lets you compare the original, output, mask, and inverse side by side.",
  },
  {
    question: "What image formats does the app support?",
    answer: "It accepts PNG, JPEG, GIF, WebP, BMP, AVIF, TIFF, OpenEXR, HDR, ICO, Targa, DDS, PDF (single-page), and PNM family formats. Max file size is 50 MB. Exports are high-resolution PNG or WebP.",
  },
  {
    question: "How do I download additional AI models?",
    answer: "Open the model manager in the app settings. You'll see a list of available models with descriptions of what each one does best. Download any of them with one click.",
  },
  {
    question: "Can I get a refund?",
    answer: `Refunds for Mac App Store purchases are handled by Apple. Visit <a href="https://reportaproblem.apple.com" target="_blank" rel="noopener noreferrer" class="text-blue-400 hover:text-blue-300 underline">reportaproblem.apple.com</a> or contact Apple Support to request one.`,
  },
  {
    question: "The app is not producing good results on my image.",
    answer: "Try a different AI model. Different models handle different subjects better (portraits, product photos, busy backgrounds). You can also adjust the mask controls to refine things. Still stuck? Email us with details and we'll help sort it out.",
  },
  {
    question: "What are the system requirements?",
    answer: "macOS 14.6 or later. The app uses on-device machine learning, so performance depends on your hardware. Apple Silicon Macs will be the fastest.",
  },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <main id="main-content" class="font-['DM_Sans'] bg-black">

    <!-- Simple Nav -->
    <nav class="fixed top-0 z-50 flex items-center w-full px-6 py-4 bg-black/80 backdrop-blur-sm">
      <a href="/offline-background-remover" class="text-sm text-neutral-300 hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="inline-block w-4 h-4 mr-1 -mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
        </svg>
        Offline Background Remover
      </a>
    </nav>

    <!-- Header -->
    <section class="relative px-6 pt-32 pb-16 overflow-hidden">
      <div class="absolute z-[1] top-0 left-1/2 -translate-x-1/2 -translate-y-[40%] w-[80%] h-[100%] bg-[radial-gradient(ellipse_at_center,_rgba(59,130,246,0.12)_0%,_transparent_70%)] pointer-events-none"></div>
      <div class="absolute inset-0 z-[2] opacity-100 mix-blend-soft-light pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;"></div>
      <div class="relative z-20 max-w-3xl mx-auto">
        <h1 class="mb-4 text-4xl font-bold text-white sm:text-5xl">Support</h1>
        <p class="text-lg text-neutral-300">
          Need help with Offline Background Remover? Check below or get in touch.
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="px-6 py-16 border-t border-white/5">
      <div class="max-w-3xl mx-auto">
        <h2 class="mb-10 text-2xl font-bold text-white">Frequently Asked Questions</h2>
        <div class="space-y-0">
          {faqs.map((faq) => (
            <details class="group border-b border-white/5">
              <summary class="flex items-center justify-between py-6 cursor-pointer list-none">
                <h3 class="text-lg font-semibold text-white group-hover:text-neutral-200 transition-colors">{faq.question}</h3>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-neutral-500 shrink-0 ml-4 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="pb-6 leading-relaxed text-neutral-300" set:html={faq.answer} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="relative px-6 py-20 overflow-hidden border-t border-white/5">
      <div class="absolute z-[1] bottom-0 left-1/2 -translate-x-1/2 translate-y-[50%] w-[80%] h-[100%] bg-[radial-gradient(ellipse_at_center,_rgba(99,102,241,0.1)_0%,_transparent_70%)] pointer-events-none"></div>
      <div class="relative z-20 max-w-3xl mx-auto text-center">
        <h2 class="mb-4 text-2xl font-bold text-white">Still Need Help?</h2>
        <p class="mb-6 text-lg text-neutral-300">
          Happy to help. Send us an email and we'll get back to you.
        </p>
        <a
          href="mailto:support@davantsystems.com"
          class="inline-flex items-center gap-2 backdrop-blur-sm px-6 py-3 text-base font-semibold text-white transition-all duration-300 bg-white/5 border border-white/50 rounded-xl hover:bg-white/15 hover:-translate-y-0.5"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          support@davantsystems.com
        </a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-8 bg-black border-t border-white/5">
      <div class="flex items-center justify-between max-w-6xl mx-auto">
        <a href="/">
          <Image src={dsLogo} alt="Davant Systems" width={100} height={40} class="object-contain" />
        </a>
        <div class="flex gap-6 text-sm text-neutral-500">
          <a href="/offline-background-remover" class="hover:text-neutral-300 transition-colors">Offline Background Remover</a>
          <a href="/offline-background-remover/privacy-policy" class="hover:text-neutral-300 transition-colors">Privacy Policy</a>
        </div>
      </div>
    </footer>

  </main>
</Layout>
