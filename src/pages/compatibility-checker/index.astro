---
import Layout from "../../layouts/Layout.astro";
import MainNavWithDropdowns from "../../components/MainNavWithDropdowns.astro";
import Footer from "../../components/Footer.astro";
import CompatibilityChecker from "../../components/compatibility/CompatibilityChecker.tsx";

const pageTitle = "System Compatibility Checker | Davant Studio";
---

<Layout title={pageTitle}>
  <MainNavWithDropdowns />
  <style>
    /* Enhanced animations for visual polish */
    @keyframes scoreReveal {
      0% {
        stroke-dashoffset: 452;
        opacity: 0;
      }
      20% {
        opacity: 1;
      }
      100% {
        stroke-dashoffset: var(--score-offset, 452);
      }
    }

    @keyframes counterTick {
      from {
        transform: translateY(10px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    @keyframes cardReveal {
      from {
        transform: translateY(20px) scale(0.95);
        opacity: 0;
      }
      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    @keyframes statusPulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.05);
      }
    }

    @keyframes scanBeam {
      0% {
        transform: translateX(-100%);
      }
      100% {
        transform: translateX(100%);
      }
    }

    @keyframes glowPulse {
      0%, 100% {
        opacity: 0.3;
      }
      50% {
        opacity: 0.6;
      }
    }

    @keyframes typewriter {
      from {
        clip-path: inset(0 100% 0 0);
      }
      to {
        clip-path: inset(0 0 0 0);
      }
    }

    /* Component card hover effects */
    .component-card {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }

    .component-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px -10px rgba(139, 92, 246, 0.3);
    }

    .component-card:hover .card-glow {
      opacity: 1;
    }

    .card-glow {
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    /* Score circle animation */
    .score-animate {
      animation: scoreReveal 2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    /* Progress fill animation */
    .progress-fill {
      animation: scanBeam 2s linear infinite;
    }

    /* Detection message fade in */
    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fadeIn {
      animation: fadeIn 0.5s ease-out forwards;
    }

    /* Typewriter cursor */
    @keyframes blink {
      0%, 50% { opacity: 1; }
      51%, 100% { opacity: 0; }
    }

    .typewriter-cursor::after {
      content: '|';
      animation: blink 1s infinite;
      color: currentColor;
      opacity: 0.5;
    }

    /* Glassmorphism for cards */
    .glass-card {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(236, 72, 153, 0.1) 100%);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    /* Neon glow effect */
    .neon-glow {
      filter: drop-shadow(0 0 10px currentColor) drop-shadow(0 0 20px currentColor);
    }

    /* Ensure proper stacking context for results */
    #results-phase {
      position: relative;
      z-index: 1;
    }

    /* Smooth reveal animation for results */
    .reveal-animation {
      animation: cardReveal 0.6s ease-out forwards;
    }

    /* Responsive adjustments */
    @media (max-width: 640px) {
      .component-card {
        padding: 1rem;
      }
      
      #score-value {
        font-size: 2rem !important;
      }
    }
  </style>
  <main class="min-h-screen">
    <section class="relative overflow-hidden">
      <!-- Background effect -->
      <div class="absolute inset-0 -z-10">
        <div class="absolute top-0 rounded-full left-1/4 w-96 h-96 bg-purple-600/10 blur-3xl"></div>
        <div class="absolute bottom-0 rounded-full right-1/4 w-96 h-96 bg-pink-600/10 blur-3xl"></div>
      </div>

      <div class="container max-w-6xl px-6 py-20 mx-auto">
        <!-- Header -->
        <div class="mb-10 text-center">
          <h1 class="mb-4 text-3xl font-bold md:text-4xl">
            <span class="text-transparent bg-gradient-to-r from-violet-400 via-cyan-400 to-blue-500 bg-clip-text">
              System Compatibility Checker
            </span>
          </h1>
          <p class="max-w-2xl mx-auto mb-6 text-lg text-cyan-100/80">
            Check if your computer can run Davant Studio's AI tools.
          </p>
        </div>

        <!-- React Component -->
        <CompatibilityChecker client:load />
      </div>
    </section>
  </main>
  <Footer />
</Layout>