---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import MainNavWithDropdowns from "../components/MainNavWithDropdowns.astro";
import Footer from "../components/Footer.astro";

// Import hero images
import hero1 from "../assets/images/hero1.png";

const pageTitle = "Articles & Resources | Davant Systems";
const pageDescription = "Learn about AI image generation, Stable Diffusion, and creative workflows with our comprehensive guides and tutorials.";

// Get all articles, sorted by date (newest first)
const allArticles = await getCollection("articles", ({ data }) => {
  return !data.draft;
});
const sortedArticles = allArticles.sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);

// Separate featured and regular articles
const featuredArticles = sortedArticles.filter(article => article.data.featured);
const regularArticles = sortedArticles.filter(article => !article.data.featured);

// Image mapping for featured images
const imageMap = {
  "../../assets/images/hero1.png": hero1,
};
---

<Layout title={pageTitle} description={pageDescription}>
  <MainNavWithDropdowns />
  <main class="relative pt-24 pb-32 min-h-screen bg-base-100">
    <!-- Hero Section -->
    <section class="relative overflow-hidden bg-gradient-to-br from-base-300 via-base-200 to-base-100">
      <div class="container px-8 py-16 mx-auto">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="mb-6 text-5xl font-bold leading-tight text-transparent bg-gradient-to-r from-pink-400 via-fuchsia-500 to-purple-500 bg-clip-text md:text-6xl">
            Articles & Resources
          </h1>
          <p class="text-xl leading-relaxed text-base-content/80 md:text-2xl">
            Learn about AI image generation, Stable Diffusion, and creative workflows with our comprehensive guides and tutorials.
          </p>
        </div>
      </div>
    </section>

    <!-- Featured Articles -->
    {featuredArticles.length > 0 && (
      <section class="container px-8 py-16 mx-auto">
        <h2 class="mb-8 text-3xl font-bold text-transparent bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text">
          Featured Articles
        </h2>
        <div class="space-y-8">
          {featuredArticles.map((article) => (
            <article class="overflow-hidden transition-all duration-300 border rounded-lg shadow-lg bg-base-200 border-base-300 hover:shadow-xl hover:border-primary/20">
              <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">
                {/* Featured Image */}
                {article.data.featuredImage && imageMap[article.data.featuredImage] && (
                  <div class="lg:col-span-1 h-48 lg:h-full overflow-hidden">
                    <Image 
                      src={imageMap[article.data.featuredImage]} 
                      alt={article.data.featuredImageAlt || article.data.title}
                      class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                      loading="lazy"
                      width={400}
                      height={300}
                    />
                  </div>
                )}
                
                {/* Content */}
                <div class={`p-8 ${article.data.featuredImage ? 'lg:col-span-2' : 'lg:col-span-3'}`}>
                  <div class="flex items-center justify-between mb-4">
                    <div class="badge badge-primary badge-outline">Featured</div>
                    <time class="text-sm text-base-content/60" datetime={article.data.pubDate.toISOString()}>
                      {article.data.pubDate.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                  </div>
                  
                  <h3 class="mb-4 text-2xl font-bold text-base-content">
                    <a href={`/articles/${article.slug}`} class="hover:text-primary transition-colors">
                      {article.data.title}
                    </a>
                  </h3>
                  
                  <p class="mb-6 text-lg text-base-content/80 leading-relaxed">
                    {article.data.description}
                  </p>
                  
                  <div class="flex items-center justify-between">
                    <div class="flex flex-wrap gap-2">
                      {article.data.tags.map((tag) => (
                        <span class="text-xs text-base-content/50 bg-base-300 px-2 py-1 rounded">{tag}</span>
                      ))}
                    </div>
                    <a href={`/articles/${article.slug}`} class="btn btn-primary">
                      Read Article
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- All Articles -->
    {regularArticles.length > 0 && (
      <section class="container px-8 py-16 mx-auto">
        <h2 class="mb-8 text-3xl font-bold text-transparent bg-gradient-to-r from-cyan-400 to-purple-500 bg-clip-text">
          All Articles
        </h2>
        <div class="space-y-6">
          {regularArticles.map((article) => (
            <article class="overflow-hidden transition-all duration-300 border rounded-lg shadow-md bg-base-200 border-base-300 hover:shadow-lg hover:border-primary/20">
              <div class="grid grid-cols-1 lg:grid-cols-4 gap-0">
                {/* Featured Image */}
                {article.data.featuredImage && imageMap[article.data.featuredImage] && (
                  <div class="lg:col-span-1 h-32 lg:h-40 overflow-hidden">
                    <Image 
                      src={imageMap[article.data.featuredImage]} 
                      alt={article.data.featuredImageAlt || article.data.title}
                      class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
                      loading="lazy"
                      width={300}
                      height={200}
                    />
                  </div>
                )}
                
                {/* Content */}
                <div class={`p-6 ${article.data.featuredImage ? 'lg:col-span-3' : 'lg:col-span-4'}`}>
                  <div class="flex items-center justify-between mb-3">
                    <time class="text-sm text-base-content/60" datetime={article.data.pubDate.toISOString()}>
                      {article.data.pubDate.toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </time>
                  </div>
                  
                  <h3 class="mb-3 text-xl font-bold text-base-content">
                    <a href={`/articles/${article.slug}`} class="hover:text-primary transition-colors">
                      {article.data.title}
                    </a>
                  </h3>
                  
                  <p class="mb-4 text-base-content/80 leading-relaxed">
                    {article.data.description}
                  </p>
                  
                  <div class="flex items-center justify-between">
                    <div class="flex flex-wrap gap-2">
                      {article.data.tags.map((tag) => (
                        <span class="text-xs text-base-content/40 bg-base-300 px-2 py-1 rounded">{tag}</span>
                      ))}
                    </div>
                    <a href={`/articles/${article.slug}`} class="btn btn-primary btn-sm">
                      Read More
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    <!-- Newsletter Section -->
    <section class="container px-8 py-16 mx-auto">
      <div class="max-w-2xl p-8 mx-auto text-center border rounded-lg bg-gradient-to-br from-purple-900/10 to-cyan-900/10 border-secondary/20">
        <h2 class="mb-4 text-2xl font-bold text-transparent bg-gradient-to-r from-pink-400 to-purple-500 bg-clip-text">
          Stay Updated
        </h2>
        <p class="mb-6 text-base-content/80">
          Get the latest articles, tutorials, and AI insights delivered to your inbox.
        </p>
        <a href="/#newsletter" class="btn btn-primary">
          Subscribe to Newsletter
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>