---
import Layout from "../layouts/Layout.astro";
import MainNavWithDropdowns from "../components/MainNavWithDropdowns.astro";
import Footer from "../components/Footer.astro";
import TypeformBookingButton from "../components/TypeformBookingButton.tsx";
import ComparisonSlider from "../components/ComparisonSlider.astro";
import Testimonials from "../components/Testimonials.astro";
import LogoGrid from "../components/LogoGrid.astro";

import aiOnTheLot from "../assets/images/events/ai-on-the-lot.jpg";

const pageTitle = "Brutalist Mockup | Magic Mirror";
---

<Layout title={pageTitle} description="Preview the Magic Mirror AI photo booth experience with this interactive mockup.">
  <MainNavWithDropdowns />
  <main id="main-content" class="relative z-10 w-full min-h-screen pt-24 overflow-hidden bg-black text-slate-50 font-inter">
    
    <!-- Hero Container: Brutalist / High Contrast -->
    <section class="relative flex flex-col items-center justify-center w-full min-h-[90vh] px-6 lg:px-12 py-12 lg:py-24">
      
      <!-- Background Image Container (Sharp borders, no blur) -->
      <div class="absolute inset-0 z-0 flex justify-end w-full h-full opacity-40 lg:opacity-60 xl:opacity-100 xl:w-1/2 xl:right-0">
         <img 
            src={aiOnTheLot.src} 
            alt="AI photo booth event" 
            class="object-cover w-full h-full grayscale-[50%] contrast-125 brightness-75"
         />
         <!-- Harsh gradient cut to solid black for text readability on desktop -->
         <div class="absolute inset-0 bg-gradient-to-t xl:bg-gradient-to-r from-black via-black/80 to-transparent"></div>
      </div>

      <!-- Foreground Content: Stark typography, aligned to grid -->
      <div class="container relative z-10 mx-auto max-w-7xl">
        <div class="flex flex-col xl:w-3/5">
          
          <!-- Brutalist Tag / Eyebrow -->
          <div class="inline-flex items-center gap-4 mb-8">
            <span class="w-12 h-1 bg-cyan-400"></span>
            <span class="text-sm font-bold tracking-[0.2em] text-cyan-400 uppercase">Interactive AI Experience</span>
          </div>

          <!-- Massive Title -->
          <h1 class="text-6xl sm:text-7xl lg:text-8xl xl:text-[7rem] font-black leading-[0.9] tracking-tighter text-white uppercase mb-8">
            Magic<br/>
            Mirror<br/>
            <span class="text-fuchsia-500">AI Booth</span>
          </h1>

          <!-- Punchy Description -->
          <p class="max-w-xl pr-4 mb-12 text-xl font-medium leading-relaxed sm:text-2xl text-slate-300">
            Ditch the props. Transform your guests into living art in real-time. The ultimate interactive photography experience for corporate events and brand activations.
          </p>

          <!-- Sharp CTA Buttons -->
          <div class="flex flex-col gap-6 sm:flex-row">
            <TypeformBookingButton
              buttonText="BOOK YOUR EVENT"
              variant="primary"
              size="lg"
              className="px-10 py-5 text-sm font-black tracking-widest text-black uppercase transition-all duration-200 bg-white border-none rounded-none hover:bg-cyan-400 hover:text-black hover:scale-100 hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_rgba(236,72,153,1)]"
              client:load
            />
            
            <a href="#demo" class="inline-flex items-center justify-center px-10 py-5 text-sm font-black tracking-widest text-white uppercase transition-all duration-200 bg-transparent border-2 border-white rounded-none hover:bg-white hover:text-black">
              See How It Works
            </a>
          </div>

          <!-- Solid Stats Bar -->
          <div class="grid w-full grid-cols-2 gap-8 pt-12 mt-16 border-t xl:grid-cols-3 border-white/20">
            <div>
              <p class="text-3xl font-black text-white sm:text-5xl">122k+</p>
              <p class="mt-2 text-sm font-bold tracking-widest text-slate-400 uppercase">Images Gen</p>
            </div>
            <div>
              <p class="text-3xl font-black text-white sm:text-5xl">30+</p>
              <p class="mt-2 text-sm font-bold tracking-widest text-slate-400 uppercase">Art Styles</p>
            </div>
            <div class="hidden xl:block">
              <p class="text-3xl font-black text-white sm:text-5xl">&lt; 3s</p>
              <p class="mt-2 text-sm font-bold tracking-widest text-slate-400 uppercase">Processing Time</p>
            </div>
          </div>
          
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full border-t-[8px] border-white"></div>

    <!-- Features & Video Section: Brutalist Grid -->
    <section class="w-full bg-white text-black" id="demo">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        
        <!-- Text Content Left -->
        <div class="flex flex-col justify-center px-6 py-20 lg:p-24 border-b lg:border-b-0 lg:border-r-[8px] border-black">
          <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black uppercase tracking-tighter leading-[0.9] mb-8">
            Magically<br/>
            Transformed<br/>
            <span class="text-cyan-500">In Real-Time</span>
          </h2>
          
          <div class="space-y-6 text-xl font-medium leading-relaxed max-w-xl">
            <p>Our cutting-edge system captures a photo every 3 seconds and uses generative AI to transform your guests in amazing ways.</p>
            <p>Watch as they become paper origami, felt puppets, comic book heroes, or any of dozens of highly curated artistic styles.</p>
          </div>

          <!-- Brutalist Badges -->
          <div class="flex flex-wrap gap-3 mt-12">
            <span class="px-4 py-2 text-xs font-black tracking-widest uppercase border-[3px] border-black text-black">Real-time Processing</span>
            <span class="px-4 py-2 text-xs font-black tracking-widest uppercase border-[3px] border-black bg-cyan-400 text-black">30+ Art Styles</span>
            <span class="px-4 py-2 text-xs font-black tracking-widest uppercase border-[3px] border-black bg-fuchsia-500 text-white">Instant Prints</span>
          </div>
        </div>

        <!-- Video Right -->
        <div class="relative w-full h-full min-h-[500px] bg-slate-200">
          <div class="absolute inset-0 p-6 lg:p-12 pb-16 lg:pb-20 bg-black flex flex-col justify-between">
            <div class="relative w-full pt-[56.25%] border-[8px] border-white bg-zinc-900">
              <iframe
                src="https://www.youtube.com/embed/vuYqdw3HwDc?controls=0"
                title="Magic Mirror AI Photo Booth Demo Video"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
                class="absolute inset-0 w-full h-full border-0 grayscale-[25%] contrast-125"
              ></iframe>
            </div>
            <p class="mt-6 text-sm font-bold tracking-widest text-cyan-400 uppercase text-center xl:text-left">Watch the magic happen live</p>
          </div>
        </div>

      </div>
    </section>

    <!-- Divider -->
    <div class="w-full border-t-[8px] border-black"></div>

    <!-- Transformation Slider Section: Brutalist -->
    <section class="relative w-full px-6 py-24 bg-black lg:py-32 lg:px-12">
      <div class="container mx-auto max-w-7xl">
        
        <div class="flex flex-col items-start justify-between gap-8 mb-16 lg:flex-row lg:items-end">
          <h2 class="text-5xl lg:text-[5rem] font-black uppercase tracking-tighter leading-[0.9] text-white">
            More Than<br/>
            <span class="text-fuchsia-500">A Filter</span>
          </h2>
          <p class="max-w-sm text-xl font-bold uppercase text-slate-300">
            A truly imaginative transformation. Drag the slider to witness real-time AI magic.
          </p>
        </div>

        <!-- Sharp container for the slider -->
        <div class="w-full border-[8px] border-white bg-zinc-900 p-2 lg:p-4">
          <ComparisonSlider
            beforeImage="/image/holiday-Shot_0003_00807-1Before.jpg"
            beforeAlt="Before transformation - Original photo of guests"
            afterImage="/image/holiday-Shot_0003_00807-2After.jpg"
            afterAlt="After transformation - Guest transformed into paper origami art style"
          />
        </div>

      </div>
    </section>

    <!-- Divider -->
    <div class="w-full border-t-[8px] border-white"></div>

    <!-- Social Proof / Logos: Brutalist -->
    <section class="w-full py-24 bg-cyan-400">
      <div class="container px-6 mx-auto lg:px-12 max-w-7xl">
        <div class="flex flex-col items-center">
          <h2 class="mb-16 text-3xl font-black tracking-tighter text-black uppercase lg:text-5xl">
            Trusted by Industry Leaders
          </h2>
          <div class="w-full p-8 border-[8px] border-black bg-white">
            <LogoGrid />
          </div>
        </div>
      </div>
    </section>

    <!-- Divider -->
    <div class="w-full border-t-[8px] border-black"></div>

    <!-- Testimonials Section -->
    <section class="w-full py-24 bg-white text-black border-b-[8px] border-black">
      <div class="container px-6 mx-auto lg:px-12 max-w-7xl">
        <h2 class="mb-16 text-4xl font-black tracking-tighter text-center uppercase lg:text-6xl text-black">
          Don't Just <span class="text-cyan-500">Take Our Word</span>
        </h2>
        <div class="p-8 border-[8px] border-black bg-zinc-100">
           <!-- Note: we reuse the existing testimonials component, but placed inside a brutalist container -->
           <Testimonials />
        </div>
      </div>
    </section>

    <!-- Final CTA Section: Brutalist -->
    <section class="w-full px-6 py-32 bg-fuchsia-500 lg:px-12">
      <div class="container mx-auto text-center max-w-7xl">
        <h2 class="text-5xl lg:text-[6xl] xl:text-[8xl] font-black uppercase tracking-tighter leading-[0.9] text-white mb-12">
          Ready to wow<br/>
          <span class="text-black">your guests?</span>
        </h2>
        
        <TypeformBookingButton
          buttonText="CHECK AVAILABILITY NOW"
          variant="primary"
          size="lg"
          className="px-12 py-6 text-xl font-black tracking-widest text-black uppercase transition-all duration-200 bg-cyan-400 border-4 border-black rounded-none hover:bg-white hover:scale-100 hover:-translate-y-2 hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]"
          client:load
        />
        
        <div class="flex flex-col items-center justify-center gap-6 mt-16 sm:flex-row sm:gap-12">
          <a href="mailto:booking@davantsystems.com" class="inline-flex items-center gap-4 text-xl font-bold text-black uppercase transition-all hover:text-white group">
            <span class="p-3 border-4 border-black bg-white group-hover:bg-black group-hover:border-white transition-colors duration-200">
              <svg class="w-6 h-6 text-black group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
              </svg>
            </span>
            booking@davantsystems.com
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  /* Base custom minimalist typography settings */
  .font-inter {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }
</style>
