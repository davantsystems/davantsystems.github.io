---
import Layout from "../../layouts/Layout.astro";
import MainNavWithDropdowns from "../../components/MainNavWithDropdowns.astro";
import Footer from "../../components/Footer.astro";
import PurchaseCard from "../../components/PurchaseCard.astro";
import RequirementsPane from "../../components/RequirementsPane.astro";
import SupportCTA from "../../components/SupportCTA.astro";
import hero2 from "../../assets/images/hero2.png";
import davantStudioMac from "../../assets/images/DavantStudio_app_mac_defaultmountain_1.png";
import davantStudioPhotoshop from "../../assets/images/davant-studio-photoshop-screenshot.jpg";

const pageTitle = "Davant Systems | Supercharge your creative workflow";
---

<Layout title={pageTitle} description="AI image generation software for creative professionals. Run Stable Diffusion locally with an intuitive interface.">
  <script slot="jsonLd" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Davant Studio",
    applicationCategory: "MultimediaApplication",
    operatingSystem: "Windows, macOS",
    description: "AI image generation software for creative professionals. Run Stable Diffusion locally with an intuitive interface.",
    url: "https://www.davantsystems.com/davant-studio",
    image: "https://www.davantsystems.com/image/press/DavantSystems-logo-1000.png",
    offers: [
      {
        "@type": "Offer",
        name: "Free",
        price: "0",
        priceCurrency: "USD",
      },
      {
        "@type": "Offer",
        name: "Pro",
        priceCurrency: "USD",
      },
    ],
    publisher: {
      "@type": "Organization",
      name: "Davant Systems",
      url: "https://www.davantsystems.com",
    },
  })} />
  <MainNavWithDropdowns />
  <main id="main-content" class="">
    <section class="border-b-2 hero__wrapper border-slate-400/5">
      <div
        class="relative flex flex-col items-center justify-center min-h-screen pt-12 overflow-hidden hero sm:flex-row"
      >
        <div
          class="relative z-20 flex flex-col items-center pt-8 pb-20 text-center hero-content text-neutral-content"
        >
          <div class="flex flex-col items-center mb-2">
            <div class="relative flex flex-col items-center cta-wrapper">
              <div
                class="flex flex-col max-w-6xl px-4 mx-auto software-spotlight sm:flex-row"
              >
                <div
                  class="flex flex-col pt-4 mx-auto text-left sm:pt-1 md:pt-24 sm:mr-8 text"
                >
                  <h1
                    class="mb-4 font-light text-transparent bg-gradient-to-tr from-pink-400 via-fuchsia-500 to-purple-800 bg-clip-text"
                  >
                    <span
                      class="-mb-4 text-5xl font-bold sm:text-4xl md:text-6xl lg:text-6xl"
                      >Davant
                    </span><span
                      class="text-5xl leading-tight sm:text-4xl md:text-6xl lg:text-6xl"
                      >Studio</span
                    >
                  </h1>

                  <p
                    class="mb-12 text-transparent font-extralight bg-gradient-to-tr from-pink-400 via-fuchsia-500 to-purple-800 bg-clip-text"
                  >
                    <span
                      class="block -mb-1 text-3xl font-extrabold sm:text-4xl md:text-4xl lg:text-4xl"
                      >AI image tools <span class="font-extralight">for</span>
                    </span><span
                      class="block text-3xl leading-tight sm:text-4xl md:text-4xl lg:text-4xl"
                      >creative professionals</span
                    >
                  </p>

                  <div class="relative flex flex-col gap-4 ml-0 md:flex-row">
                    <div class="text-sm">
                      <a
                        class="relative z-10 w-auto pl-0 pr-4 mt-4 mb-1 text-sm font-semibold text-white transition-all duration-300 rounded-md shadow-lg border-white/10 btn btn-primary indicator bg-gradient-to-r from-purple-500/80 to-pink-500/80 hover:from-purple-500 hover:to-pink-500 hover:scale-105 backdrop-blur-md"
                        href="https://mailchi.mp/davantsystems/davant-studio-free-download"
                      >
                        <span
                          class="p-2 bg-transparent rounded-full badge-neutral"
                        >
                          <svg
                            class="stroke-neutral"
                            width="22px"
                            height="22px"
                            viewBox="0 0 24 24"
                            fill="none"
                            xmlns="http://www.w3.org/2000/svg"
                            stroke="#ffffff"
                          >
                            <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                            <g
                              id="SVGRepo_tracerCarrier"
                              stroke-linecap="round"
                              stroke-linejoin="round"></g>
                            <g id="SVGRepo_iconCarrier">
                              <path
                                d="M8 22.0002H16C18.8284 22.0002 20.2426 22.0002 21.1213 21.1215C22 20.2429 22 18.8286 22 16.0002V15.0002C22 12.1718 22 10.7576 21.1213 9.8789C20.3529 9.11051 19.175 9.01406 17 9.00195M7 9.00195C4.82497 9.01406 3.64706 9.11051 2.87868 9.87889C2 10.7576 2 12.1718 2 15.0002L2 16.0002C2 18.8286 2 20.2429 2.87868 21.1215C3.17848 21.4213 3.54062 21.6188 4 21.749"
                                stroke-width="1.5"
                                stroke-linecap="round"></path>
                              <path
                                d="M12 2L12 15M12 15L9 11.5M12 15L15 11.5"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path>
                            </g>
                          </svg>
                        </span>
                        <span class="pt-1">Download Free Version</span>
                      </a>
                      <div class="pt-1">
                        <p class="pt-1 mb-4 text-xs text-center">
                          No credit card required
                        </p>
                      </div>
                    </div>

                    <div class="">
                      <a
                        class="relative w-auto mt-4 mb-2 text-sm text-white transition-all duration-300 rounded-md shadow-md border-white/20 btn-outline btn md:text-sm indicator hover:scale-105 bg-base-300/50 backdrop-blur-sm hover:bg-base-300/80"
                        href="#signup"
                      >
                        <span class="pt-1">View Premium Features</span>
                      </a>
                      <div class="">
                        <p class="pt-1 mb-4 text-xs text-center">
                          $30/month, cancel anytime
                        </p>
                      </div>
                    </div>
                  </div>
                  <div class="flex mx-auto mt-8 text-xs">
                    <div class="flex items-center mr-4 align-center">
                      <svg
                        height="22px"
                        width="24px"
                        class="item-start stroke-white fill-white"
                        version="1.1"
                        id="Capa_1"
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 452.986 452.986"
                        fill="#ffffff"
                        ><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g
                          id="SVGRepo_tracerCarrier"
                          stroke-linecap="round"
                          stroke-linejoin="round"></g><g
                          id="SVGRepo_iconCarrier"
                        >
                          <g>
                            <g>
                              <path
                                d="M165.265,53.107L21.689,81.753v132.531l143.575-2.416V53.107 M431.297,245.583l-233.18-3.991 v164.822l233.18,46.571V245.583 M165.265,241.097l-143.575-2.438v132.509l143.575,28.668V241.097 M431.297,0l-233.18,46.528 v164.822l233.18-3.969V0"
                              ></path>
                            </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                            <g> </g>
                          </g>
                        </g>
                      </svg>
                      <p class="mt-auto mb-auto ml-1 align-center">Windows</p>
                    </div>
                    <div class="flex items-center mr-4 align-center">
                      <svg
                        width="22px"
                        height="22px"
                        class="item-start stroke-white fill-white"
                        viewBox="-1.5 0 20 20"
                        version="1.1"
                        xmlns="http://www.w3.org/2000/svg"
                        fill="#fff"
                      >
                        <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                        <g
                          id="SVGRepo_tracerCarrier"
                          stroke-linecap="round"
                          stroke-linejoin="round"></g>
                        <g id="SVGRepo_iconCarrier">
                          <title>apple [#173]</title>
                          <desc>Created with Sketch.</desc>
                          <defs> </defs>
                          <g
                            id="Page-1"
                            stroke-width="0.0002"
                            fill-rule="evenodd"
                          >
                            <g
                              id="Dribbble-Light-Preview"
                              transform="translate(-102.000000, -7439.000000)"
                            >
                              <g
                                id="icons"
                                transform="translate(56.000000, 160.000000)"
                              >
                                <path
                                  d="M57.5708873,7282.19296 C58.2999598,7281.34797 58.7914012,7280.17098 58.6569121,7279 C57.6062792,7279.04 56.3352055,7279.67099 55.5818643,7280.51498 C54.905374,7281.26397 54.3148354,7282.46095 54.4735932,7283.60894 C55.6455696,7283.69593 56.8418148,7283.03894 57.5708873,7282.19296 M60.1989864,7289.62485 C60.2283111,7292.65181 62.9696641,7293.65879 63,7293.67179 C62.9777537,7293.74279 62.562152,7295.10677 61.5560117,7296.51675 C60.6853718,7297.73474 59.7823735,7298.94772 58.3596204,7298.97372 C56.9621472,7298.99872 56.5121648,7298.17973 54.9134635,7298.17973 C53.3157735,7298.17973 52.8162425,7298.94772 51.4935978,7298.99872 C50.1203933,7299.04772 49.0738052,7297.68074 48.197098,7296.46676 C46.4032359,7293.98379 45.0330649,7289.44985 46.8734421,7286.3899 C47.7875635,7284.87092 49.4206455,7283.90793 51.1942837,7283.88393 C52.5422083,7283.85893 53.8153044,7284.75292 54.6394294,7284.75292 C55.4635543,7284.75292 57.0106846,7283.67793 58.6366882,7283.83593 C59.3172232,7283.86293 61.2283842,7284.09893 62.4549652,7285.8199 C62.355868,7285.8789 60.1747177,7287.09489 60.1989864,7289.62485"
                                  id="apple-[#173]"
                                >
                                </path>
                              </g>
                            </g>
                          </g>
                        </g>
                      </svg>
                      <p class="ml-1">Mac</p>
                    </div>
                  </div>
                </div>

                <div
                  class="relative mb-0 ml-0 space-x-2 bg-transparent border-0 border-indigo-950/50 screenshot-carousel wrapper__screenshots sm:w-60 md:w-1/2"
                >
                  <div class="relative shadow-md item">
                    <img
                      class="z-10 w-full"
                      src={davantStudioMac.src}
                      alt="Screenshot of Davant Studio software"
                    />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div
          class="absolute bottom-0 block h-full min-w-full -translate-x-1/2 background-image left-1/2 z-1"
        >
          <img
            class="relative block object-cover w-full h-full hero__background-image"
            src={hero2.src}
            alt="Screenshot of Davant Studio software"
          />
          <div
            class="absolute bottom-0 left-0 z-10 w-full gradient-fade pb-28 bg-gradient-to-b from-transparent to-base-300"
          >
          </div>
        </div>
      </div>

      <section class="container px-4 py-20 mx-auto">
        <div class="max-w-2xl mx-auto mb-12">
          <h2
            class="pr-4 mx-auto mb-8 text-xl font-bold text-transparent bg-clip-text bg-gradient-to-bl from-violet-400 via-cyan-400 to-blue-500 md:text-2xl lg:text-3xl"
          >
            Your real-time art & design assistant
          </h2>
          <p class="mb-2 text-xl">
            Design, paint & create in your favorite creative programs.
          </p>
          <p class="mb-2 text-xl">
            Generate & control unlimited enhanced versions of your
            image.
          </p>
          <p class="mb-2 text-xl">
            All on <em>your</em> local computer for 100% privacy & power.
          </p>
        </div>
        <div class="relative block p-2 mb-2">
          <img
            class="relative z-10 block w-full"
            src={davantStudioPhotoshop.src}
            loading="lazy"
            alt="Davant Studio and Photoshop"
          />
          <div
            class="absolute top-0 left-0 block w-full h-full bg-gradient-to-br from-pink-400/20 via-fuchsia-500/20 to-purple-500/20"
          >
          </div>
        </div>
        <p class="italic text-right text-md text-cyan-100">Photoshop</p>
      </section>

      <section class="container px-4 py-24 mx-auto">
        <div class="max-w-6xl mx-auto">
          <div class="mb-16 text-center">
            <h2 class="mb-4 text-4xl font-bold md:text-5xl lg:text-5xl">
              <span
                class="text-transparent bg-gradient-to-bl from-violet-400 via-cyan-400 to-blue-500 bg-clip-text"
                >Professional Features</span
              >
            </h2>
            <p class="max-w-2xl mx-auto text-lg text-cyan-100/80">
              Everything you need to accelerate your creative workflow and
              deliver stunning results faster than ever before.
            </p>
          </div>

          <!-- Features Grid -->
          <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            <!-- Performance Features -->
            <div
              class="relative p-8 transition-all duration-300 border rounded-2xl bg-base-300/40 backdrop-blur-sm border-white/5 hover:border-white/20 hover:shadow-xl hover:bg-base-300/60 group"
            >
              <div class="flex items-start mb-4">
                <div class="p-3 rounded-lg bg-purple-500/20">
                  <svg
                    class="w-6 h-6 text-purple-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
              </div>
              <h3 class="mb-3 text-xl font-bold text-white">
                Lightning-Fast Generation
              </h3>
              <p class="text-sm leading-relaxed text-cyan-100/70">
                Generate variations in seconds, not minutes. Real-time AI engine
                optimized for creative professionals.
              </p>
              <div
                class="absolute transition-opacity opacity-0 top-4 right-4 group-hover:opacity-100"
              >
                <span
                  class="px-2 py-1 text-xs font-medium text-purple-300 rounded bg-purple-500/20"
                  >Performance</span
                >
              </div>
            </div>

            <div
              class="relative p-8 transition-all duration-300 border rounded-2xl bg-base-300/40 backdrop-blur-sm border-white/5 hover:border-white/20 hover:shadow-xl hover:bg-base-300/60 group"
            >
              <div class="flex items-start mb-4">
                <div class="p-3 rounded-lg bg-purple-500/20">
                  <svg
                    class="w-6 h-6 text-purple-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"
                    ></path>
                  </svg>
                </div>
              </div>
              <h3 class="mb-3 text-xl font-bold text-white">Precise Control</h3>
              <p class="text-sm leading-relaxed text-cyan-100/70">
                Professional-grade controls for every parameter. Fine-tune your
                vision with surgical precision.
              </p>
              <div
                class="absolute transition-opacity opacity-0 top-4 right-4 group-hover:opacity-100"
              >
                <span
                  class="px-2 py-1 text-xs font-medium text-purple-300 rounded bg-purple-500/20"
                  >Control</span
                >
              </div>
            </div>

            <div
              class="relative p-8 transition-all duration-300 border rounded-2xl bg-base-300/40 backdrop-blur-sm border-white/5 hover:border-white/20 hover:shadow-xl hover:bg-base-300/60 group"
            >
              <div class="flex items-start mb-4">
                <div class="p-3 rounded-lg bg-purple-500/20">
                  <svg
                    class="w-6 h-6 text-purple-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                    ></path>
                  </svg>
                </div>
              </div>
              <h3 class="mb-3 text-xl font-bold text-white">
                100% Private & Secure
              </h3>
              <p class="text-sm leading-relaxed text-cyan-100/70">
                Your creative work never leaves your computer. Complete privacy
                and data ownership guaranteed.
              </p>
              <div
                class="absolute transition-opacity opacity-0 top-4 right-4 group-hover:opacity-100"
              >
                <span
                  class="px-2 py-1 text-xs font-medium text-purple-300 rounded bg-purple-500/20"
                  >Privacy</span
                >
              </div>
            </div>

            <div
              class="relative p-8 transition-all duration-300 border rounded-2xl bg-base-300/40 backdrop-blur-sm border-white/5 hover:border-white/20 hover:shadow-xl hover:bg-base-300/60 group"
            >
              <div class="flex items-start mb-4">
                <div class="p-3 rounded-lg bg-purple-500/20">
                  <svg
                    class="w-6 h-6 text-purple-400"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"
                    ></path>
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
