        <div
          id="download-button"
          class="relative flex flex-col items-center justify-center pt-24 pb-24 overflow-hidden text-cyan-200"
        >
          <!-- Subtle light effect behind cards -->
          <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[400px] -z-10"
          >
            <div
              class="absolute inset-0 rounded-full bg-purple-600/10 blur-3xl animate-pulse"
              style="animation-duration: 4s;"
            >
            </div>
            <div class="absolute rounded-full inset-4 bg-purple-500/5 blur-2xl">
