---

<footer class="relative z-30">

  <!-- Main footer content -->
  <div class="bg-base-300">
    <div class="max-w-6xl px-6 pt-16 pb-10 mx-auto">
      <!-- Top section: Logo + Nav columns -->
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12">

        <!-- Brand column -->
        <div class="lg:col-span-4">
          <a href="/" class="inline-block mb-4 transition-opacity hover:opacity-80">
            <Image src={Logo} alt="Davant Systems" width={140} height={56} class="block object-contain" />
          </a>
          <p class="max-w-xs text-sm leading-relaxed text-gray-400">
            AI-powered creative tools for designers, artists, and visual arts professionals.
          </p>

          <!-- Social icons -->
          <div class="flex gap-3 mt-6">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Follow us on ${social.platform}`}
                class="flex items-center justify-center w-9 h-9 rounded-lg border border-gray-700 text-gray-500 transition-all duration-200 hover:text-cyan-300 hover:border-cyan-700 hover:bg-cyan-900"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
                  <path d={social.path} />
                </svg>
              </a>
            ))}
          </div>
        </div>

        <!-- Products column -->
        <nav class="lg:col-span-3" aria-label="Products">
          <h3 class="mb-4 text-xs font-bold tracking-widest uppercase text-gray-500">Products</h3>
          <ul class="flex flex-col gap-4">
            {productLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-400 transition-colors duration-200 hover:text-cyan-300">
                  {link.label}
                </a>
                {link.children && (
                  <ul class="flex flex-col gap-1 mt-0 ml-3 mb-2">
                    {link.children.map((child) => (
                      <li>
                        <a
                          href={child.href}
                          class="text-xs text-gray-500 transition-colors duration-200 hover:text-cyan-300"
                          {...(child.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>

        <!-- Community column -->
        <nav class="lg:col-span-3" aria-label="Community">
          <h3 class="mb-4 text-xs font-bold tracking-widest uppercase text-gray-500">Community</h3>
          <ul class="flex flex-col gap-2.5">
            {communityLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-gray-400 transition-colors duration-200 hover:text-cyan-300"
                  {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Company column -->
        <nav class="lg:col-span-2" aria-label="Company">
          <h3 class="mb-4 text-xs font-bold tracking-widest uppercase text-gray-500">Company</h3>
          <ul class="flex flex-col gap-2.5">
            {companyLinks.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-gray-400 transition-colors duration-200 hover:text-cyan-300">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>

      <!-- Bottom bar -->
      <div class="pt-8 mt-12 border-t border-gray-700">
        <p class="text-xs text-gray-500">
          &copy; {currentYear} Davant Systems. All rights reserved.
        </p>
      </div>
    </div>
  </div>
</footer>

<!-- Bottom gradient fade overlay -->
<div
  class="fixed bottom-0 left-0 z-10 block w-full scale-y-50 pointer-events-none opacity-70 translate-y-1/4 bg h-1/6 bg-gradient-to-b from-transparent to-base-300"
></div>
