---
import MailchimpForm from "./MailchimpForm.astro";
---

<div class="flex flex-col max-w-4xl py-10 mx-auto md:flex-row md:items-center">
  <div class="block w-full pt-8 mb-10 md:p-4 md:w-1/2 basis-full">
    <h2
      class="mb-8 text-3xl md:text-5xl leading-10 text-transparent bg-gradient-to-r from-purple-300 to-pink-300 bg-clip-text"
    >
      Get updates <br /><span
        class="block mt-2 pl-1 text-2xl sm:text-3xl text-cyan-100"
        >in our email newsletter</span
      >
    </h2>
    <div class="pl-1 pr-4 mb-4 text-cyan-100">
      <p class="mb-2">The best way to get "official" updates.</p>
      <p>Product updates, event info, and updates in AI.</p>
    </div>
  </div>
  <div
    class="relative block w-full px-4 pt-8 pb-6 border rounded-xl shadow-lg sm:px-6 md:px-10 bg-base-300/40 md:w-1/2 basis-full min-w-sm md:px-4 lg:px-10 border-white/10 backdrop-blur-sm"
  >
    <MailchimpForm />
  </div>
</div>
