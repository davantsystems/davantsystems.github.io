---
export interface Props {
  value: string;
  label: string;
  delay?: number;
  countTo?: number;
  animationDelay?: number;
}

const { value, label, delay = 0, countTo, animationDelay = 0 } = Astro.props;

// Generate unique animation class based on delay
const animationDelayClass = animationDelay === 0 ? '' : animationDelay === 1 ? '-delay-1' : '-delay-2';
---

<div class="relative group">
  <div class={`absolute inset-0 bg-gradient-to-br from-primary/5 to-primary/10 rounded-2xl blur-xl animate-backdrop-pulse${animationDelayClass}`}></div>
  <div class={`relative p-10 text-center border bg-base-100/90 backdrop-blur-sm rounded-2xl border-base-content/10 animate-stat-glow${animationDelayClass}`}>
    <div 
      class="mb-2 text-5xl font-black lg:text-6xl text-slate-100 animate-count" 
      data-count={countTo}
      data-delay={delay}
    >
      {value}
    </div>
    <p class="text-lg text-slate-200 animate-count" data-delay={delay}>{label}</p>
  </div>
</div>

<style>
  @keyframes stat-glow {
    0%, 100% {
      border-color: rgba(139, 92, 246, 0.1);
      box-shadow: 0 0 20px rgba(139, 92, 246, 0.05);
    }
    50% {
      border-color: rgba(139, 92, 246, 0.3);
      box-shadow: 0 0 40px rgba(139, 92, 246, 0.15), 0 0 60px rgba(139, 92, 246, 0.1);
    }
  }

  @keyframes backdrop-pulse {
    0%, 100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.7;
    }
  }

  .animate-backdrop-pulse {
    animation: backdrop-pulse 4s ease-in-out infinite;
  }

  .animate-backdrop-pulse-delay-1 {
    animation: backdrop-pulse 4s ease-in-out infinite;
    animation-delay: 0.33s;
  }

  .animate-backdrop-pulse-delay-2 {
    animation: backdrop-pulse 4s ease-in-out infinite;
    animation-delay: 0.66s;
  }

  .animate-stat-glow {
    animation: stat-glow 4s ease-in-out infinite;
  }

  .animate-stat-glow-delay-1 {
    animation: stat-glow 4s ease-in-out infinite;
    animation-delay: 1.33s;
  }

  .animate-stat-glow-delay-2 {
    animation: stat-glow 4s ease-in-out infinite;
    animation-delay: 2.66s;
  }

  .animate-count {
    opacity: 0;
    transform: translateY(20px);
    animation: fade-in-up 0.6s ease-out forwards;
    animation-fill-mode: both;
  }
  
  @keyframes fade-in-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>