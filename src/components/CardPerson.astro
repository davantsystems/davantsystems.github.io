---
export interface Props {
  headline: string;
  name: string;
  email: string;
}

const { headline, name, email } = Astro.props;
---

<div
  class="relative px-4 py-10 overflow-hidden border-0 rounded-2xl border-opacity-10 border-success lg:px-8 lg:py-20 text-terminal"
>
  <div class="relative z-10 block content">
    <h4
      class="mb-4 text-xl font-bold sm:text-3xl md:text-3xl lg:text-4xl lg:mb-6 miniblur"
    >
      {headline}
    </h4>
    <p class="mb-3 text-sm lg:text-lg">{name}</p>
    <a
      class="text-sm font-bold link-hover"
      href={`mailto:${email}`}>{email}</a
    >
  </div>
  <div
    class="absolute inset-0 z-0 bg-linear-to-br from-purple-950 via-teal-800 to-black opacity-10"
  >
  </div>
</div>

<style>
  .text-terminal {
    color: oklch(0.860572 0.115038 178.625);
  }
  .miniblur {
    text-shadow:
      0em -0.01em 0.01em oklch(0.860572 0.115038 178.625 / 0.4),
      0 0 0.02em oklch(0.860572 0.115038 178.625 / 0.3),
      0 0 0.08em oklch(0.860572 0.115038 178.625 / 0.2),
      0 0 0.12em oklch(0.860572 0.115038 178.625 / 0.15);
  }
</style>
