---
export interface Props {
  href?: string;
  onClick?: string;
  variant?: 'primary' | 'secondary';
  size?: 'md' | 'lg';
  class?: string;
  [key: string]: any;
}

const { 
  href, 
  onClick, 
  variant = 'primary', 
  size = 'lg',
  class: className = '',
  ...rest 
} = Astro.props;

const isLink = !!href;
const Element = isLink ? 'a' : 'button';

const baseClasses = 'relative font-semibold group overflow-hidden transform transform-origin-center transition-all duration-300';

const sizeClasses = {
  md: 'btn btn-md px-8 sm:px-10',
  lg: 'btn btn-lg px-10 py-4 text-lg'
};

const variantClasses = {
  primary: 'bg-gradient-to-r from-pink-500 via-fuchsia-500 to-purple-600 hover:from-pink-600 hover:via-fuchsia-600 hover:to-purple-700 text-white border-0 shadow-xl shadow-purple-500/30 hover:scale-[1.02] hover:shadow-2xl hover:shadow-purple-500/50',
  secondary: 'border-2 btn-outline border-slate-400/50 text-slate-300 hover:bg-blue-500/15 hover:border-blue-400 hover:text-slate-200 backdrop-blur-sm'
};

const classes = `${baseClasses} ${sizeClasses[size]} ${variantClasses[variant]} ${className}`;

const elementProps = {
  class: classes,
  ...(isLink ? { href } : {}),
  ...(onClick ? { onclick: onClick } : {}),
  ...rest
};
---

<Element {...elementProps}>
  <span class="relative z-10 tracking-wide">
    <slot />
  </span>
  {variant === 'primary' ? (
    <>
      <span class="absolute inset-0 transition-transform duration-700 ease-out -translate-x-full pointer-events-none bg-gradient-to-r from-white/0 via-white/20 to-white/0 group-hover:translate-x-full"></span>
      <span class="absolute inset-0 transition-opacity duration-300 rounded-lg opacity-0 pointer-events-none bg-white/10 group-hover:opacity-100"></span>
    </>
  ) : (
    <span class="absolute inset-0 transition-transform duration-700 ease-out -translate-x-full pointer-events-none bg-gradient-to-r from-blue-500/0 via-blue-500/10 to-blue-500/0 group-hover:translate-x-full"></span>
  )}
</Element>

<style>
  /* Button shadow styles */
  .shadow-xl.shadow-purple-500\/30 {
    box-shadow: 0 20px 40px rgba(168, 85, 247, 0.3), 0 0 30px rgba(168, 85, 247, 0.2);
  }

  .hover\:shadow-2xl.hover\:shadow-purple-500\/50:hover {
    box-shadow: 0 25px 50px rgba(168, 85, 247, 0.5), 0 0 40px rgba(168, 85, 247, 0.3);
  }
</style>