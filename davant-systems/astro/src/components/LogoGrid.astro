---
import logoRalphLauren from '../assets/images/logos/logo-RalphLauren-white.png';
import logoAMD from '../assets/images/logos/logo-AMD-white.png';
import logoUCLA from '../assets/images/logos/logo-UCLA-white.png';
import logoAsus from '../assets/images/logos/logo-Asus-white.png';
import logoHackaday from '../assets/images/logos/logo-Hackaday-white.png';
import logoVanJones from '../assets/images/logos/logo-VanJones-white.png';
import logoTechWeekLA from '../assets/images/logos/logo-TechWeekLA-white.png';
import logoSilverdraft from '../assets/images/logos/logo-silverdraft.png';
import logoAILA from '../assets/images/logos/logo-AILA-white.png';
import logoAIMVS from '../assets/images/logos/logo-AIMVS-white.png';
import logoCuriousRefuge from '../assets/images/logos/logo-CuriousRefuge-white.png';
import logoGlobalObjects from '../assets/images/logos/logo-GlobalObjects-white.png';
import logoNFMLA from '../assets/images/logos/logo-NFMLA-white.png';
import logoXRM from '../assets/images/logos/logo-XRM-white.png';
import logoBruinAI from '../assets/images/logos/logo-BruinAI-white.png';
import logoPugetSystems from '../assets/images/logos/logo-PugetSystems-white.png';
import logoNuleep from '../assets/images/logos/logo-Nuleep-white.png';
import logoFbrcAI from '../assets/images/logos/logo-FbrcAI-white.png';
import logoImmerseStudio from '../assets/images/logos/logo-ImmerseStudio-white.png';

const logos = [
  { src: logoRalphLauren.src, alt: "Ralph Lauren logo", grid: "first" },
  { src: logoAMD.src, alt: "AMD logo", grid: "first" },
  { src: logoUCLA.src, alt: "UCLA logo", grid: "first" },
  { src: logoAsus.src, alt: "Asus logo", grid: "first" },
  { src: logoHackaday.src, alt: "Hackaday logo", grid: "second" },
  { src: logoVanJones.src, alt: "Van Jones logo", grid: "second" },
  { src: logoTechWeekLA.src, alt: "TechWeek LA logo", grid: "second" },
  { src: logoSilverdraft.src, alt: "Silverdraft logo", grid: "second" },
  { src: logoAILA.src, alt: "AILA logo", grid: "second" },
  { src: logoAIMVS.src, alt: "AIMVS logo", grid: "second" },
  { src: logoCuriousRefuge.src, alt: "CuriousRefuge logo", grid: "second" },
  { src: logoGlobalObjects.src, alt: "GlobalObjects logo", grid: "second" },
  { src: logoNFMLA.src, alt: "NFMLA logo", grid: "second" },
  { src: logoXRM.src, alt: "XRM logo", grid: "second" },
  { src: logoBruinAI.src, alt: "BruinAI logo", grid: "second" },
  { src: logoPugetSystems.src, alt: "PugetSystems logo", grid: "second" },
  { src: logoNuleep.src, alt: "Nuleep logo", grid: "second" },
  { src: logoFbrcAI.src, alt: "FbrcAI logo", grid: "second" },
  { src: logoImmerseStudio.src, alt: "ImmerseStudio logo", grid: "second" }
];

const firstGridLogos = logos.filter(logo => logo.grid === "first");
const secondGridLogos = logos.filter(logo => logo.grid === "second");
---

<style>
  @keyframes logo-glow-pulse {
    0%, 80%, 100% {
      opacity: 0.7;
      filter: drop-shadow(0 0 2px rgba(255, 255, 255, 0.2));
    }
    10% {
      opacity: 1;
      filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.6)) 
              drop-shadow(0 0 3px rgba(255, 255, 255, 0.4));
    }
  }

  @keyframes logo-fade {
    from {
      opacity: 0;
      transform: translateY(10px);
      filter: drop-shadow(0 0 0px rgba(255, 255, 255, 0));
    }
    to {
      opacity: 0.7;
      transform: translateY(0);
      filter: drop-shadow(0 0 2px rgba(255, 255, 255, 0.2));
    }
  }

  .logo-with-glow {
    animation: logo-fade 0.8s ease-out forwards, 
               logo-glow-pulse 6s ease-in-out infinite;
    animation-fill-mode: forwards;
  }

  /* Staggered animation delays - fade happens quickly, glow is staggered */
  .logo-delay-0 { animation-delay: 0s, 0s; }
  .logo-delay-1 { animation-delay: 0.1s, 0.3s; }
  .logo-delay-2 { animation-delay: 0.2s, 0.6s; }
  .logo-delay-3 { animation-delay: 0.3s, 0.9s; }
  .logo-delay-4 { animation-delay: 0.4s, 1.2s; }
  .logo-delay-5 { animation-delay: 0.5s, 1.5s; }
  .logo-delay-6 { animation-delay: 0.6s, 1.8s; }
  .logo-delay-7 { animation-delay: 0.7s, 2.1s; }
  .logo-delay-8 { animation-delay: 0.8s, 2.4s; }
  .logo-delay-9 { animation-delay: 0.9s, 2.7s; }
  .logo-delay-10 { animation-delay: 1.0s, 3.0s; }
  .logo-delay-11 { animation-delay: 1.1s, 3.3s; }
  .logo-delay-12 { animation-delay: 1.2s, 3.6s; }
  .logo-delay-13 { animation-delay: 1.3s, 3.9s; }
  .logo-delay-14 { animation-delay: 1.4s, 4.2s; }
  .logo-delay-15 { animation-delay: 1.5s, 4.5s; }
  .logo-delay-16 { animation-delay: 1.6s, 4.8s; }
  .logo-delay-17 { animation-delay: 1.7s, 5.1s; }
  .logo-delay-18 { animation-delay: 1.8s, 5.4s; }
</style>

<>
  <div class="grid grid-cols-2 gap-4 sm:grid-cols-4 lg:grid-cols-4 lg:mb-8">
    {firstGridLogos.map((logo, index) => (
      <div class="flex items-center justify-center px-6 py-2 sm:py-4 sm:px-2 sm:px-4 md:px-8 sm:py-2">
        <img
          src={logo.src}
          loading="lazy"
          alt={logo.alt}
          class={`max-w-full h-auto opacity-0 logo-with-glow logo-delay-${index}`}
        />
      </div>
    ))}
  </div>
  <div class="grid grid-cols-4 gap-4 lg:grid-cols-7">
    {secondGridLogos.map((logo, index) => (
      <div class="flex items-center justify-center px-2 py-2 sm:px-4 md:px-8 sm:py-0">
        <img
          src={logo.src}
          loading="lazy"
          alt={logo.alt}
          class={`max-w-full h-auto opacity-0 logo-with-glow logo-delay-${index + firstGridLogos.length}`}
        />
      </div>
    ))}
  </div>
</>