---
import Link from './Link.astro';
import NavbarLogo from './NavbarLogo.astro';

const davantStudioStripePortal = "https://billing.stripe.com/p/login/6oEg26f8K3697yE144";
---

<div class="fixed top-0 z-50 border-purple-700/30 navbar bg-gradient-to-b from-black via-black/80 to-base-300/100 border-b-1" data-nav-component>
  <div class="justify-start navbar-start">
    <Link class="px-0 py-0 btn btn-ghost" href="/">
      <NavbarLogo />
    </Link>
  </div>
  <div class="hidden gap-2 navbar-center md:flex">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost">Davant Studio</div>
      <ul tabindex="0" class="dropdown-content menu bg-base-100/95 backdrop-blur-sm rounded-md z-[1] w-52 p-2 shadow-lg border border-purple-500/30">
        <li><a href="/davant-studio/" class="hover:bg-primary/10">Software Overview</a></li>
        <li><a href="/davant-studio/download/" class="hover:bg-primary/10">Download</a></li>
      </ul>
    </div>
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost">Magic Mirror</div>
      <ul tabindex="0" class="dropdown-content menu bg-base-100/95 backdrop-blur-sm rounded-md z-[1] w-52 p-2 shadow-lg border border-purple-500/30">
        <li><a href="/photobooth/" class="hover:bg-primary/10">AI Photo Booth</a></li>
        <li><a href="/event-galleries/" class="hover:bg-primary/10">Event Galleries</a></li>
      </ul>
    </div>
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost">Learn & Create</div>
      <ul tabindex="0" class="dropdown-content menu bg-base-100/95 backdrop-blur-sm rounded-md z-[1] w-52 p-2 shadow-lg border border-purple-500/30">
        <li><a href="/training/" class="hover:bg-primary/10">Training & Workshops</a></li>
        <li><a href="/articles/" class="hover:bg-primary/10">Articles</a></li>
        <li><a href="/ambassadors/" class="hover:bg-primary/10">Creative Ambassadors Program</a></li>
        <li><a href="https://civitai.com/user/David_Davant_Systems" target="_blank" rel="noopener noreferrer" class="hover:bg-primary/10">Research on CivitAI</a></li>
      </ul>
    </div>
  </div>
  <div class="navbar-end">
    <a class="btn btn-outline btn-secondary btn-xs" href={davantStudioStripePortal} target="_blank">Manage Subscription</a>
  </div>
  <div class="dropdown dropdown-end">
    <div tabindex="0" role="button" class="btn btn-ghost md:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
    </div>
    <ul tabindex="0" class="menu menu-sm dropdown-content text-cyan-100 mt-3 z-[10] p-2 shadow border-2 border-indigo-950 bg-base-100/95 backdrop-blur-sm rounded-md w-52">
      <li>
        <details>
          <summary>Davant Studio</summary>
          <ul>
            <li><Link href="/davant-studio/" class="transition-all hover:bg-primary/20">Software Overview</Link></li>
            <li><Link href="/download/" class="transition-all hover:bg-primary/20">Download</Link></li>
          </ul>
        </details>
      </li>
      <li>
        <details>
          <summary>Magic Mirror</summary>
          <ul>
            <li><Link href="/photobooth/" class="transition-all hover:bg-primary/20">AI Photo Booth</Link></li>
            <li><Link href="/event-galleries/" class="transition-all hover:bg-primary/20">Event Galleries</Link></li>
          </ul>
        </details>
      </li>
      <li>
        <details>
          <summary>Learn & Create</summary>
          <ul>
            <li><Link href="/training/" class="transition-all hover:bg-primary/20">Training & Workshops</Link></li>
            <li><Link href="/articles/" class="transition-all hover:bg-primary/20">Articles</Link></li>
            <li><Link href="/ambassadors/" class="transition-all hover:bg-primary/20">Creative Ambassadors Program</Link></li>
            <li><a href="https://civitai.com/user/David_Davant_Systems" target="_blank" rel="noopener noreferrer" class="transition-all hover:bg-primary/20">Research on CivitAI</a></li>
          </ul>
        </details>
      </li>
    </ul>
  </div>
  <span class="absolute top-0 left-0 w-full h-full scale-y-150 pointer-events-none select-none opacity-40 -z-10 bg-gradient-to-b from-base-100 via-base-100 to-transparent"></span>
</div>

<style>
  /* Gradient underline effect on hover for nav items */
  .dropdown .btn-ghost {
    position: relative;
  }
  
  .dropdown .btn-ghost::after {
    content: '';
    position: absolute;
    bottom: 0.25rem;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(to right, rgb(236 72 153), rgb(139 92 246));
    transition: width 0.3s ease, left 0.3s ease;
    border-radius: 1px;
  }
  
  .dropdown .btn-ghost:hover::after {
    width: 80%;
    left: 10%;
  }
  
  /* Subtle glow effect for dropdown content */
  .dropdown-content {
    box-shadow: 
      0 10px 25px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(139, 92, 246, 0.15),
      inset 0 0 1px rgba(139, 92, 246, 0.3);
  }
</style>

