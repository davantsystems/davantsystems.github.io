---
import Link from './Link.astro';
import NavbarLogo from './NavbarLogo.astro';

const davantStudioStripePortal = "https://billing.stripe.com/p/login/6oEg26f8K3697yE144";
---

<div class="fixed top-0 z-50 navbar bg-gradient-to-b from-black to-transparent" data-nav-component>
  <div class="navbar-start">
    <Link class="btn btn-ghost p-2" href="/">
      <NavbarLogo />
    </Link>
  </div>
  <div class="hidden navbar-center md:flex">
    <ul class="px-1 tracking-tight menu menu-horizontal text-cyan-100 drop-shadow-sm">
      <li>
        <div class="dropdown" data-dropdown="davant-studio">
          <label tabindex="0" class="hover:bg-base-100/70 transition-all dropdown-trigger cursor-pointer">Davant Studio</label>
          <ul tabindex="0" class="dropdown-content z-[10] menu p-2 shadow border-2 border-indigo-950 bg-base-100/95 backdrop-blur-sm rounded-md w-52 mt-3">
            <li><Link href="/davant-studio/" class="hover:bg-primary/20 text-cyan-100 transition-all">Software Overview</Link></li>
            <li><Link href="/download/" class="hover:bg-primary/20 text-cyan-100 transition-all">Download</Link></li>
          </ul>
        </div>
      </li>
      <li>
        <div class="dropdown" data-dropdown="magic-mirror">
          <label tabindex="0" class="hover:bg-base-100/70 transition-all dropdown-trigger cursor-pointer">Magic Mirror</label>
          <ul tabindex="0" class="dropdown-content z-[10] menu p-2 shadow border-2 border-indigo-950 bg-base-100/95 backdrop-blur-sm rounded-md w-52 mt-3">
            <li><Link href="/photobooth/" class="hover:bg-primary/20 text-cyan-100 transition-all">AI Photo Booth</Link></li>
          </ul>
        </div>
      </li>
      <li>
        <div class="dropdown" data-dropdown="learn-create">
          <label tabindex="0" class="hover:bg-base-100/70 transition-all dropdown-trigger cursor-pointer">Learn & Create</label>
          <ul tabindex="0" class="dropdown-content z-[10] menu p-2 shadow border-2 border-indigo-950 bg-base-100/95 backdrop-blur-sm rounded-md w-52 mt-3">
            <li><Link href="/training/" class="hover:bg-primary/20 text-cyan-100 transition-all">Training & Workshops</Link></li>
            <li><Link href="/articles/" class="hover:bg-primary/20 text-cyan-100 transition-all">Articles</Link></li>
            <li><Link href="/ambassadors/" class="hover:bg-primary/20 text-cyan-100 transition-all">Creative Ambassadors Program</Link></li>
          </ul>
        </div>
      </li>
    </ul>
  </div>
  <div class="navbar-end">
    <a class="btn btn-outline btn-secondary btn-xs" href={davantStudioStripePortal} target="_blank">Manage Subscription</a>
  </div>
  <div class="dropdown dropdown-end">
    <div tabindex="0" role="button" class="btn btn-ghost md:hidden">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
    </div>
    <ul tabindex="0" class="menu menu-sm dropdown-content text-cyan-100 mt-3 z-[10] p-2 shadow border-2 border-indigo-950 bg-base-100/95 backdrop-blur-sm rounded-md w-52">
      <li>
        <details>
          <summary>Davant Studio</summary>
          <ul>
            <li><Link href="/davant-studio/" class="hover:bg-primary/20 transition-all">Software Overview</Link></li>
            <li><Link href="/download/" class="hover:bg-primary/20 transition-all">Download</Link></li>
          </ul>
        </details>
      </li>
      <li>
        <details>
          <summary>Magic Mirror</summary>
          <ul>
            <li><Link href="/photobooth/" class="hover:bg-primary/20 transition-all">AI Photo Booth</Link></li>
          </ul>
        </details>
      </li>
      <li>
        <details>
          <summary>Learn & Create</summary>
          <ul>
            <li><Link href="/training/" class="hover:bg-primary/20 transition-all">Training & Workshops</Link></li>
            <li><Link href="/articles/" class="hover:bg-primary/20 transition-all">Articles</Link></li>
            <li><Link href="/ambassadors/" class="hover:bg-primary/20 transition-all">Creative Ambassadors Program</Link></li>
          </ul>
        </details>
      </li>
    </ul>
  </div>
  <span class="absolute top-0 left-0 w-full h-full scale-y-150 pointer-events-none select-none opacity-40 -z-10 bg-gradient-to-b from-base-100 via-base-100 to-transparent"></span>
</div>

<style>
  /* Common styles for all nav items */
  .nav-item,
  .dropdown-trigger {
    position: relative;
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    transition: all 0.3s ease;
  }
  
  /* Style the dropdown labels */
  label.dropdown-trigger {
    display: inline-block;
  }
  
  /* Firefox-specific fixes for dropdown hover */
  @-moz-document url-prefix() {
    .dropdown-hover:hover .dropdown-content,
    .dropdown-hover:focus-within .dropdown-content {
      opacity: 1;
      visibility: visible;
      display: block;
    }
  }
  
  /* Ensure nav-item overrides Link component defaults */
  .nav-item.nav-item {
    display: inline-block;
    position: relative;
  }
  
  /* Enhanced hover states for all nav items */
  .nav-item:hover,
  .dropdown-trigger:hover {
    background-color: rgb(15 23 42 / 0.7);
    color: rgb(164 215 238);
    transform: translateY(-1px);
  }
  
  /* Add gradient underline effect on hover for all nav items */
  .nav-item::after,
  .dropdown-trigger::after {
    content: '';
    position: absolute;
    bottom: 0.25rem;
    left: 50%;
    width: 0;
    height: 2px;
    background: linear-gradient(to right, rgb(236 72 153), rgb(139 92 246));
    transition: width 0.3s ease, left 0.3s ease;
    border-radius: 1px;
    z-index: 1;
  }
  
  .nav-item:hover::after,
  .dropdown-trigger:hover::after {
    width: 80%;
    left: 10%;
  }
  
  /* Ensure Link component styling doesn't interfere */
  .nav-item.nav-item {
    text-decoration: none !important;
  }
  
  /* Enhanced mobile menu styling */
  @media (max-width: 768px) {
    .dropdown-content .nav-item:hover {
      background-color: rgb(236 72 153 / 0.2);
      color: rgb(164 215 238);
    }
  }
</style>

<script>
  // Cross-browser dropdown handling with Firefox fixes
  function initDropdowns() {
    const dropdowns = document.querySelectorAll('[data-dropdown]');
    let openDropdown = null;
    let hoverTimeout = null;
    
    // Detect Firefox
    const isFirefox = navigator.userAgent.toLowerCase().indexOf('firefox') > -1;
    
    dropdowns.forEach(dropdown => {
      const trigger = dropdown.querySelector('.dropdown-trigger');
      
      // For Firefox, use click-based interaction
      if (isFirefox) {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          
          if (openDropdown && openDropdown !== dropdown) {
            openDropdown.classList.remove('dropdown-open');
          }
          
          dropdown.classList.toggle('dropdown-open');
          openDropdown = dropdown.classList.contains('dropdown-open') ? dropdown : null;
        });
      } else {
        // For other browsers, use hover
        dropdown.addEventListener('mouseenter', () => {
          clearTimeout(hoverTimeout);
          
          // Close other dropdowns
          if (openDropdown && openDropdown !== dropdown) {
            openDropdown.classList.remove('dropdown-open');
          }
          
          dropdown.classList.add('dropdown-open');
          openDropdown = dropdown;
        });
        
        dropdown.addEventListener('mouseleave', () => {
          hoverTimeout = setTimeout(() => {
            dropdown.classList.remove('dropdown-open');
            if (openDropdown === dropdown) {
              openDropdown = null;
            }
          }, 150);
        });
      }
      
      // Keyboard navigation for all browsers
      trigger.addEventListener('focus', () => {
        if (openDropdown && openDropdown !== dropdown) {
          openDropdown.classList.remove('dropdown-open');
        }
        dropdown.classList.add('dropdown-open');
        openDropdown = dropdown;
      });
      
      trigger.addEventListener('blur', (e) => {
        setTimeout(() => {
          if (!dropdown.contains(document.activeElement)) {
            dropdown.classList.remove('dropdown-open');
            if (openDropdown === dropdown) {
              openDropdown = null;
            }
          }
        }, 200);
      });
    });
    
    // Close dropdowns when clicking outside
    document.addEventListener('click', (e) => {
      if (openDropdown && !openDropdown.contains(e.target)) {
        openDropdown.classList.remove('dropdown-open');
        openDropdown = null;
      }
    });
    
    // Close dropdowns on escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && openDropdown) {
        openDropdown.classList.remove('dropdown-open');
        openDropdown = null;
      }
    });
  }
  
  // Initialize on load and after navigation
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDropdowns);
  } else {
    initDropdowns();
  }
  
  document.addEventListener('astro:page-load', initDropdowns);
</script>
