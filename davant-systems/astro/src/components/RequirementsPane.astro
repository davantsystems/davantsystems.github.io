---
---

<div class="w-full">
  <div class="text-center mb-12">
    <h2 class="text-4xl font-bold md:text-5xl lg:text-5xl mb-4">
      <span class="text-transparent bg-gradient-to-r from-violet-400 via-cyan-400 to-blue-500 bg-clip-text">System Requirements</span>
    </h2>
    <p class="text-lg text-cyan-100/80 max-w-2xl mx-auto">Davant Studio is optimized for professional hardware to deliver real-time AI generation performance.</p>
  </div>
  
  <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
    <!-- Windows Card -->
    <div class="relative border rounded-2xl bg-gradient-to-br from-purple-900/20 to-transparent border-purple-800/30 overflow-hidden">
      <div class="p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="p-3 rounded-lg bg-purple-500/20">
            <svg class="w-8 h-8 text-purple-400 fill-current" viewBox="0 0 24 24">
              <path d="M3,12V6.75L9,5.43V11.91L3,12M20,3V11.75L10,11.9V5.21L20,3M3,13L9,13.09V19.9L3,18.75V13M20,13.25V22L10,20.09V13.1L20,13.25Z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white">Windows</h3>
        </div>
        
        <div class="space-y-6">
          <!-- Minimum Requirements -->
          <div class="border-t border-purple-800/30 pt-4">
            <h4 class="text-sm font-semibold text-purple-300 uppercase tracking-wider mb-3">Minimum Requirements</h4>
            <ul class="space-y-2 text-sm text-cyan-100/70">
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">OS:</strong> Windows 10 (64-bit)</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">GPU:</strong> NVIDIA RTX 3060 (12GB VRAM)</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">RAM:</strong> 16GB DDR4</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">Storage:</strong> 50GB available space</span>
              </li>
            </ul>
          </div>
          
          <!-- Recommended Requirements -->
          <div class="border-t border-purple-800/30 pt-4">
            <h4 class="text-sm font-semibold text-pink-300 uppercase tracking-wider mb-3">Recommended for Best Performance</h4>
            <ul class="space-y-2 text-sm text-cyan-100/70">
              <li class="flex items-start">
                <svg class="w-4 h-4 text-pink-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                <span><strong class="text-white">OS:</strong> Windows 11</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-pink-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                <span><strong class="text-white">GPU:</strong> NVIDIA RTX 4070+ (16GB+ VRAM)</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-pink-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                <span><strong class="text-white">RAM:</strong> 32GB DDR5</span>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="mt-6 p-3 bg-amber-500/10 border border-amber-500/30 rounded-lg">
          <p class="text-xs text-amber-200"><strong>Note:</strong> AMD GPU support coming soon</p>
        </div>
      </div>
    </div>
    
    <!-- Mac Card -->
    <div class="relative border rounded-2xl bg-gradient-to-br from-purple-900/20 to-transparent border-purple-800/30 overflow-hidden">
      <div class="p-8">
        <div class="flex items-center gap-4 mb-6">
          <div class="p-3 rounded-lg bg-purple-500/20">
            <svg class="w-8 h-8 text-purple-400 fill-current" viewBox="0 0 24 24">
              <path d="M18.71,19.5C17.88,20.74 17,21.95 15.66,21.97C14.32,22 13.89,21.18 12.37,21.18C10.84,21.18 10.37,21.95 9.1,22C7.79,22.05 6.8,20.68 5.96,19.47C4.25,17 2.94,12.45 4.7,9.39C5.57,7.87 7.13,6.91 8.82,6.88C10.1,6.86 11.32,7.75 12.11,7.75C12.89,7.75 14.37,6.68 15.92,6.84C16.57,6.87 18.39,7.1 19.56,8.82C19.47,8.88 17.39,10.1 17.41,12.63C17.44,15.65 20.06,16.66 20.09,16.67C20.06,16.74 19.67,18.11 18.71,19.5M13,3.5C13.73,2.67 14.94,2.04 15.94,2C16.07,3.17 15.6,4.35 14.9,5.19C14.21,6.04 13.07,6.7 11.95,6.61C11.8,5.46 12.36,4.26 13,3.5Z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white">macOS</h3>
        </div>
        
        <div class="space-y-6">
          <!-- Minimum Requirements -->
          <div class="border-t border-purple-800/30 pt-4">
            <h4 class="text-sm font-semibold text-purple-300 uppercase tracking-wider mb-3">Minimum Requirements</h4>
            <ul class="space-y-2 text-sm text-cyan-100/70">
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">OS:</strong> macOS 14.6 Sequoia or newer</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">Chip:</strong> Apple Silicon M1</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">RAM:</strong> 16GB Unified Memory</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-purple-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                </svg>
                <span><strong class="text-white">Storage:</strong> 50GB available space</span>
              </li>
            </ul>
          </div>
          
          <!-- Recommended Requirements -->
          <div class="border-t border-purple-800/30 pt-4">
            <h4 class="text-sm font-semibold text-pink-300 uppercase tracking-wider mb-3">Recommended for Best Performance</h4>
            <ul class="space-y-2 text-sm text-cyan-100/70">
              <li class="flex items-start">
                <svg class="w-4 h-4 text-pink-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                <span><strong class="text-white">Chip:</strong> M2 Pro/Max or M3 series</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-pink-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                <span><strong class="text-white">RAM:</strong> 32GB+ Unified Memory</span>
              </li>
              <li class="flex items-start">
                <svg class="w-4 h-4 text-pink-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                <span><strong class="text-white">GPU Cores:</strong> 30+ for optimal performance</span>
              </li>
            </ul>
          </div>
        </div>
        
        <div class="mt-6 p-3 bg-emerald-500/10 border border-emerald-500/30 rounded-lg">
          <p class="text-xs text-emerald-200"><strong>Optimized:</strong> Native Apple Silicon performance</p>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Additional Info -->
  <div class="mt-8 text-center">
    <p class="text-sm text-cyan-100/60 mb-4">Not sure if your system is compatible?</p>
    <a href="/compatibility-checker" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-purple-300 border border-purple-800/50 rounded-lg hover:bg-purple-800/20 hover:border-purple-600/50 transition-all">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
      </svg>
      Check System Compatibility
    </a>
  </div>
</div>