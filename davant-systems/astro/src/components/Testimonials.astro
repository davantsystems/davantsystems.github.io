---
import TestimonialCard from './TestimonialCard.astro';

export interface Props {
  title?: string;
  subtitle?: string;
  testimonials?: Array<{
    quote: string;
    author: string;
    accentColor: 'purple' | 'cyan' | 'fuchsia';
    gradientFrom: string;
    gradientTo: string;
  }>;
}

const { 
  title = "Guests can't stop raving",
  subtitle = "An experience that leaves an impression",
  testimonials = [
    {
      quote: "So addicting! I could play with this all night.",
      author: "Sarah M.",
      accentColor: "cyan" as const,
      gradientFrom: "from-cyan-400",
      gradientTo: "to-blue-400"
    },
    {
      quote: "This is the future!",
      author: "Mike T.",
      accentColor: "cyan" as const,
      gradientFrom: "from-cyan-400",
      gradientTo: "to-blue-400"
    },
    {
      quote: "Definitely my favorite part of the event",
      author: "Jessica L.",
      accentColor: "cyan" as const,
      gradientFrom: "from-cyan-400",
      gradientTo: "to-blue-400"
    }
  ]
} = Astro.props;
---

<div class="container relative z-10 max-w-6xl px-4 mx-auto mt-24">
  <div class="mb-16 text-center">
    <h2 class="mb-4 text-2xl font-bold leading-tight sm:text-3xl lg:text-5xl">
      <span class="text-transparent bg-gradient-to-br from-violet-400 via-cyan-400 to-blue-500 bg-clip-text">{title}</span>
    </h2>
    <p class="text-lg font-light lg:text-xl text-base-content">{subtitle}</p>
  </div>
  
  <div class="grid grid-cols-1 gap-6 mb-48 md:grid-cols-3">
    {testimonials.map((testimonial, index) => (
      <TestimonialCard
        quote={testimonial.quote}
        author={testimonial.author}
        accentColor={testimonial.accentColor}
        gradientFrom={testimonial.gradientFrom}
        gradientTo={testimonial.gradientTo}
        offset={index != 1}
        index={index}
      />
    ))}
  </div>
</div>