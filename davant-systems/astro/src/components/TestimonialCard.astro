---
export interface Props {
  quote: string;
  author: string;
  accentColor: 'purple' | 'cyan' | 'fuchsia';
  gradientFrom: string;
  gradientTo: string;
  offset?: boolean;
  index?: number;
}

const { quote, author, accentColor, gradientFrom, gradientTo, offset = false, index = 0 } = Astro.props;

const colorClasses = {
  purple: {
    glow: 'from-purple-500/20 to-pink-500/20',
    border: 'border-purple-500/20',
    borderActive: 'border-purple-500/40',
    quote: 'text-purple-400'
  },
  cyan: {
    glow: 'from-cyan-500/20 to-blue-500/20',
    border: 'border-cyan-500/20',
    borderActive: 'border-cyan-500/40',
    quote: 'text-cyan-400'
  },
  fuchsia: {
    glow: 'from-fuchsia-500/20 to-purple-500/20',
    border: 'border-fuchsia-500/20',
    borderActive: 'border-fuchsia-500/40',
    quote: 'text-fuchsia-400'
  }
};

const colors = colorClasses[accentColor];
---

<div class={`testimonial-card relative transition-all duration-700 transform h-full ${offset ? 'md:mt-8' : ''}`} style={`--delay: ${index * 0.3}s;`}>
  <div class={`testimonial-glow absolute inset-0 bg-gradient-to-br ${colors.glow} rounded-2xl blur-xl opacity-0 transition-opacity duration-700`}></div>
  <div class={`testimonial-border relative p-8 border bg-base-300/50 backdrop-blur-sm pt-16 pb-16 rounded-2xl ${colors.border} transition-all duration-700 h-full flex flex-col justify-center`} data-border-active={colors.borderActive}>
    <div class={`mb-4 text-4xl absolute top-0 left-2 ${colors.quote}`}>❝</div>
    <p class="mb-6 text-lg font-semibold text-center lg:text-2xl text-base-content">"{quote}"</p>
    <div class="flex items-center justify-center gap-3">
      <div>
        <p class="text-xs font-normal">{author}</p>
      </div>
    </div>
  </div>
</div>

<style>
  .testimonial-card {
    animation: testimonial-lift 3s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes testimonial-lift {
    0%, 100% {
      transform: translateY(0);
    }
    15% {
      transform: translateY(-8px);
    }
    50% {
      transform: translateY(0);
    }
  }

  .testimonial-card .testimonial-glow {
    animation: testimonial-glow 3s ease-in-out infinite;
    animation-delay: var(--delay);
  }

  @keyframes testimonial-glow {
    0%, 100% {
      opacity: 0;
    }
    15%, 20% {
      opacity: 0.6;
    }
    40% {
      opacity: 0.2
    },
    60% {
      opacity: 0;
    }
  }
</style>
