---
import Layout from "../layouts/Layout.astro";
import MainNavWithDropdowns from "../components/MainNavWithDropdowns.astro";
import Footer from "../components/Footer.astro";
import LogoGrid from "../components/LogoGrid.astro";

// Import images properly
import launchPartyHero from "../assets/images/launch-party-hero.jpg";
import hero2Image from "../assets/images/hero2.png";
import printsMosaic from "../assets/images/prints-mosaic_corrected.jpg";

const pageTitle = "Davant Systems | Magic Mirror AI Photobooth";
---

<Layout title={pageTitle}>
  <MainNavWithDropdowns />
  <main class="relative z-10 overflow-x-hidden text-base font-open-sans bg-base-300">
    <div class="relative mega-hero-wrapper">
      <section class="relative z-30 hero__wrapper">
        <div class="relative z-40 flex items-center justify-center min-h-screen px-4">
          <div class="relative text-wrapper animate-fade-in-up">
            <div class="mt-8 text-center md:mt-12">
              <p class="mb-4 text-sm font-medium leading-relaxed uppercase md:text-base lg:text-lg text-base-content">Make your next event</p>
            </div>
            <div class="relative title-wrapper">
            <h1 class="relative text-5xl font-black tracking-tight text-center text-transparent bg-clip-text bg-gradient-to-br from-pink-400 via-fuchsia-500 to-purple-600 sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl leading-[0.85] mb-8 md:mb-12 hero-text-stroke" aria-label="One of a kind">One of a kind</h1>
            <span class="absolute inset-0 w-full text-5xl font-black tracking-tight text-center -z-10 sm:text-6xl md:text-7xl lg:text-8xl xl:text-9xl shadow-glow opacity-60 leading-[0.85] text-black" aria-hidden="true">One of a kind</span>
            </div>
          </div>
        </div>
        <div class="relative z-50 mt-8 overflow-visible lg:-mt-32">
          <div class="container relative z-50 flex flex-col justify-center px-4 pb-20 mx-auto -mb-24 overflow-visible sm:pb-4 max-w-7xl lg:flex-row-reverse lg:items-stretch lg:gap-8">
            <div class="relative flex flex-col shadow-lg lg:w-1/2">
              <div class="relative flex flex-col justify-center flex-1 p-8 border shadow-2xl sm:p-10 lg:p-14 rounded-3xl bg-base-300/50 backdrop-blur-xl border-purple-400/20 hero-card-shadow">
                <div class="flex flex-col justify-center flex-1">
                <h2 class="mb-8">
                  <span class="block mb-3 text-xl font-bold tracking-wider text-transparent uppercase md:text-2xl bg-gradient-to-r from-pink-400 to-purple-600 bg-clip-text">Magic Mirror</span>
                  <span class="inline-block text-4xl font-black leading-none text-transparent sm:text-5xl md:text-6xl lg:text-7xl bg-gradient-to-br from-pink-400 via-fuchsia-500 to-purple-600 bg-clip-text">AI </span>
                  <span class="inline-block -ml-2 text-4xl font-thin -skew-x-12 sm:text-5xl md:text-6xl lg:text-7xl neon-glow-secondary text-cyan-400 font-sacramento animate-pulse-slow"><span class="neon-first">P</span>hoto <span class="neon-second">B</span>ooth</span>
                </h2>
                <p class="max-w-xl mb-10 text-base leading-relaxed md:text-lg lg:text-xl text-base-content">Transform your guests into living art with AI-powered real-time transformations that create unforgettable memories.</p>
                <div class="flex flex-col gap-4 sm:flex-row sm:gap-6">
                  <button 
                    data-tf-popup="KJvQaJXG" 
                    data-tf-opacity="100" 
                    data-tf-size="100" 
                    data-tf-iframe-props="title=Book Davant Systems AI Photobooth" 
                    data-tf-transitive-search-params 
                    data-tf-medium="snippet" 
                    class="relative btn btn-md sm:btn-lg bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-600 hover:from-cyan-600 hover:via-blue-600 hover:to-purple-700 text-white border-0 shadow-xl shadow-blue-500/40 transform transform-origin-center transition-all duration-500 hover:scale-[1.03] hover:shadow-2xl hover:shadow-blue-500/60 px-8 sm:px-10 font-semibold group w-full sm:w-auto overflow-hidden cta-button-shadow"
                  >
                    <span class="relative z-10 tracking-wide">Book Your Event</span>
                    <span class="absolute inset-0 transition-transform duration-700 ease-out -translate-x-full pointer-events-none bg-gradient-to-r from-white/0 via-white/20 to-white/0 group-hover:translate-x-full"></span>
                    <span class="absolute inset-0 transition-opacity duration-300 rounded-lg opacity-0 pointer-events-none bg-white/10 group-hover:opacity-100"></span>
                  </button>
                  <a href="#learn-more" class="relative w-full px-8 overflow-hidden font-medium transition-all border-2 btn btn-md sm:btn-lg btn-outline border-slate-400/50 text-slate-300 hover:bg-blue-500/15 hover:border-blue-400 hover:text-slate-200 duration-400 sm:w-auto sm:px-10 group backdrop-blur-sm">
                    <span class="relative z-10 tracking-wide">Explore Features</span>
                    <span class="absolute inset-0 transition-transform duration-700 ease-out -translate-x-full pointer-events-none bg-gradient-to-r from-blue-500/0 via-blue-500/10 to-blue-500/0 group-hover:translate-x-full"></span>
                  </a>
                </div>
                </div>
              </div>
            </div>

            <div class="relative flex flex-col mt-12 shadow-lg lg:w-1/2 lg:mt-0">
              <div class="relative flex flex-1 group">
                <div class="absolute transition-all duration-700 scale-110 -inset-6 bg-gradient-to-br from-cyan-400/25 via-blue-500/20 to-purple-500/25 rounded-3xl opacity-35 blur-3xl group-hover:opacity-55 animate-pulse-slow"></div>
                <div class="absolute transition-all duration-500 opacity-25 -inset-3 bg-gradient-to-tr from-blue-500/15 via-purple-600/10 to-cyan-400/15 rounded-2xl blur-xl group-hover:opacity-45"></div>
                <div class="relative flex flex-1 overflow-hidden border shadow-2xl rounded-2xl border-purple-400/30 backdrop-blur-sm bg-gradient-to-br from-purple-900/10 to-pink-900/10">
                  <img
                    class="w-full h-full object-cover transform transition-all duration-700 group-hover:scale-[1.02] filter group-hover:brightness-110 group-hover:contrast-105"
                    src={launchPartyHero.src}
                    loading="eager"
                    alt="AI Photo Booth experience at an event with guests enjoying the interactive transformation"
                  />
                  <div class="absolute inset-0 transition-opacity duration-500 opacity-0 bg-gradient-to-t from-base-300/60 via-transparent to-transparent group-hover:opacity-100"></div>
                  <div class="absolute inset-0 transition-opacity duration-500 bg-gradient-to-br from-blue-500/0 via-transparent to-purple-500/8 opacity-40 group-hover:opacity-60"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="absolute top-0 left-0 z-10 w-full h-full pointer-events-none">
          <div class="absolute inset-0 bg-gradient-to-b from-base-300/95 via-base-300/20 to-base-300/95"></div>
          <div class="absolute bottom-0 left-0 w-full h-80 bg-gradient-to-t from-base-300 via-base-300/60 to-transparent"></div>
          <!-- <video 
            class="fixed top-0 left-0 z-0 object-cover w-full h-full opacity-80 filter brightness-75 contrast-110 saturate-110" 
            autoplay 
            loop 
            muted 
            playsinline
            preload="metadata"
          >
            <source src="/video/NinjaPenguin-02_timelapse-afters.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video> -->
          <!-- <div class="absolute top-0 left-0 z-50 block w-full h-full opacity-40 mix-blend-multiply bg-gradient-to-br from-purple-900/70 via-pink-900/50 to-cyan-900/60"></div>
          <div class="absolute top-0 left-0 block w-full h-full z-45 opacity-20 mix-blend-screen bg-gradient-to-tr from-fuchsia-500/30 via-transparent to-purple-500/30"></div> -->
          <!-- Enhanced animated particles overlay -->
          <div class="absolute inset-0 z-40 opacity-40">
            <div class="absolute w-2 h-2 rounded-full top-20 left-10 bg-cyan-300 animate-pulse blur-sm particle-cyan-sm"></div>
            <div class="absolute w-3 h-3 bg-blue-300 rounded-full top-40 right-20 animate-pulse blur-sm particle-blue-md"></div>
            <div class="absolute w-2 h-2 bg-purple-300 rounded-full bottom-32 left-1/4 animate-pulse blur-sm particle-purple-sm"></div>
            <div class="absolute w-4 h-4 rounded-full opacity-50 top-1/2 right-1/3 bg-slate-300 animate-pulse blur-sm particle-slate-lg"></div>
            <div class="absolute w-1 h-1 rounded-full top-3/4 left-1/3 bg-cyan-400 animate-pulse blur-sm particle-cyan-xs"></div>
            <div class="absolute w-2 h-2 bg-blue-400 rounded-full top-1/4 right-1/4 animate-pulse blur-sm particle-blue-sm"></div>
          </div>
        </div>
      </section>

      <section class="relative z-20 py-32 md:pt-60 md:pb-60 bg-gradient-to-b from-base-300 to-base-100 texture-overlay" id="learn-more">
        <div class="container flex flex-col px-4 mx-auto max-w-7xl lg:flex-row lg:items-center lg:gap-16">
          <div class="mb-16 lg:w-1/2 lg:mb-0">
            <div class="max-w-xl">
              <h2 class="mb-10 text-2xl font-bold leading-tight sm:text-3xl lg:text-5xl">
                <span class="text-transparent bg-gradient-to-br from-violet-400 via-cyan-400 to-blue-500 bg-clip-text">Magically transformed</span>
                <span class="block mt-2 text-xl font-light sm:text-2xl lg:text-3xl text-base-content">by AI in real-time</span>
              </h2>
              <div class="space-y-6 text-lg text-base-content">
                <p class="leading-relaxed">Our cutting-edge system captures a photo every 3 seconds and uses generative AI to transform your guests in amazing ways.</p>
                <p class="leading-relaxed">Watch as they become paper origami, felt puppets, comic book heroes, or any of dozens of artistic styles.</p>
              </div>
              <div class="flex flex-wrap gap-4 mt-10">
                <span class="inline-block px-4 py-2 text-sm font-medium border rounded-full bg-gradient-to-r from-blue-500/20 to-cyan-500/20 border-blue-400/30 text-cyan-200 backdrop-blur-sm">Real-time Processing</span>
                <span class="inline-block px-4 py-2 text-sm font-medium border rounded-full bg-gradient-to-r from-purple-500/20 to-blue-500/20 border-purple-400/30 text-slate-200 backdrop-blur-sm">30+ Art Styles</span>
                <span class="inline-block px-4 py-2 text-sm font-medium text-blue-200 border rounded-full bg-gradient-to-r from-slate-500/20 to-blue-500/20 border-slate-400/30 backdrop-blur-sm">Instant Prints</span>
              </div>
            </div>
          </div>
          <div class="lg:w-1/2">
            <div class="relative group">
              <div class="absolute transition-opacity duration-500 -inset-4 bg-gradient-to-r from-cyan-500 via-blue-500 to-purple-500 rounded-2xl opacity-20 blur-2xl group-hover:opacity-30"></div>
              <div class="relative overflow-hidden border shadow-2xl rounded-2xl border-purple-500/20 video-container-16-9 bg-base-300">
                <iframe
                  src="https://www.youtube.com/embed/vuYqdw3HwDc"
                  title="Magic Mirror AI Photo Booth Demo Video"
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                  class="absolute inset-0 w-full h-full"
                ></iframe>
                <div class="absolute inset-0 transition-opacity duration-300 opacity-0 pointer-events-none bg-gradient-to-t from-base-300/20 to-transparent group-hover:opacity-100"></div>
              </div>
            </div>
            <p class="mt-4 text-sm text-center text-base-content">Watch the magic happen in real-time</p>
          </div>
        </div>
      </section>
    </div>

    <section class="relative z-20 py-24 md:py-32 bg-gradient-to-b from-base-100 to-base-300">
      <div class="container relative z-10 max-w-6xl px-4 mx-auto mt-24">
        <div class="mb-16 text-center">
          <h2 class="mb-4 text-2xl font-bold leading-tight sm:text-3xl lg:text-5xl">
            <span class="text-transparent bg-gradient-to-br from-violet-400 via-cyan-400 to-blue-500 bg-clip-text">Guests can't stop raving</span>
          </h2>
          <p class="text-lg font-light lg:text-xl text-base-content">Real reactions from real events</p>
        </div>
        
        <div class="grid grid-cols-1 gap-6 mb-48 md:grid-cols-3">
          <div class="relative transition-all duration-300 transform group hover:-translate-y-2">
            <div class="absolute inset-0 transition-opacity duration-300 opacity-0 bg-gradient-to-br from-purple-500/20 to-pink-500/20 rounded-2xl blur-xl group-hover:opacity-100"></div>
            <div class="relative p-8 transition-colors duration-300 border bg-base-300/50 backdrop-blur-sm rounded-2xl border-purple-500/20 hover:border-purple-500/40">
              <div class="mb-4 text-4xl text-purple-400">❝</div>
              <p class="mb-4 text-lg font-semibold lg:text-2xl text-base-content">"So addicting!"</p>
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-full sm:w-12 sm:h-12 bg-gradient-to-br from-purple-400 to-pink-400"></div>
                <div>
                  <p class="text-sm font-semibold">Sarah M.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="relative transition-all duration-300 transform group hover:-translate-y-2 md:mt-8">
            <div class="absolute inset-0 transition-opacity duration-300 opacity-0 bg-gradient-to-br from-cyan-500/20 to-blue-500/20 rounded-2xl blur-xl group-hover:opacity-100"></div>
            <div class="relative p-8 transition-colors duration-300 border bg-base-300/50 backdrop-blur-sm rounded-2xl border-cyan-500/20 hover:border-cyan-500/40">
              <div class="mb-4 text-4xl text-cyan-400">❝</div>
              <p class="mb-4 text-lg font-semibold lg:text-2xl text-base-content">"This is the future"</p>
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-full sm:w-12 sm:h-12 bg-gradient-to-br from-cyan-400 to-blue-400"></div>
                <div>
                  <p class="text-sm font-semibold">Mike T.</p>
                </div>
              </div>
            </div>
          </div>
          
          <div class="relative transition-all duration-300 transform group hover:-translate-y-2">
            <div class="absolute inset-0 transition-opacity duration-300 opacity-0 bg-gradient-to-br from-fuchsia-500/20 to-purple-500/20 rounded-2xl blur-xl group-hover:opacity-100"></div>
            <div class="relative p-8 transition-colors duration-300 border bg-base-300/50 backdrop-blur-sm rounded-2xl border-fuchsia-500/20 hover:border-fuchsia-500/40">
              <div class="mb-4 text-4xl text-fuchsia-400">❝</div>
              <p class="mb-4 text-lg font-semibold lg:text-2xl text-base-content">"My favorite part!"</p>
              <div class="flex items-center gap-3">
                <div class="flex-shrink-0 w-10 h-10 rounded-full sm:w-12 sm:h-12 bg-gradient-to-br from-fuchsia-400 to-purple-400"></div>
                <div>
                  <p class="text-sm font-semibold">Jessica L.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="relative z-20 px-4 pt-24 pb-48">
        <div class="max-w-4xl mx-auto mb-8 text-center">
          <h3 class="mb-8 text-2xl font-bold sm:text-3xl lg:text-5xl">
            <span class="leading-tight text-transparent bg-gradient-to-r from-pink-400 via-fuchsia-500 to-purple-600 bg-clip-text">More than a filter.</span>
            <span class="block mt-4 text-xl font-light sm:text-2xl lg:text-4xl text-base-content">A truly imaginative transformation</span>
          </h3>
          <p class="max-w-2xl mx-auto text-lg text-base-content">Drag the slider to see how our AI transforms reality into art in real-time</p>
        </div>
        
        <div class="relative max-w-5xl mx-auto">
          <!-- Glow effect -->
          <div class="absolute transition-opacity duration-700 -inset-8 bg-gradient-to-r from-pink-500 via-purple-500 to-cyan-500 rounded-3xl opacity-10 blur-3xl group-hover:opacity-20"></div>
          
          <!-- Main container -->
          <div class="relative p-4 bg-base-300/30 backdrop-blur-sm rounded-3xl lg:p-8">
            <!-- Labels -->
            <div class="absolute z-20 pointer-events-none top-4 sm:top-8 left-4 sm:left-8">
              <span class="inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-full bg-base-300/70 backdrop-blur-md border border-purple-500/30 shadow-lg">
                <span class="text-xs font-semibold sm:text-sm text-base-content">Before</span>
              </span>
            </div>
            <div class="absolute z-20 pointer-events-none top-4 sm:top-8 right-4 sm:right-8">
              <span class="inline-flex items-center px-3 sm:px-4 py-1.5 sm:py-2 rounded-full bg-base-300/70 backdrop-blur-md border border-purple-500/30 shadow-lg">
                <span class="text-xs font-semibold text-transparent sm:text-sm bg-gradient-to-r from-pink-400 to-purple-600 bg-clip-text">After AI Magic</span>
              </span>
            </div>
            
            <!-- Professional Comparison Slider -->
            <div class="relative overflow-hidden border shadow-2xl rounded-2xl border-purple-500/20 group comparison-slider" data-comparison-slider>
              <div class="relative aspect-[16/9] w-full">
                <!-- After Image (Bottom Layer) -->
                <div class="absolute inset-0">
                  <img 
                    alt="After transformation - Guest transformed into paper origami art style" 
                    src="/image/holiday-Shot_0003_00807-2After.jpg" 
                    class="object-cover w-full h-full"
                    loading="lazy"
                  />
                  <!-- Subtle gradient overlay -->
                  <div class="absolute inset-0 bg-gradient-to-br from-transparent via-transparent to-purple-900/10"></div>
                </div>
                
                <!-- Before Image (Top Layer with Clip) -->
                <div class="absolute inset-0 comparison-before clip-left-half">
                  <img 
                    alt="Before transformation - Original photo of guests" 
                    src="/image/holiday-Shot_0003_00807-1Before.jpg" 
                    class="object-cover w-full h-full"
                    loading="lazy"
                  />
                  <!-- Subtle gradient overlay -->
                  <div class="absolute inset-0 bg-gradient-to-bl from-transparent via-transparent to-base-300/10"></div>
                </div>
                
                <!-- Slider Control -->
                <div class="absolute inset-y-0 comparison-slider-handle slider-position-center">
                  <!-- Vertical divider line -->
                  <div class="absolute top-0 bottom-0 left-1/2 w-0.5 -translate-x-1/2 bg-gradient-to-b from-transparent via-white/50 to-transparent"></div>
                  
                  <!-- Extra glow lines -->
                  <div class="absolute top-0 bottom-0 w-4 -translate-x-1/2 left-1/2 bg-gradient-to-b from-transparent via-white/10 to-transparent blur-sm"></div>
                  <div class="absolute top-0 bottom-0 w-8 -translate-x-1/2 left-1/2 bg-gradient-to-b from-transparent via-purple-400/20 to-transparent blur-xl"></div>
                  
                  <!-- Draggable handle -->
                  <div class="absolute -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2 cursor-col-resize touch-none">
                    <div class="relative group/handle">
                      <!-- Handle background -->
                      <div class="relative transition-all duration-300 rounded-full shadow-2xl w-14 h-14 bg-gradient-to-br from-white to-gray-100 ring-2 ring-purple-500 ring-offset-2 ring-offset-transparent group-hover/handle:scale-110 group-hover/handle:ring-purple-400 group-hover/handle:ring-offset-purple-500/20">
                        <!-- Handle icon -->
                        <div class="absolute inset-0 flex items-center justify-center">
                          <svg class="w-5 h-5 text-purple-600" fill="none" viewBox="0 0 24 24">
                            <path d="M7 16V8M17 16V8M12 16V8" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                            <path d="M3 12L7 8V16L3 12Z" fill="currentColor" opacity="0.7"/>
                            <path d="M21 12L17 16V8L21 12Z" fill="currentColor" opacity="0.7"/>
                          </svg>
                        </div>
                      </div>
                      <!-- Hover glow -->
                      <div class="absolute inset-0 transition-opacity duration-300 scale-150 rounded-full opacity-0 bg-gradient-to-r from-purple-500/30 to-pink-500/30 blur-xl group-hover/handle:opacity-100"></div>
                      
                      <!-- Pulse animation on hover -->
                      <div class="absolute inset-0 transition-all duration-700 scale-100 rounded-full opacity-0 bg-white/20 group-hover/handle:scale-150 group-hover/handle:opacity-0"></div>
                    </div>
                  </div>
                  
                  <!-- Touch area for mobile -->
                  <div class="absolute w-16 h-24 -translate-x-1/2 -translate-y-1/2 top-1/2 left-1/2 cursor-col-resize touch-none"></div>
                </div>
                
                <!-- Interactive hint -->
                <div class="absolute transition-opacity duration-500 -translate-x-1/2 pointer-events-none bottom-4 left-1/2 comparison-hint">
                  <div class="flex items-center gap-2 px-4 py-2 border rounded-full shadow-lg bg-base-300/90 backdrop-blur-md border-purple-500/30">
                    <svg class="w-4 h-4 text-purple-400 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l-3 3 3 3m8-6l3 3-3 3"></path>
                    </svg>
                    <span class="text-xs font-medium text-base-content">Drag to compare</span>
                  </div>
                </div>
                
                <!-- Percentage indicator -->
                <div class="absolute transition-all duration-300 -translate-x-1/2 opacity-0 pointer-events-none -top-16 left-1/2 comparison-percentage">
                  <div class="relative">
                    <div class="px-4 py-2 rounded-lg shadow-xl bg-gradient-to-br from-purple-600/90 to-pink-600/90 backdrop-blur-md">
                      <span class="text-sm font-bold text-white">50%</span>
                    </div>
                    <!-- Arrow pointing down -->
                    <div class="absolute left-1/2 -bottom-2 -translate-x-1/2 w-0 h-0 border-l-[6px] border-l-transparent border-r-[6px] border-r-transparent border-t-[8px] border-t-purple-600/90"></div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Bottom text -->
            <div class="mt-8 text-center">
              <p class="text-sm text-base-content">One moment captured, infinite artistic possibilities</p>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute bottom-0 z-0 block h-full min-w-full -translate-x-1/2 opacity-100 pointer-events-none select-none background-image left-1/2 z-1">
        <img
          class="relative block object-cover w-full h-full opacity-50 hero__background-image"
          src={hero2Image.src}
          loading="lazy"
          alt="Abstract gradient background from pink to dark purple"
        />
        <div class="absolute bottom-0 left-0 z-10 w-full opacity-100 gradient-fade pb-28 bg-gradient-to-b from-transparent to-base-300"></div>
      </div>
    </section>

    <section class="relative z-20 overflow-hidden py-28 md:py-64 bg-base-200 texture-overlay">
      <div class="container max-w-6xl px-4 mx-auto">
        <div class="mb-20 text-center">
          <h2 class="text-2xl font-bold text-transparent stroke-2 sm:text-3xl lg:text-5xl bg-gradient-to-r from-purple-400 to-pink-600 bg-clip-text drop-shadow-sm">Proven Impact</h2>
        </div>
        <div class="grid max-w-4xl grid-cols-1 gap-10 mx-auto md:grid-cols-3">
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-primary/10 rounded-2xl blur-xl animate-backdrop-pulse"></div>
            <div class="relative p-10 text-center border bg-base-100/50 backdrop-blur-sm rounded-2xl border-base-content/10 animate-stat-glow">
              <div class="mb-2 text-5xl font-black lg:text-6xl text-base-content animate-count" data-count="175" data-delay="0">122k+</div>
              <p class="text-lg text-base-content/80 animate-count" data-delay="0">Images generated</p>
            </div>
          </div>
          <div class="relative group">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-primary/10 rounded-2xl blur-xl animate-backdrop-pulse-delay-1"></div>
