<script is:inline>
// Comparison slider functionality
document.addEventListener('DOMContentLoaded', () => {
  const comparisonSlider = document.querySelector('[data-comparison-slider]');
  if (!comparisonSlider) return;
  
  const beforeImage = comparisonSlider.querySelector('.comparison-before');
  const sliderHandle = comparisonSlider.querySelector('.comparison-slider-handle');
  const percentageIndicator = comparisonSlider.querySelector('.comparison-percentage span');
  
  if (!beforeImage || !sliderHandle) return;
  
  let isDragging = false;
  let currentPosition = 50;
  
  function updateSliderPosition(percentage) {
    percentage = Math.max(0, Math.min(100, percentage));
    currentPosition = percentage;
    beforeImage.style.clipPath = `inset(0 ${100 - percentage}% 0 0)`;
    sliderHandle.style.left = `${percentage}%`;
    if (percentageIndicator) {
      percentageIndicator.textContent = `${Math.round(percentage)}%`;
    }
  }
  
  function getPositionFromEvent(e, rect) {
    const x = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
    return ((x - rect.left) / rect.width) * 100;
  }
  
  function startDragging(e) {
    e.preventDefault();
    isDragging = true;
    comparisonSlider.classList.add('is-dragging');
    document.body.style.cursor = 'col-resize';
  }
  
  function drag(e) {
    if (!isDragging) return;
    const rect = comparisonSlider.getBoundingClientRect();
    updateSliderPosition(getPositionFromEvent(e, rect));
  }
  
  function stopDragging() {
    isDragging = false;
    comparisonSlider.classList.remove('is-dragging');
    document.body.style.cursor = '';
  }
  
  // Events
  sliderHandle.addEventListener('mousedown', startDragging);
  document.addEventListener('mousemove', drag);
  document.addEventListener('mouseup', stopDragging);
  
  comparisonSlider.addEventListener('click', (e) => {
    if (e.target === sliderHandle || sliderHandle.contains(e.target)) return;
    const rect = comparisonSlider.getBoundingClientRect();
    updateSliderPosition(getPositionFromEvent(e, rect));
  });
  
  updateSliderPosition(50);
});

// Count-up animation for stats
document.addEventListener('DOMContentLoaded', () => {
  const observerOptions = {
    threshold: 0.5,
    rootMargin: '0px 0px -100px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && !entry.target.hasAttribute('data-animated')) {
        entry.target.setAttribute('data-animated', 'true');
        const delay = parseInt(entry.target.getAttribute('data-delay')) || 0;
        
        setTimeout(() => {
          // Start fade-in animation
          entry.target.classList.add('animate-fade-in-up');
          // Start count-up animation only for elements with data-count
          if (entry.target.hasAttribute('data-count')) {
            animateCounter(entry.target);
          }
        }, delay);
      }
    });
  }, observerOptions);

  function animateCounter(element) {
    const target = parseFloat(element.getAttribute('data-count'));
    const isPercentage = element.textContent.includes('%');
    const isKilo = element.textContent.includes('k');
    const isInteger = Number.isInteger(target);
    
    let start = target > 10 ? target * 0.7 : 0;
    const duration = 2000;
    const startTime = performance.now();

    function updateCount(currentTime) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      
      // Easing function for smooth animation
      const easeOutCubic = 1 - Math.pow(1 - progress, 3);
      const current = start + (target - start) * easeOutCubic;
      
      if (isPercentage) {
        element.textContent = Math.round(current) + '%';
      } else if (isKilo) {
        if (isInteger || current >= 1) {
          element.textContent = Math.round(current) + 'k+';
        } else {
          element.textContent = current.toFixed(1) + 'k+';
        }
      } else {
        element.textContent = Math.round(current);
      }
      
      if (progress < 1) {
        requestAnimationFrame(updateCount);
      }
    }
    
    requestAnimationFrame(updateCount);
  }

  // Observe all elements with animate-count class
  document.querySelectorAll('.animate-count').forEach(element => {
    observer.observe(element);
  });
});
</script>