---
import Layout from '../layouts/Layout.astro';
import MainNav from '../components/MainNav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';
import ninjaPenguinImage from '../assets/images/events/ninja-penguin.jpg';
import aiOnTheLotImage from '../assets/images/events/ai-on-the-lot.jpg';
import promptedImage from '../assets/images/events/prompted.jpg';

interface EventCardProps {
  title: string;
  date: string;
  description: string;
  galleryUrl: string;
  imageSrc: any;
  imageAlt: string;
}

const events: EventCardProps[] = [
  {
    title: "Ninja Penguin",
    date: "May 17, 2025",
    description: "Magic Mirror photos from the Ninja Penguin event",
    galleryUrl: "https://photos.davantsystems.com/share/xFOvyflkMoaGDk9f68S4JIQiovrGiAddoJsvUfZ1oZm2hrRSmvj-d4L0pZAcf5EfStE",
    imageSrc: ninjaPenguinImage,
    imageAlt: "Ninja Penguin Event"
  },
  {
    title: "AI on the Lot",
    date: "May 28-29, 2025",
    description: "Magic Mirror photos from AI on the Lot",
    galleryUrl: "https://photos.davantsystems.com/share/k1FlFml8nSbi8fUhiHieoTaFE70vXzNkmxzU-UiN6_p_96qKn7THPrOcuQUBh1FwKvs",
    imageSrc: aiOnTheLotImage,
    imageAlt: "AI on the Lot Event"
  },
  {
    title: "Prompted by Promise Studios",
    date: "May 6, 2025",
    description: "Magic Mirror photos from the Prompted event by Promise Studios",
    galleryUrl: "https://photos.davantsystems.com/share/PbYcHY_3xUX_h03DRxjK8hm6YDVUwyLfkS3eH1q3mYqta9WvIlM54dsBk004yNy9nGQ",
    imageSrc: promptedImage,
    imageAlt: "Prompted Event by Promise Studios"
  }
];
---

<Layout title="Event Photo Galleries - Magic Mirror by Davant Systems">
	<MainNav />
	<main class="z-20 pt-12">
		<section class="relative py-20 bg-base-300">
			<div class="container mx-auto px-4">
				<div class="text-center mb-12">
					<h1 class="text-5xl font-bold mb-4 bg-gradient-to-br from-cyan-500 via-secondary to-purple-500 bg-clip-text text-transparent">
						Event Photo Galleries
					</h1>
					<p class="text-xl text-base-content/70 max-w-2xl mx-auto">
						Browse photos from our recent Magic Mirror events. Click on any event to view the full gallery.
					</p>
				</div>

				<div class="grid grid-cols-1 gap-8 max-w-3xl mx-auto">
					{events.map((event) => (
						<div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-[1.02] overflow-hidden md:card-side">
							<figure class="relative h-64 md:h-auto md:w-1/2 overflow-hidden bg-base-200">
								<Image
									src={event.imageSrc}
									alt={event.imageAlt}
									class="w-full h-full object-cover"
									loading="lazy"
									decoding="async"
								/>
							</figure>
							<div class="card-body md:w-1/2">
								<h2 class="card-title text-2xl mb-2 text-secondary">
									{event.title}
								</h2>
								<p class="text-base-content/60 mb-2">{event.date}</p>
								{event.description && (
									<p class="text-base-content/80 mb-4">{event.description}</p>
								)}
								<div class="card-actions justify-end">
									<a
										href={event.galleryUrl}
										target="_blank"
										rel="noopener noreferrer"
										class="btn btn-primary btn-sm"
									>
										View Gallery
										<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
										</svg>
									</a>
								</div>
							</div>
						</div>
					))}
				</div>

				<div class="mt-16 mb-8">
					<div class="relative overflow-hidden rounded-2xl bg-gradient-to-r from-purple-600 via-pink-600 to-purple-600 p-1">
						<div class="relative bg-base-100 rounded-2xl p-8 md:p-12">
							<div class="absolute inset-0 bg-gradient-to-r from-purple-600/10 via-pink-600/10 to-purple-600/10"></div>
							<div class="relative z-10 max-w-3xl mx-auto text-center">
								<h3 class="text-3xl md:text-4xl font-bold mb-4 bg-gradient-to-r from-purple-400 to-pink-400 bg-clip-text text-transparent">
									Want Magic Mirror at Your Event?
								</h3>
								<p class="text-lg md:text-xl text-base-content/80 mb-8 max-w-2xl mx-auto">
									Create unforgettable memories with our AI-powered photo booth experience. Perfect for corporate events, parties, and celebrations.
								</p>
								<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
									<a href="/photobooth" class="btn btn-lg btn-primary bg-gradient-to-r from-purple-500 to-pink-500 border-0 text-white hover:from-purple-600 hover:to-pink-600 shadow-lg hover:shadow-xl transform hover:scale-105 transition-all duration-200">
										Book Magic Mirror
										<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width={2} d="M13 7l5 5m0 0l-5 5m5-5H6" />
										</svg>
									</a>
									<a href="/photobooth#features" class="btn btn-lg btn-outline btn-secondary hover:bg-secondary hover:text-secondary-content">
										View Features
									</a>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>