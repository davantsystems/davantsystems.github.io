  // Hardware detection functions
  function detectPlatform() {
    const userAgent = navigator.userAgent.toLowerCase();
    const platform = navigator.platform.toLowerCase();

    if (platform.includes('win') || userAgent.includes('windows')) {
      return 'windows';
    } else if (platform.includes('mac') || userAgent.includes('macintosh')) {
      return 'mac';
    } else if (platform.includes('linux') || userAgent.includes('linux')) {
      return 'linux';
    }
    return 'unknown';
  }
  
  function detectOSVersion() {
    const userAgent = navigator.userAgent;
    let os = 'Unknown OS';
    let version = '';
    let versionNumber = '';
    
    // Enhanced Windows detection
    if (userAgent.includes('Windows')) {
      os = 'Windows';
      
      // Try modern User-Agent Client Hints API first (Chrome 89+)
      if (navigator.userAgentData && navigator.userAgentData.platformVersion) {
        const platformVersion = navigator.userAgentData.platformVersion;
        const majorVersion = parseInt(platformVersion.split('.')[0]);
        
        if (majorVersion >= 13) {
          version = '11';
        } else if (majorVersion >= 10) {
          version = '10';
        } else {
          version = '10/11'; // Fallback
        }
      }
      // Enhanced Windows 11 detection methods
      else if (userAgent.includes('Windows NT 10.0')) {
        // Try multiple Windows 11 detection methods
        let isWindows11 = false;
        
        // Method 1: Check for Windows 11 specific features
        try {
          if ('windowControlsOverlay' in navigator) {
            isWindows11 = true;
          }
        } catch (e) {}
        
        // Method 2: Screen resolution hints (Windows 11 has different defaults)
        const screenWidth = window.screen.width;
        const screenHeight = window.screen.height;
        if (screenWidth >= 1920 && screenHeight >= 1080) {
          // Check for common Windows 11 resolutions with new scaling
          const ratio = screenWidth / screenHeight;
          if (Math.abs(ratio - 16/9) < 0.1 || Math.abs(ratio - 16/10) < 0.1) {
            // Lean towards Windows 11 for modern high-res displays
            if (!version) isWindows11 = true;
          }
        }
        
        // Method 3: Check for newer browser features that correlate with Windows 11
        try {
          if ('getDisplayMedia' in navigator.mediaDevices && 'requestPictureInPicture' in HTMLVideoElement.prototype) {
            // These APIs are more commonly available on Windows 11 systems
            if (!version) isWindows11 = true;
          }
        } catch (e) {}
        
        version = isWindows11 ? '11' : '10';
        
        // If still uncertain, use the safer fallback
        if (!version) version = '10/11';
      } else if (userAgent.includes('Windows NT 6.3')) {
        version = '8.1';
      } else if (userAgent.includes('Windows NT 6.2')) {
        version = '8';
      } else if (userAgent.includes('Windows NT 6.1')) {
        version = '7';
      }
    }
    // macOS detection
    else if (userAgent.includes('Mac OS X')) {
      os = 'macOS';
      const match = userAgent.match(/Mac OS X ([\d_]+)/);
      if (match) {
        const versionParts = match[1].split('_');
        const major = parseInt(versionParts[0]);
        const minor = parseInt(versionParts[1]) || 0;
        const patch = parseInt(versionParts[2]) || 0;
        
        // Format version number
        if (major >= 11) {
          versionNumber = patch > 0 ? `${major}.${minor}.${patch}` : `${major}.${minor}`;
        } else {
          versionNumber = `10.${minor}${patch > 0 ? '.' + patch : ''}`;
        }
        
        // Convert to macOS version names with numbers
        if (major >= 14) {
          version = `Sonoma ${versionNumber}`;
        } else if (major === 13) {
          version = `Ventura ${versionNumber}`;
        } else if (major === 12) {
          version = `Monterey ${versionNumber}`;
        } else if (major === 11) {
          version = `Big Sur ${versionNumber}`;
        } else if (major === 10) {
          if (minor >= 15) version = `Catalina ${versionNumber}`;
          else if (minor === 14) version = `Mojave ${versionNumber}`;
          else if (minor === 13) version = `High Sierra ${versionNumber}`;
          else version = versionNumber;
        }
      }
    }
    // Linux detection
    else if (userAgent.includes('Linux')) {
      os = 'Linux';
      if (userAgent.includes('Ubuntu')) {
        const ubuntuMatch = userAgent.match(/Ubuntu[\/\s]?([\d\.]+)?/);
        version = ubuntuMatch && ubuntuMatch[1] ? `Ubuntu ${ubuntuMatch[1]}` : 'Ubuntu';
      } else if (userAgent.includes('Fedora')) {
        const fedoraMatch = userAgent.match(/Fedora[\/\s]?([\d\.]+)?/);
        version = fedoraMatch && fedoraMatch[1] ? `Fedora ${fedoraMatch[1]}` : 'Fedora';
      } else if (userAgent.includes('Debian')) {
        const debianMatch = userAgent.match(/Debian[\/\s]?([\d\.]+)?/);
        version = debianMatch && debianMatch[1] ? `Debian ${debianMatch[1]}` : 'Debian';
      }
    }
    
    return version ? `${os} ${version}` : os;
  }

  function detectGPU() {
    let canvas = document.createElement('canvas');
    let gl = canvas.getContext('webgl2') || canvas.getContext('webgl');
    
    if (!gl) {
      return { renderer: 'Unknown', version: 0, confidence: 'low', vram: 0 };
    }

    let renderer = 'Unknown GPU';
    let version = gl instanceof WebGL2RenderingContext ? 2 : 1;
    let confidence = 'low';
    let estimatedVRAM = 0;

    try {
      const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
      if (debugInfo) {
        const rawRenderer = gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) || 'Unknown GPU';
        
        // Enhanced parsing for different GPU vendors
        renderer = parseGPURenderer(rawRenderer);
        
        if (renderer !== 'Unknown GPU') {
          confidence = 'high';
          // Estimate VRAM based on detected GPU
          estimatedVRAM = estimateVRAMFromGPU(renderer, gl);
        }
      }
    } catch (e) {
      console.error('GPU detection error:', e);
    }

    // Enhanced Apple Silicon detection
    if (renderer === 'Apple GPU' || renderer.toLowerCase().includes('apple gpu')) {
      const appleModel = detectAppleSiliconModel(gl);
      if (appleModel) {
        renderer = `Apple ${appleModel}`;
        confidence = 'high';
        estimatedVRAM = estimateAppleSiliconVRAM(appleModel);
      }
    }

    // If we still have unknown GPU, try performance-based detection
    if (renderer === 'Unknown GPU' || confidence === 'low') {
      const perfClass = classifyGPUByPerformance(gl);
      if (perfClass.tier !== 'unknown') {
        renderer = perfClass.description;
        confidence = 'medium';
        estimatedVRAM = perfClass.estimatedVRAM;
      }
    }

    return { renderer, version, confidence, vram: estimatedVRAM };
  }

  function parseGPURenderer(rawRenderer) {
    // Clean up common prefixes/suffixes
    let cleaned = rawRenderer.replace(/ANGLE \(/, '').replace(/\)$/, '').replace(/Direct3D\d+.*?\)/, '').trim();
    
    // NVIDIA parsing
    if (cleaned.toLowerCase().includes('nvidia') || cleaned.toLowerCase().includes('geforce')) {
      // Extract RTX models
      const rtxMatch = cleaned.match(/(?:RTX|GeForce RTX)\s*(\d{4})\s*(Ti|SUPER)?/i);
      if (rtxMatch) {
        const model = rtxMatch[1];
        const variant = rtxMatch[2] ? ` ${rtxMatch[2]}` : '';
        return `NVIDIA RTX ${model}${variant}`;
      }
      
      // Extract GTX models
      const gtxMatch = cleaned.match(/(?:GTX|GeForce GTX)\s*(\d{3,4})\s*(Ti|SUPER)?/i);
      if (gtxMatch) {
        const model = gtxMatch[1];
        const variant = gtxMatch[2] ? ` ${gtxMatch[2]}` : '';
        return `NVIDIA GTX ${model}${variant}`;
      }
      
      return 'NVIDIA GPU';
    }
    
    // AMD parsing
    if (cleaned.toLowerCase().includes('amd') || cleaned.toLowerCase().includes('radeon')) {
      // Extract RX models
      const rxMatch = cleaned.match(/(?:RX|Radeon RX)\s*(\d{4})\s*(XT|XTX)?/i);
      if (rxMatch) {
        const model = rxMatch[1];
        const variant = rxMatch[2] ? ` ${rxMatch[2]}` : '';
        return `AMD RX ${model}${variant}`;
      }
      
      // Extract older R9/R7 models
      const rMatch = cleaned.match(/R(\d)\s*(\d{3})/i);
      if (rMatch) {
        return `AMD R${rMatch[1]} ${rMatch[2]}`;
      }
      
      return 'AMD GPU';
    }
    
    // Intel parsing
    if (cleaned.toLowerCase().includes('intel')) {
      // Intel Arc
      const arcMatch = cleaned.match(/Arc.*?A(\d{3})/i);
      if (arcMatch) {
        return `Intel Arc A${arcMatch[1]}`;
      }
      
      // Intel Iris/UHD
      if (cleaned.toLowerCase().includes('iris xe')) {
        return 'Intel Iris Xe';
      } else if (cleaned.toLowerCase().includes('iris')) {
        return 'Intel Iris';
      } else if (cleaned.toLowerCase().includes('uhd')) {
        return 'Intel UHD Graphics';
      }
      
      return 'Intel Graphics';
    }
    
    return cleaned || 'Unknown GPU';
  }

  function estimateVRAMFromGPU(gpuName, gl) {
    const lowerName = gpuName.toLowerCase();
    
    // NVIDIA estimates
    if (lowerName.includes('rtx 4090')) return 24;
    if (lowerName.includes('rtx 4080')) return 16;
    if (lowerName.includes('rtx 4070 ti') || lowerName.includes('rtx 4070ti')) return 12;
    if (lowerName.includes('rtx 4070')) return 12;
    if (lowerName.includes('rtx 4060 ti') || lowerName.includes('rtx 4060ti')) return 16; // Some are 8GB
    if (lowerName.includes('rtx 4060')) return 8;
    if (lowerName.includes('rtx 3090')) return 24;
    if (lowerName.includes('rtx 3080')) return 10; // Some are 12GB
    if (lowerName.includes('rtx 3070')) return 8;
    if (lowerName.includes('rtx 3060')) return 12; // Some are 8GB
    
    // AMD estimates  
    if (lowerName.includes('rx 7900 xtx')) return 24;
    if (lowerName.includes('rx 7900 xt')) return 20;
    if (lowerName.includes('rx 7800 xt')) return 16;
    if (lowerName.includes('rx 7700 xt')) return 12;
    if (lowerName.includes('rx 6900 xt')) return 16;
    if (lowerName.includes('rx 6800 xt')) return 16;
    if (lowerName.includes('rx 6700 xt')) return 12;
    
    // Intel Arc estimates
    if (lowerName.includes('arc a770')) return 16;
    if (lowerName.includes('arc a750')) return 8;
    if (lowerName.includes('arc a380')) return 6;
    
    // Use WebGL parameters to estimate for unknown GPUs
    return estimateVRAMFromWebGL(gl);
  }

  function estimateVRAMFromWebGL(gl) {
    try {
      // Get maximum texture size (correlates with VRAM)
      const maxTexSize = gl.getParameter(gl.MAX_TEXTURE_SIZE);
      const maxRenderbufferSize = gl.getParameter(gl.MAX_RENDERBUFFER_SIZE);
      
      // Rough VRAM estimation based on texture capabilities
      if (maxTexSize >= 16384) return 8; // High-end
      if (maxTexSize >= 8192) return 4;  // Mid-range
      if (maxTexSize >= 4096) return 2;  // Entry-level
      return 1; // Very basic
    } catch (e) {
      return 0;
    }
  }

  function estimateAppleSiliconVRAM(model) {
    const modelLower = model.toLowerCase();
    if (modelLower.includes('m3 max')) return 48;
    if (modelLower.includes('m3 pro')) return 18;
    if (modelLower.includes('m3')) return 10;
    if (modelLower.includes('m2 max')) return 38;
    if (modelLower.includes('m2 pro')) return 16;
    if (modelLower.includes('m2')) return 10;
    if (modelLower.includes('m1 max')) return 32;
    if (modelLower.includes('m1 pro')) return 16;
    if (modelLower.includes('m1')) return 8;
    return 8; // Fallback
  }

  function classifyGPUByPerformance(gl) {
    try {
      const startTime = performance.now();
      
      // Create a complex shader for GPU performance testing
      const vertexShader = gl.createShader(gl.VERTEX_SHADER);
      gl.shaderSource(vertexShader, `
        attribute vec2 position;
        void main() {
          gl_Position = vec4(position, 0.0, 1.0);
        }
      `);
      gl.compileShader(vertexShader);
      
      const fragmentShader = gl.createShader(gl.FRAGMENT_SHADER);
      gl.shaderSource(fragmentShader, `
        precision mediump float;
        void main() {
          vec2 coord = gl_FragCoord.xy / 1000.0;
          float result = 0.0;
          for(int i = 0; i < 100; i++) {
            result += sin(coord.x * float(i)) * cos(coord.y * float(i));
          }
          gl_FragColor = vec4(result, result, result, 1.0);
        }
      `);
      gl.compileShader(fragmentShader);
      
      const program = gl.createProgram();
      gl.attachShader(program, vertexShader);
      gl.attachShader(program, fragmentShader);
      gl.linkProgram(program);
      
      const elapsedTime = performance.now() - startTime;
      
      // Clean up
      gl.deleteShader(vertexShader);
      gl.deleteShader(fragmentShader);
      gl.deleteProgram(program);
      
      // Classify based on shader compilation time (rough indicator)
      if (elapsedTime < 5) {
        return { tier: 'high', description: 'High-end GPU', estimatedVRAM: 8 };
      } else if (elapsedTime < 15) {
        return { tier: 'medium', description: 'Mid-range GPU', estimatedVRAM: 4 };
      } else {
        return { tier: 'low', description: 'Entry-level GPU', estimatedVRAM: 2 };
      }
    } catch (e) {
      return { tier: 'unknown', description: 'Unknown GPU', estimatedVRAM: 0 };
    }
  }

  function detectAppleSiliconModel(gl) {
    const platform = navigator.platform;
    const cores = navigator.hardwareConcurrency || 0;
    
    if (!platform.includes('Mac')) {
      return null;
    }

    // Try Chrome's detailed renderer string first
    if (gl) {
      try {
        const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
        if (debugInfo) {
          const renderer = gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) || '';
          const appleMatch = renderer.match(/Apple\s*(M\d+(?:\s*(?:Pro|Max|Ultra))?)/i);
          if (appleMatch) {
            return appleMatch[1];
          }
        }
      } catch (e) {}
    }

    // Fallback based on core count
    const year = new Date().getFullYear();
    const isRecent = year >= 2023;

    if (cores >= 20) {
      return isRecent ? 'M3 Max' : 'M2 Ultra';
    } else if (cores >= 16) {
      return isRecent ? 'M3 Pro' : 'M2 Max';
    } else if (cores >= 12) {
      return 'M2 Pro';
    } else if (cores >= 10) {
      return 'M2';
    } else if (cores >= 8) {
      return 'M2';
    }

    return 'Apple Silicon';
  }

  function detectScreen() {
    return {
      width: window.screen.width * (window.devicePixelRatio || 1),
      height: window.screen.height * (window.devicePixelRatio || 1),
    };
  }

  function detectCPU() {
    const cores = navigator.hardwareConcurrency || 4;
    let model = 'Unknown CPU';
    let confidence = 'low';
    
    // Try to infer CPU model based on platform and core count
    const platform = detectPlatform();
    const gpuInfo = detectGPU();
    
    if (platform === 'mac' && gpuInfo.renderer.toLowerCase().includes('apple')) {
      // Apple Silicon detection based on GPU renderer and cores
      const appleModel = detectAppleSiliconModel(null);
      if (appleModel && appleModel !== 'Apple Silicon') {
        model = `Apple ${appleModel}`;
        confidence = 'high';
      } else {
        model = 'Apple Silicon';
        confidence = 'medium';
      }
    } else if (platform === 'windows' || platform === 'linux') {
      // Enhanced CPU detection for Windows/Linux
      const cpuClass = classifyCPUByPerformance(cores);
      model = cpuClass.description;
      confidence = cpuClass.confidence;
    }
    
    return { cores, model, confidence };
  }

  function classifyCPUByPerformance(cores) {
    // Run a lightweight CPU benchmark
    const perfScore = runCPUBenchmark();
    const deviceMemory = navigator.deviceMemory || 0;
    
    // Estimate CPU generation/tier based on performance and system characteristics
    let description = 'Unknown CPU';
    let confidence = 'low';
    
    // High-performance tier (13th gen Intel, Ryzen 7000)
    if (perfScore < 10 && cores >= 16) {
      description = `High-end CPU (${cores} cores, ~2023+ generation)`;
      confidence = 'medium';
    } else if (perfScore < 10 && cores >= 12) {
      description = `Performance CPU (${cores} cores, ~2022+ generation)`;
      confidence = 'medium';
    } else if (perfScore < 10 && cores >= 8) {
      description = `Modern CPU (${cores} cores, ~2021+ generation)`;
      confidence = 'medium';
    }
    // Mid-performance tier (12th gen Intel, Ryzen 5000)
    else if (perfScore < 20 && cores >= 16) {
      description = `Performance CPU (${cores} cores, ~2021-2022 generation)`;
      confidence = 'medium';
    } else if (perfScore < 20 && cores >= 8) {
      description = `Mid-range CPU (${cores} cores, ~2020-2021 generation)`;
      confidence = 'medium';
    } else if (perfScore < 20 && cores >= 6) {
      description = `Standard CPU (${cores} cores, ~2019+ generation)`;
      confidence = 'medium';
    }
    // Lower-performance tier (older generations)
    else if (perfScore < 40 && cores >= 8) {
      description = `Older CPU (${cores} cores, ~2018-2020 generation)`;
      confidence = 'medium';
    } else if (cores >= 4) {
      description = `Entry-level CPU (${cores} cores)`;
      confidence = 'low';
    } else {
      description = `Basic CPU (${cores} cores)`;
      confidence = 'low';
    }
    
    // Factor in device memory as additional hint
    if (deviceMemory >= 16 && confidence === 'medium') {
      confidence = 'medium-high';
    } else if (deviceMemory >= 8 && confidence === 'low') {
      confidence = 'medium';
    }
    
    return { description, confidence };
  }

  function runCPUBenchmark() {
    const iterations = 50000;
    const startTime = performance.now();
    
    // Simple mathematical benchmark
    let result = 0;
    for (let i = 0; i < iterations; i++) {
      result += Math.sqrt(i) * Math.sin(i) + Math.cos(i * 0.1);
    }
    
    const elapsedTime = performance.now() - startTime;
    
    // Return normalized score (lower is better performance)
    return elapsedTime;
  }

  // Scoring functions
  function calculateGPUScore(specs) {
    if (specs.userProvided.gpuModel) {
      const gpuInfo = GPU_DATABASE[specs.userProvided.gpuModel];
      if (gpuInfo) {
        return (gpuInfo.minScore + gpuInfo.maxScore) / 2;
      }
    }

    // Check detected GPU renderer
    const renderer = specs.detected.gpuRenderer.toLowerCase();
    
    // Try to match against known Apple Silicon models
    if (renderer.includes('apple')) {
      // Extract model from renderer string like "Apple M2"
      const modelMatch = renderer.match(/apple\s*(m\d+(?:\s*(?:pro|max|ultra))?)/i);
      if (modelMatch) {
        const modelKey = modelMatch[1].toLowerCase().replace(/\s+/g, '-');
        const gpuInfo = GPU_DATABASE[modelKey];
        if (gpuInfo) {
          return (gpuInfo.minScore + gpuInfo.maxScore) / 2;
        }
      }
      
      // Generic Apple Silicon score
      if (renderer.includes('apple silicon')) {
        return 60; // Base M1 level performance
      }
    }

    // Check for integrated graphics
    if (renderer.includes('intel') && !renderer.includes('arc')) {
      return 10;
    }

    return 25;
  }

  function calculateRAMScore(specs) {
    const ram = specs.userProvided.systemRAM || 0;
    if (ram === 0) return 0;
    
    const { minimum, recommended, optimal } = REQUIREMENTS.ram;
    
    if (ram >= optimal) return 100;
    if (ram >= recommended) return 80 + ((ram - recommended) / (optimal - recommended)) * 20;
    if (ram >= minimum) return 50 + ((ram - minimum) / (recommended - minimum)) * 30;
    
    return Math.max(0, (ram / minimum) * 50);
  }

  function calculateCPUScore(specs) {
    const cores = specs.detected.cpuCores;
    const { minimum, recommended, optimal } = REQUIREMENTS.cpu;
    
    if (cores >= optimal) return 100;
    if (cores >= recommended) return 80 + ((cores - recommended) / (optimal - recommended)) * 20;
    if (cores >= minimum) return 50 + ((cores - minimum) / (recommended - minimum)) * 30;
    
    return Math.max(0, (cores / minimum) * 50);
  }


  function calculateCompatibility(specs) {
    const scores = {
      gpu: calculateGPUScore(specs),
      ram: calculateRAMScore(specs),
      cpu: calculateCPUScore(specs)
    };

    const overallScore = Math.round(
      scores.gpu * COMPONENT_WEIGHTS.gpu +
      scores.ram * COMPONENT_WEIGHTS.ram +
      scores.cpu * COMPONENT_WEIGHTS.cpu
    );

    const minScore = Math.min(scores.gpu, scores.ram);
    let tier = 'recommended';
    
    if (minScore < 30 || overallScore < 40) {
      tier = 'incompatible';
    } else if (minScore < 50 || overallScore < 60) {
      tier = 'minimum';
    } else if (overallScore >= 80 && minScore >= 70) {
      tier = 'optimal';
    }

    const recommendations = generateRecommendations(scores, specs);

    return { score: overallScore, tier, scores, recommendations };
  }

  function generateRecommendations(scores, specs) {
    const recommendations = [];
    
    if (scores.gpu < 50) {
      recommendations.push('Upgrade to at least an NVIDIA RTX 3060 or Apple M1 for basic functionality');
    } else if (scores.gpu < 80) {
      recommendations.push('Consider upgrading to an RTX 4070 or M2 Pro for optimal performance');
    }
    
    const currentRAM = specs.userProvided.systemRAM || 0;
    if (currentRAM > 0 && currentRAM < REQUIREMENTS.ram.minimum) {
      recommendations.push(`Upgrade RAM from ${currentRAM}GB to at least ${REQUIREMENTS.ram.minimum}GB`);
    } else if (currentRAM < REQUIREMENTS.ram.recommended) {
      recommendations.push(`Consider upgrading to ${REQUIREMENTS.ram.recommended}GB RAM for better multitasking`);
    }
    
    // Storage recommendation (always show)
    recommendations.push('Note: We recommend at least 40GB of free storage for Stable Diffusion models');
    
    if (recommendations.length === 0) {
      recommendations.push('Your system exceeds recommended specifications!');
      recommendations.push('Enable GPU acceleration in Davant Studio for maximum performance');
    }
    
    return recommendations;
  }

  // UI update functions
  function updateDetectionStatus(message) {
    document.getElementById('detection-status').textContent = message;
  }

  function animateScore(targetScore) {
    const scoreElement = document.getElementById('score-value');
    const circle = document.getElementById('score-circle');
    const circumference = 2 * Math.PI * 72; // Updated for new radius
    
    // Set initial state
    circle.classList.add('score-animate');
    circle.style.setProperty('--score-offset', circumference - (targetScore / 100) * circumference);
    
    // Update glow based on score
    const scoreGlow = document.getElementById('score-glow');
    if (scoreGlow) {
      if (targetScore >= 85) {
        scoreGlow.className = 'absolute inset-0 w-40 h-40 rounded-full bg-gradient-to-r from-emerald-500 to-cyan-500 blur-xl opacity-40 transition-all duration-2000';
      } else if (targetScore >= 70) {
        scoreGlow.className = 'absolute inset-0 w-40 h-40 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 blur-xl opacity-30 transition-all duration-2000';
      } else if (targetScore >= 50) {
        scoreGlow.className = 'absolute inset-0 w-40 h-40 rounded-full bg-gradient-to-r from-amber-500 to-orange-500 blur-xl opacity-30 transition-all duration-2000';
      } else {
        scoreGlow.className = 'absolute inset-0 w-40 h-40 rounded-full bg-gradient-to-r from-red-500 to-pink-500 blur-xl opacity-30 transition-all duration-2000';
      }
    }
    
    // Animate the number counter with easing
    let startTime = null;
    const duration = 2000; // 2 seconds to match CSS animation
    
    function easeOutCubic(t) {
      return 1 - Math.pow(1 - t, 3);
    }
    
    function updateCounter(currentTime) {
      if (!startTime) startTime = currentTime;
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      
      const easedProgress = easeOutCubic(progress);
      const currentScore = Math.round(easedProgress * targetScore);
      
      scoreElement.textContent = currentScore.toString();
      
      if (progress < 1) {
        requestAnimationFrame(updateCounter);
      } else {
        // Trigger status icon reveal after score completes
        setTimeout(() => {
          const icons = document.querySelectorAll('#success-icon, #warning-icon, #error-icon');
          icons.forEach(icon => {
            if (!icon.classList.contains('hidden')) {
              icon.style.animation = 'statusPulse 0.6s ease-out';
            }
          });
        }, 100);
      }
    }
    
    requestAnimationFrame(updateCounter);
  }

  function updateTierDisplay(tier) {
    const answerElement = document.getElementById('compatibility-answer');
    const explanationElement = document.getElementById('compatibility-explanation');
    const successIcon = document.getElementById('success-icon');
    const warningIcon = document.getElementById('warning-icon');
    const errorIcon = document.getElementById('error-icon');
    
    // Hide all icons
    successIcon.classList.add('hidden');
    warningIcon.classList.add('hidden');
    errorIcon.classList.add('hidden');
    
    const tierMessages = {
      optimal: {
        answer: 'Your computer will run Davant Studio excellently',
        explanation: 'You\'ll enjoy fast AI generation with all features available.',
        icon: 'success',
        answerClass: 'text-emerald-400'
      },
      recommended: {
        answer: 'Your computer can run Davant Studio well',
        explanation: 'You\'ll have smooth performance with most features working great.',
        icon: 'success',
        answerClass: 'text-emerald-400'
      },
      minimum: {
        answer: 'Your computer can run Davant Studio',
        explanation: 'It will work, but some features may be slower or limited.',
        icon: 'warning',
        answerClass: 'text-amber-400'
      },
      incompatible: {
        answer: 'Your computer needs upgrades for Davant Studio',
        explanation: 'We recommend upgrading your hardware before purchasing.',
        icon: 'error',
        answerClass: 'text-red-400'
      }
    };
    
    const config = tierMessages[tier];
    answerElement.textContent = config.answer;
    answerElement.className = `text-lg font-bold ${config.answerClass}`;
    
    // Typewriter effect for explanation
    explanationElement.textContent = '';
    const text = config.explanation;
    let charIndex = 0;
    
    function typeWriter() {
      if (charIndex < text.length) {
        explanationElement.textContent += text.charAt(charIndex);
        charIndex++;
        setTimeout(typeWriter, 30);
      }
    }
    
    // Start typewriter after a short delay
    setTimeout(typeWriter, 500);
    
    // Show appropriate icon
    if (config.icon === 'success') {
      successIcon.classList.remove('hidden');
    } else if (config.icon === 'warning') {
      warningIcon.classList.remove('hidden');
    } else if (config.icon === 'error') {
      errorIcon.classList.remove('hidden');
    }
  }

  function updateComponentStatus(component, score, specs) {
    const statusElement = document.getElementById(`${component}-status`);
    const progressElement = document.getElementById(`${component}-progress`);
    
    let status = 'Optimal';
    let statusClass = 'bg-emerald-500/20 text-emerald-300';
    
    if (score < 50) {
      status = 'Below Minimum';
      statusClass = 'bg-red-500/20 text-red-300';
    } else if (score < 70) {
      status = 'Minimum';
      statusClass = 'bg-amber-500/20 text-amber-300';
    } else if (score < 85) {
      status = 'Recommended';
      statusClass = 'bg-cyan-500/20 text-cyan-300';
    }
    
    // Animate status badge appearance
    statusElement.style.transform = 'scale(0)';
    statusElement.textContent = status;
    statusElement.className = `absolute top-1 right-1 px-2 py-0.5 text-xs transition-all duration-300 rounded ${statusClass}`;
    
    // Animate progress bar
    if (progressElement) {
      setTimeout(() => {
        progressElement.style.width = `${score}%`;
      }, 200);
    }
    
    // Animate status badge scale
    setTimeout(() => {
      statusElement.style.transform = 'scale(1)';
    }, 100);
    
    // Update component-specific elements
    switch (component) {
      case 'gpu':
        let gpuModel = 'Unknown GPU';
        if (specs.userProvided.gpuModel && GPU_DATABASE[specs.userProvided.gpuModel]) {
          // User selected from dropdown
          gpuModel = GPU_DATABASE[specs.userProvided.gpuModel].model;
        } else if (specs.detected.gpuRenderer) {
          // Auto-detected or form-provided display text
          gpuModel = specs.detected.gpuRenderer;
        }
        const gpuModelElement = document.getElementById('gpu-model-display');
        const gpuScoreElement = document.getElementById('gpu-score');
        if (gpuModelElement) {
          gpuModelElement.textContent = gpuModel;
          gpuModelElement.classList.remove('hidden'); // Ensure it's visible
        }
        if (gpuScoreElement) gpuScoreElement.textContent = `Score: ${Math.round(score)}/100`;
        break;
      case 'ram':
        const ram = specs.userProvided.systemRAM || specs.detected.estimatedRAM || 0;
        const ramAmountElement = document.getElementById('ram-amount');
        const ramScoreElement = document.getElementById('ram-score');
        if (ramAmountElement) {
          ramAmountElement.textContent = `${ram}GB`;
          ramAmountElement.classList.remove('hidden'); // Ensure it's visible
        }
        if (ramScoreElement) ramScoreElement.textContent = `Score: ${Math.round(score)}/100`;
        break;
      case 'cpu':
        let cpuDisplay = 'Unknown CPU';
        if (specs.detected.cpuModel) {
          cpuDisplay = specs.detected.cpuModel;
          if (specs.detected.cpuCores) {
            cpuDisplay += ` (${specs.detected.cpuCores} cores)`;
          }
        } else if (specs.detected.cpuCores) {
          cpuDisplay = `${specs.detected.cpuCores} cores`;
        }
        const cpuModelElement = document.getElementById('cpu-model-display');
        const cpuScoreElement = document.getElementById('cpu-score');
        if (cpuModelElement) {
          cpuModelElement.textContent = cpuDisplay;
          cpuModelElement.classList.remove('hidden'); // Ensure it's visible
        }
        if (cpuScoreElement) cpuScoreElement.textContent = `Score: ${Math.round(score)}/100`;
        break;
    }
  }

  // Function to update progress bar
  function updateProgressBar(percent) {
    const progressBar = document.getElementById('progress-bar');
    progressBar.style.width = percent + '%';
  }

  // Function to show results
  function showResults() {
    // Calculate compatibility
    const result = calculateCompatibility(systemSpecs);
    
    // Smooth phase transition
    const detectionPhase = document.getElementById('detection-phase');
    const inputPhase = document.getElementById('input-phase');
    const resultsPhase = document.getElementById('results-phase');
    
    // Fade out current phase
    if (!detectionPhase.classList.contains('hidden')) {
      detectionPhase.style.opacity = '0';
      setTimeout(() => detectionPhase.classList.add('hidden'), 300);
    }
    if (!inputPhase.classList.contains('hidden')) {
      inputPhase.style.opacity = '0';
      setTimeout(() => inputPhase.classList.add('hidden'), 300);
    }
    
    // Show results with fade in
    setTimeout(() => {
      resultsPhase.classList.remove('hidden');
      resultsPhase.style.opacity = '0';
      setTimeout(() => {
        resultsPhase.style.transition = 'opacity 0.5s ease';
        resultsPhase.style.opacity = '1';
      }, 50);
    }, 350);
    
    // Animate the score circle and update score
    animateScore(result.score);
    
    // Update tier display with new user-friendly messages
    updateTierDisplay(result.tier);
    
    // Update components
    updateComponentStatus('gpu', result.scores.gpu, systemSpecs);
    updateComponentStatus('ram', result.scores.ram, systemSpecs);
    updateComponentStatus('cpu', result.scores.cpu, systemSpecs);
    
    // Show recommendations
    if (result.recommendations.length > 0) {
      document.getElementById('recommendations').classList.remove('hidden');
      const list = document.getElementById('recommendation-list');
      list.innerHTML = result.recommendations
        .map(rec => `<li class="flex items-start">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <span>${rec}</span>
        </li>`)
        .join('');
    }
  }

  // Helper function to show component detection
  function showComponentDetection(componentId, value) {
    const row = document.getElementById(`${componentId}-row`);
    const spinner = document.getElementById(`${componentId}-spinner`);
    const check = document.getElementById(`${componentId}-check`);
    const valueSpan = document.getElementById(`detected-${componentId}`);
    
    // Activate row
    row.classList.remove('opacity-30');
    row.classList.add('opacity-100');
    
    // Show spinner if not already shown
    if (spinner && spinner.classList.contains('hidden')) {
      spinner.classList.remove('hidden');
    }
    
    // Update value
    valueSpan.textContent = 'Detecting...';
    valueSpan.classList.remove('text-cyan-100/50');
    valueSpan.classList.add('text-cyan-100/70');
    
    // After a short delay, show the result
    setTimeout(() => {
      valueSpan.innerHTML = value;
      valueSpan.classList.remove('text-cyan-100/70');
      valueSpan.classList.add('text-cyan-100');
      
      // Hide spinner and show check
      if (spinner) spinner.classList.add('hidden');
      if (check) check.classList.remove('hidden');
    }, 400);
  }

  // Function to start auto-detection
  function startAutoDetection() {
    // Hide choice phase and intro description, show detection phase
    document.getElementById('choice-phase').classList.add('hidden');
    document.getElementById('intro-description').classList.add('hidden');
    document.getElementById('detection-phase').classList.remove('hidden');
    
    // Reset all rows to initial state
    ['platform', 'gpu', 'cpu', 'display'].forEach(comp => {
      const row = document.getElementById(`${comp}-row`);
      const check = document.getElementById(`${comp}-check`);
      const spinner = document.getElementById(`${comp}-spinner`);
      const value = document.getElementById(`detected-${comp}`);
      
      row.classList.add('opacity-30');
      row.classList.remove('opacity-100');
      check.classList.add('hidden');
      if (comp !== 'platform') spinner.classList.add('hidden');
      value.textContent = 'Waiting...';
      value.classList.add('text-cyan-100/50');
      value.classList.remove('text-cyan-100');
    });
    
    // Start detection with progress animation
    updateDetectionStatus('Initializing hardware detection...');
    updateProgressBar(10);
    
    // Detect platform first
    setTimeout(() => {
      updateProgressBar(25);
      updateDetectionStatus('Detecting operating system...');
      systemSpecs.detected.platform = detectPlatform();
      systemSpecs.detected.osVersion = detectOSVersion();
      showComponentDetection('platform', systemSpecs.detected.osVersion);
    }, 500);
    
    // Then GPU
    setTimeout(() => {
      updateProgressBar(50);
      updateDetectionStatus('Analyzing graphics processor...');
      document.getElementById('gpu-spinner').classList.remove('hidden');
      
      const gpuInfo = detectGPU();
      systemSpecs.detected.gpuRenderer = gpuInfo.renderer;
      systemSpecs.detected.webglVersion = gpuInfo.version;
      systemSpecs.detected.gpuConfidence = gpuInfo.confidence;
      systemSpecs.detected.estimatedVRAM = gpuInfo.vram;
      
      // Show GPU with confidence indicator
      let displayText = gpuInfo.renderer || 'Unknown';
      if (gpuInfo.confidence === 'high') {
        displayText += ' <span class="text-green-400">✓</span>';
      } else if (gpuInfo.confidence === 'medium') {
        displayText += ' <span class="text-yellow-400">~</span>';
      }
      
      if (gpuInfo.vram > 0) {
        displayText += ` (${gpuInfo.vram}GB VRAM)`;
      }
      
      showComponentDetection('gpu', displayText);
    }, 1200);
    
    // Then CPU
    setTimeout(() => {
      updateProgressBar(70);
      updateDetectionStatus('Checking processor performance...');
      document.getElementById('cpu-spinner').classList.remove('hidden');
      
      const cpuInfo = detectCPU();
      systemSpecs.detected.cpuCores = cpuInfo.cores;
      systemSpecs.detected.cpuModel = cpuInfo.model;
      systemSpecs.detected.cpuConfidence = cpuInfo.confidence;
      
      // Show CPU with confidence indicator
      let displayText = cpuInfo.model;
      if (cpuInfo.confidence === 'high') {
        displayText += ' <span class="text-green-400">✓</span>';
      } else if (cpuInfo.confidence === 'medium' || cpuInfo.confidence === 'medium-high') {
        displayText += ' <span class="text-yellow-400">~</span>';
      }
      
      showComponentDetection('cpu', displayText);
    }, 2000);
    
    // Finally display
    setTimeout(() => {
      updateProgressBar(90);
      updateDetectionStatus('Reading display information...');
      document.getElementById('display-spinner').classList.remove('hidden');
      
      systemSpecs.detected.screenResolution = detectScreen();
      showComponentDetection('display', 
        `${systemSpecs.detected.screenResolution.width} × ${systemSpecs.detected.screenResolution.height}`);
    }, 2800);
    
    // Complete detection
    setTimeout(() => {
      updateProgressBar(100);
      updateDetectionStatus('Detection complete!');
      
      // Small delay before processing results
      setTimeout(() => {
      
      // Check if we detected enough information to skip manual input
      const hasGPUInfo = systemSpecs.detected.gpuRenderer && 
                        systemSpecs.detected.gpuRenderer !== 'Unknown' &&
                        systemSpecs.detected.gpuRenderer !== 'Unknown GPU';
      
      const isAppleSilicon = systemSpecs.detected.gpuRenderer.toLowerCase().includes('apple');
      
      if (hasGPUInfo && isAppleSilicon) {
        // For Apple Silicon, we can estimate RAM based on the model
        const renderer = systemSpecs.detected.gpuRenderer.toLowerCase();
        let estimatedRAM = 16; // Default
        
        if (renderer.includes('max') || renderer.includes('ultra')) {
          estimatedRAM = 32; // M1/M2/M3 Max typically have 32GB+
        } else if (renderer.includes('pro')) {
          estimatedRAM = 16; // M1/M2/M3 Pro typically have 16GB+
        } else {
          estimatedRAM = 8; // Base models typically have 8GB+
        }
        
        // Set defaults for Apple Silicon
        systemSpecs.userProvided.systemRAM = estimatedRAM;
        systemSpecs.detected.estimatedRAM = estimatedRAM;
        
        // Map detected GPU to our database
        const modelMatch = renderer.match(/apple\s*(m\d+(?:\s*(?:pro|max|ultra))?)/i);
        if (modelMatch) {
          const modelKey = modelMatch[1].toLowerCase().replace(/\s+/g, '-');
          if (GPU_DATABASE[modelKey]) {
            systemSpecs.userProvided.gpuModel = modelKey;
          }
        }
        
        // Skip to results
        setTimeout(() => {
          document.getElementById('detection-phase').classList.add('hidden');
          showResults();
        }, 1500);
      } else {
        // Show input phase for manual entry
        setTimeout(() => {
          document.getElementById('detection-phase').classList.add('hidden');
          document.getElementById('input-phase').classList.remove('hidden');
        }, 1500);
      }
      }, 500);
    }, 3600);
  }
  
  // Main execution
  document.addEventListener('DOMContentLoaded', async () => {
    // Handle auto-detect button
    document.getElementById('auto-detect-button').addEventListener('click', () => {
      startAutoDetection();
    });
    
    // Handle manual input button
    document.getElementById('manual-input-button').addEventListener('click', () => {
      // Hide choice phase and intro description, show input phase directly
      document.getElementById('choice-phase').classList.add('hidden');
      document.getElementById('intro-description').classList.add('hidden');
      document.getElementById('input-phase').classList.remove('hidden');
    });
    
    // Handle OS selection and CPU options
    const osSelect = document.getElementById('os-select');
    const cpuModelSelect = document.getElementById('cpu-model');
    const gpuBrandSelect = document.getElementById('gpu-brand');
    const gpuModelSelect = document.getElementById('gpu-model');
    
    if (osSelect && cpuModelSelect) {
      osSelect.addEventListener('change', (e) => {
        const osValue = e.target.value;
        
        // Clear CPU options
        cpuModelSelect.innerHTML = '<option value="">Select CPU...</option>';
        
        if (!osValue) {
          return;
        }
        
        // Determine OS type
        let osType = 'windows';
        if (osValue.includes('macos')) {
          osType = 'mac';
        } else if (osValue === 'linux') {
          osType = 'linux';
        }
        
        // Populate CPU options based on OS
        const cpuOptions = CPU_OPTIONS_BY_OS[osType];
        if (cpuOptions) {
          cpuOptions.forEach(group => {
            const optgroup = document.createElement('optgroup');
            optgroup.label = group.group;
            
            group.options.forEach(option => {
              const opt = document.createElement('option');
              opt.value = option.value;
              opt.textContent = option.text;
              optgroup.appendChild(opt);
            });
            
            cpuModelSelect.appendChild(optgroup);
          });
        }
        
        // Add "Other" option
        const otherOption = document.createElement('option');
        otherOption.value = 'other';
        otherOption.textContent = 'Other/Older CPU';
        cpuModelSelect.appendChild(otherOption);
        
        // Handle macOS GPU auto-selection
        if (osType === 'mac') {
          // Check if an Apple Silicon CPU will be selected
          cpuModelSelect.addEventListener('change', function handleCPUChange(e) {
            const cpuValue = e.target.value;
            if (cpuValue && cpuValue.startsWith('m')) {
              // It's Apple Silicon - auto-select Apple GPU
              gpuBrandSelect.value = 'apple';
              gpuBrandSelect.dispatchEvent(new Event('change'));
              
              // After GPU models load, select the matching GPU
              setTimeout(() => {
                if (gpuModelSelect) {
                  gpuModelSelect.value = cpuValue; // CPU and GPU values match for Apple Silicon
                }
              }, 100);
            }
            
            // Remove this listener after first use
            cpuModelSelect.removeEventListener('change', handleCPUChange);
          });
        }
      });
    }
    
    // Handle GPU brand selection
    if (gpuBrandSelect && gpuModelSelect) {
      gpuBrandSelect.addEventListener('change', (e) => {
        const brand = e.target.value;
        
        // Clear current options
        gpuModelSelect.innerHTML = '';
        
        if (!brand) {
          gpuModelSelect.innerHTML = '<option value="">Select brand first...</option>';
          gpuModelSelect.disabled = true;
          return;
        }
        
        // Enable the model select
        gpuModelSelect.disabled = false;
        
        // Add default option
        gpuModelSelect.innerHTML = '<option value="">Select model...</option>';
        
        // Add models for selected brand
        const brandModels = GPU_MODELS_BY_BRAND[brand];
        if (brandModels) {
          Object.entries(brandModels).forEach(([series, models]) => {
            const optgroup = document.createElement('optgroup');
            optgroup.label = series;
            
            models.forEach(model => {
              const option = document.createElement('option');
              option.value = model.value;
              option.textContent = model.text;
              optgroup.appendChild(option);
            });
            
            gpuModelSelect.appendChild(optgroup);
          });
        }
        
        // Add "Other" option
        const otherOption = document.createElement('option');
        otherOption.value = 'other';
        otherOption.textContent = 'Other/Not Listed';
        gpuModelSelect.appendChild(otherOption);
      });
    }
    
    // Handle switch to auto-detection
    const switchToAutoBtn = document.getElementById('switch-to-auto');
    if (switchToAutoBtn) {
      switchToAutoBtn.addEventListener('click', () => {
        // Hide input phase and start auto-detection
        document.getElementById('input-phase').classList.add('hidden');
        startAutoDetection();
      });
    }
    
    // Handle form submission
    document.getElementById('specs-form').addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Get form values
      const osSelect = document.getElementById('os-select').value;
      if (osSelect) {
        // Map OS selection to platform and version
        if (osSelect.includes('windows')) {
          systemSpecs.detected.platform = 'windows';
          if (osSelect === 'windows-11') systemSpecs.detected.osVersion = 'Windows 11';
          else if (osSelect === 'windows-10') systemSpecs.detected.osVersion = 'Windows 10';
        } else if (osSelect.includes('macos')) {
          systemSpecs.detected.platform = 'mac';
          if (osSelect === 'macos-sonoma') systemSpecs.detected.osVersion = 'macOS Sonoma';
          else if (osSelect === 'macos-ventura') systemSpecs.detected.osVersion = 'macOS Ventura';
          else if (osSelect === 'macos-monterey') systemSpecs.detected.osVersion = 'macOS Monterey';
        } else if (osSelect === 'linux') {
          systemSpecs.detected.platform = 'linux';
          systemSpecs.detected.osVersion = 'Linux';
        }
      }
      
      const cpuModel = document.getElementById('cpu-model').value;
      if (cpuModel) {
        systemSpecs.detected.cpuCores = CPU_CORES_MAP[cpuModel] || 4;
        
        // Map CPU selection to model name
        const cpuOption = document.querySelector(`#cpu-model option[value="${cpuModel}"]`);
        if (cpuOption) {
          systemSpecs.detected.cpuModel = cpuOption.textContent || 'Unknown CPU';
        }
      }
      
      const gpuModelValue = document.getElementById('gpu-model').value;
      systemSpecs.userProvided.gpuModel = gpuModelValue || undefined;
      
      // Also store the display text for the GPU
      if (gpuModelValue) {
        const gpuOption = document.querySelector(`#gpu-model option[value="${gpuModelValue}"]`);
        if (gpuOption) {
          systemSpecs.detected.gpuRenderer = gpuOption.textContent || 'Unknown GPU';
        }
      }
      
      systemSpecs.userProvided.systemRAM = parseInt(document.getElementById('system-ram').value) || 0;
      
      // Log the final specs for debugging
      console.log('Form submission - systemSpecs:', systemSpecs);
      
      // Hide input phase and show results
      document.getElementById('input-phase').classList.add('hidden');
      showResults();
    });
    
    
    // Handle recheck
    document.getElementById('recheck-button').addEventListener('click', () => {
      // Reset everything and go back to choice screen
      document.getElementById('results-phase').classList.add('hidden');
      document.getElementById('detection-phase').classList.add('hidden');
      document.getElementById('input-phase').classList.add('hidden');
      document.getElementById('choice-phase').classList.remove('hidden');
      document.getElementById('intro-description').classList.remove('hidden');
      
      // Reset system specs
      systemSpecs = {
        detected: {
          platform: 'unknown',
          osVersion: '',
          gpuRenderer: '',
          webglVersion: 0,
          cpuCores: 0,
          cpuModel: '',
          screenResolution: { width: 0, height: 0 }
        },
        userProvided: {}
      };
      
      // Reset form
      document.getElementById('specs-form').reset();
      
      // Reset GPU model dropdown
      const gpuModelSelect = document.getElementById('gpu-model');
      if (gpuModelSelect) {
        gpuModelSelect.innerHTML = '<option value="">Select brand first...</option>';
        gpuModelSelect.disabled = true;
      }
    });
  });
</script>