---
import Layout from "../../layouts/Layout.astro";
import MainNavWithDropdowns from "../../components/MainNavWithDropdowns.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "System Compatibility Checker | Davant Studio";
---

<Layout title={pageTitle}>
  <MainNavWithDropdowns />
  <style>
    /* Enhanced animations for visual polish */
    @keyframes scoreReveal {
      0% {
        stroke-dashoffset: 452;
        opacity: 0;
      }
      20% {
        opacity: 1;
      }
      100% {
        stroke-dashoffset: var(--score-offset, 452);
      }
    }

    @keyframes counterTick {
      from {
        transform: translateY(10px);
        opacity: 0;
      }
      to {
        transform: translateY(0);
        opacity: 1;
      }
    }

    @keyframes cardReveal {
      from {
        transform: translateY(20px) scale(0.95);
        opacity: 0;
      }
      to {
        transform: translateY(0) scale(1);
        opacity: 1;
      }
    }

    @keyframes statusPulse {
      0%, 100% {
        transform: scale(1);
      }
      50% {
        transform: scale(1.05);
      }
    }

    @keyframes scanBeam {
      0% {
        transform: translateX(-100%);
      }
      100% {
        transform: translateX(100%);
      }
    }

    @keyframes glowPulse {
      0%, 100% {
        opacity: 0.3;
      }
      50% {
        opacity: 0.6;
      }
    }

    @keyframes typewriter {
      from {
        clip-path: inset(0 100% 0 0);
      }
      to {
        clip-path: inset(0 0 0 0);
      }
    }

    /* Component card hover effects */
    .component-card {
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform;
    }

    .component-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px -10px rgba(139, 92, 246, 0.3);
    }

    .component-card:hover .card-glow {
      opacity: 1;
    }

    .card-glow {
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    /* Progress bar animations */
    .progress-fill {
      animation: scanBeam 2s ease-in-out infinite;
    }

    /* Score circle animations */
    .score-animate {
      animation: scoreReveal 2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }

    /* Staggered reveals */
    .stagger-1 {
      animation: cardReveal 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      animation-delay: 0.2s;
      opacity: 0;
    }

    .stagger-2 {
      animation: cardReveal 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      animation-delay: 0.4s;
      opacity: 0;
    }

    .stagger-3 {
      animation: cardReveal 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      animation-delay: 0.6s;
      opacity: 0;
    }

    /* Typewriter effect */
    .typewriter {
      animation: typewriter 1s steps(50) forwards;
    }

    /* Reduced motion support */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* Mobile optimizations */
    @media (max-width: 768px) {
      @keyframes cardReveal {
        from {
          transform: translateY(10px);
          opacity: 0;
        }
        to {
          transform: translateY(0);
          opacity: 1;
        }
      }

      .stagger-1, .stagger-2, .stagger-3 {
        animation-duration: 0.4s;
      }
      
      /* Scale down score circle on mobile */
      #score-glow {
        width: 7.5rem !important;
        height: 7.5rem !important;
      }
      
      #results-phase .relative.w-40.h-40 {
        width: 7.5rem !important;
        height: 7.5rem !important;
      }
      
      #results-phase svg {
        width: 7.5rem !important;
        height: 7.5rem !important;
      }
      
      #results-phase svg circle {
        cx: 60;
        cy: 60;
        r: 54;
      }
      
      #score-value {
        font-size: 2rem !important;
      }
    }
  </style>
  <main class="min-h-screen">
    <section class="relative overflow-hidden">
      <!-- Background effect -->
      <div class="absolute inset-0 -z-10">
        <div class="absolute top-0 rounded-full left-1/4 w-96 h-96 bg-purple-600/10 blur-3xl"></div>
        <div class="absolute bottom-0 rounded-full right-1/4 w-96 h-96 bg-pink-600/10 blur-3xl"></div>
      </div>

      <div class="container max-w-6xl px-6 py-20 mx-auto">
        <!-- Header -->
        <div class="mb-10 text-center">
          <h1 class="mb-4 text-3xl font-bold md:text-4xl">
            <span class="text-transparent bg-gradient-to-r from-violet-400 via-cyan-400 to-blue-500 bg-clip-text">
              System Compatibility Checker
            </span>
          </h1>
          <p id="intro-description" class="max-w-2xl mx-auto mb-6 text-lg text-cyan-100/80">
            Check if your computer can run Davant Studio's AI tools.
          </p>
        </div>

        <!-- Main Content Area -->
        <div class="max-w-4xl mx-auto">
          <!-- Initial Choice Phase -->
          <div id="choice-phase" class="mb-12">
            <!-- Big GO Button Container -->
            <div class="mb-12 text-center">
              <div class="relative inline-block">
                <!-- Glow effect -->
                <div class="absolute inset-0 rounded-full opacity-50 bg-gradient-to-r from-purple-500 to-pink-500 blur-2xl animate-pulse"></div>
                
                <!-- Main GO button -->
                <button id="auto-detect-button" 
                  class="relative w-48 h-48 text-3xl font-bold text-white transition-all duration-300 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 hover:scale-105 hover:shadow-2xl hover:shadow-purple-500/30 group">
                  <span class="block transition-all duration-300 group-hover:scale-110">GO</span>
                  <span class="block mt-1 text-sm font-normal opacity-80">Start Scan</span>
                </button>
              </div>
              
              <p class="mt-8 text-lg text-cyan-100/60">
                Click to analyze your current system
              </p>
            </div>

            <!-- Manual input option - subtle button -->
            <div class="text-center">
              <button id="manual-input-button" 
                class="px-6 py-2.5 text-sm text-purple-300/80 border border-purple-800/30 rounded-full hover:border-purple-700/50 hover:bg-purple-900/20 hover:text-purple-200 transition-all duration-200">
                Check a different system manually
              </button>
            </div>
          </div>

          <!-- Detection Phase -->
          <div id="detection-phase" class="hidden mb-12">
            <div class="relative p-8 border rounded-2xl bg-gradient-to-br from-purple-900/20 to-transparent border-purple-800/30">
              <!-- Header with Legend -->
              <div class="flex items-start justify-between mb-6">
                <h2 class="flex items-center gap-3 text-2xl font-bold text-white">
                  <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  Detecting Your System
                </h2>
                
                <!-- Detection Legend - Top Right -->
                <div class="p-3 border rounded-lg bg-purple-900/20 border-purple-800/20">
                  <div class="flex items-center gap-4 text-xs">
                    <span class="text-purple-300 font-medium">Confidence:</span>
                    <div class="flex gap-3 text-cyan-100/70">
                      <span><span class="text-green-400">✓</span> High</span>
                      <span><span class="text-yellow-400">~</span> Medium</span>
                      <span>○ Low</span>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Progress indicator -->
              <div class="mb-6">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm text-cyan-100/70" id="detection-status">Analyzing hardware...</span>
                  <span class="text-xs text-purple-300">Scanning...</span>
                </div>
                <div class="relative h-3 overflow-hidden rounded-full bg-purple-900/30">
                  <div id="progress-bar" class="absolute inset-y-0 left-0 w-0 transition-all duration-500 rounded-full bg-gradient-to-r from-purple-500 to-pink-500"></div>
                  <div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 to-pink-500/20 animate-pulse"></div>
                  <!-- Scanning beam effect -->
                  <div class="absolute inset-y-0 w-20 progress-fill bg-gradient-to-r from-transparent via-white/30 to-transparent"></div>
                </div>
              </div>

              <!-- Detected Specs -->
              <div id="detected-specs" class="space-y-4">
                <div id="platform-row" class="p-4 transition-opacity duration-300 border rounded-lg bg-purple-900/10 border-purple-800/20 opacity-30">
                  <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm font-medium text-purple-300">
                      <span id="platform-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="platform-spinner" class="animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      Platform
                    </span>
                    <span id="detected-platform" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
                <div id="gpu-row" class="p-4 transition-opacity duration-300 border rounded-lg bg-purple-900/10 border-purple-800/20 opacity-30">
                  <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm font-medium text-purple-300">
                      <span id="gpu-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="gpu-spinner" class="hidden animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      GPU Info
                    </span>
                    <span id="detected-gpu" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
                <div id="cpu-row" class="p-4 transition-opacity duration-300 border rounded-lg bg-purple-900/10 border-purple-800/20 opacity-30">
                  <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm font-medium text-purple-300">
                      <span id="cpu-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="cpu-spinner" class="hidden animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      CPU Cores
                    </span>
                    <span id="detected-cpu" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
                <div id="display-row" class="p-4 transition-opacity duration-300 border rounded-lg bg-purple-900/10 border-purple-800/20 opacity-30">
                  <div class="flex items-center justify-between">
                    <span class="flex items-center gap-2 text-sm font-medium text-purple-300">
                      <span id="display-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="display-spinner" class="hidden animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      Display
                    </span>
                    <span id="detected-display" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- User Input Phase -->
          <div id="input-phase" class="hidden mb-12">
            <div class="relative p-8 border rounded-2xl bg-gradient-to-br from-purple-900/20 to-transparent border-purple-800/30">
              <h2 class="flex items-center gap-3 mb-6 text-2xl font-bold text-white">
                <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Enter System Information
              </h2>
              <p class="mb-4 text-cyan-100/70">
                Please provide your system specifications to check compatibility with Davant Studio.
              </p>
              
              <!-- Auto-scan option -->
              <div class="mb-6 text-center">
                <button type="button" id="switch-to-auto" 
                  class="text-sm underline transition-colors duration-200 text-purple-300/80 hover:text-purple-300 underline-offset-4">
                  Try auto-detection instead
                </button>
              </div>

              <form id="specs-form" class="space-y-6">
                <!-- Two column grid for compact layout -->
                <div class="grid gap-4 md:grid-cols-2">
                  <!-- Operating System -->
                  <div>
                    <label for="os-select" class="block mb-2 text-sm font-medium text-purple-300">
                      Operating System
                    </label>
                    <select id="os-select" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                      <option value="">Select OS...</option>
                      <option value="windows-11">Windows 11</option>
                      <option value="windows-10">Windows 10</option>
                      <option value="macos-sonoma">macOS Sonoma</option>
                      <option value="macos-ventura">macOS Ventura</option>
                      <option value="macos-monterey">macOS Monterey</option>
                      <option value="linux">Linux</option>
                    </select>
                  </div>

                  <!-- CPU Model -->
                  <div>
                    <label for="cpu-model" class="block mb-2 text-sm font-medium text-purple-300">
                      Processor (CPU)
                    </label>
                    <select id="cpu-model" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                      <option value="">Select OS first...</option>
                    </select>
                  </div>
                </div>

                <!-- GPU Brand and Model in two columns -->
                <div class="grid gap-4 md:grid-cols-2">
                  <!-- GPU Brand -->
                  <div>
                    <label for="gpu-brand" class="block mb-2 text-sm font-medium text-purple-300">
                      Graphics Card Brand
                    </label>
                    <select id="gpu-brand" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                      <option value="">Select brand...</option>
                      <option value="nvidia">NVIDIA</option>
                      <option value="amd">AMD Radeon</option>
                      <option value="intel">Intel</option>
                      <option value="apple">Apple (Integrated)</option>
                    </select>
                  </div>

                  <!-- GPU Model -->
                  <div>
                    <label for="gpu-model" class="block mb-2 text-sm font-medium text-purple-300">
                      Graphics Card Model
                    </label>
                    <select id="gpu-model" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20" disabled>
                      <option value="">Select brand first...</option>
                    </select>
                  </div>
                </div>

                <!-- System RAM -->
                <div>
                  <label for="system-ram" class="block mb-2 text-sm font-medium text-purple-300">
                    Memory (RAM)
                  </label>
                  <select id="system-ram" 
                    class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                    <option value="">Select RAM...</option>
                    <option value="8">8 GB</option>
                    <option value="16">16 GB</option>
                    <option value="24">24 GB</option>
                    <option value="32">32 GB</option>
                    <option value="48">48 GB</option>
                    <option value="64">64 GB</option>
                    <option value="128">128 GB</option>
                  </select>
                </div>

                <!-- Submit Button -->
                <button type="submit" 
                  class="w-full px-6 py-3 mt-2 font-semibold text-white transition-all duration-300 rounded-lg bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 hover:shadow-lg hover:shadow-purple-500/20">
                  Check Compatibility
                </button>
              </form>
            </div>
          </div>


          <!-- Results Phase -->
          <div id="results-phase" class="hidden">
            <!-- Compatibility Results -->
            <div class="flex flex-col items-center justify-center gap-6 mb-6 lg:flex-row">
              <!-- Score Circle -->
              <div class="relative flex-shrink-0">
                <!-- Glow effect -->
                <div id="score-glow" class="absolute inset-0 w-40 h-40 rounded-full bg-gradient-to-r from-purple-500 to-pink-500 blur-xl opacity-30 transition-all duration-2000"></div>
                
                <!-- Score Circle -->
                <div class="relative w-40 h-40">
                  <!-- Background circle -->
                  <svg class="w-full h-full transform -rotate-90">
                    <circle cx="80" cy="80" r="72" 
                      stroke="currentColor" 
                      stroke-width="10" 
                      fill="none" 
                      class="text-purple-900/30"></circle>
                    <!-- Progress circle -->
                    <circle id="score-circle" 
                      cx="80" cy="80" r="72" 
                      stroke="url(#gradient)" 
                      stroke-width="10" 
                      fill="none"
                      stroke-dasharray="452"
                      stroke-dashoffset="452"
                      class="transition-all duration-1000"></circle>
                    <defs>
                      <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#8b5cf6" />
                        <stop offset="100%" style="stop-color:#ec4899" />
                      </linearGradient>
                    </defs>
                  </svg>
                  
                  <!-- Score in center -->
                  <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span id="score-value" class="mb-1 text-4xl font-bold text-white">0</span>
                    <span class="text-xs tracking-wider text-purple-300 uppercase">Score</span>
                  </div>
                </div>
              </div>
              
              <!-- Status & Message -->
              <div class="flex-1 max-w-lg text-center lg:text-left">
                <!-- Status Icon & Answer -->
                <div class="flex items-center justify-center gap-3 mb-2 lg:justify-start">
                  <svg id="success-icon" class="flex-shrink-0 hidden w-8 h-8 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <svg id="warning-icon" class="flex-shrink-0 hidden w-8 h-8 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-1.732-.833-2.5 0L4.268 15.5c-.77.833.192 2.5 1.732 2.5z"></path>
                  </svg>
                  <svg id="error-icon" class="flex-shrink-0 hidden w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  
                  <h2 id="compatibility-answer" class="text-lg font-bold text-white md:text-xl">Checking your system...</h2>
                </div>
                
                <!-- Explanation -->
                <p id="compatibility-explanation" class="text-base leading-relaxed text-cyan-100/80"></p>
              </div>
            </div>

            <!-- Component Breakdown -->
            <div class="grid gap-4 mb-8 md:grid-cols-3">
              <!-- GPU Status -->
              <div class="relative p-3 border component-card stagger-1 bg-gradient-to-br from-purple-900/20 to-transparent border-purple-800/30 rounded-xl">
                <!-- Card glow effect -->
                <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-purple-500/10 to-pink-500/10 card-glow"></div>
                
                <div class="relative z-10 flex flex-col h-full">
                  <div class="flex-grow">
                    <div class="flex items-start justify-between">
                      <div class="flex items-center gap-1">
                        <div class="p-1 transition-all duration-300 rounded-lg bg-purple-500/20 group-hover:bg-purple-500/30">
                          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                          </svg>
                        </div>
                        <h3 class="text-base font-semibold text-white">GPU</h3>
                      </div>
