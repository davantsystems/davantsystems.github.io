---
import Layout from "../../layouts/Layout.astro";
import MainNavWithDropdowns from "../../components/MainNavWithDropdowns.astro";
import Footer from "../../components/Footer.astro";

const pageTitle = "System Compatibility Checker | Davant Studio";
---

<Layout title={pageTitle}>
  <MainNavWithDropdowns />
  <main class="min-h-screen">
    <section class="relative overflow-hidden">
      <!-- Background effect -->
      <div class="absolute inset-0 -z-10">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-purple-600/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-pink-600/10 rounded-full blur-3xl"></div>
      </div>

      <div class="container max-w-6xl mx-auto px-6 py-20">
        <!-- Header -->
        <div class="text-center mb-16">
          <h1 class="text-5xl md:text-6xl font-bold mb-6">
            <span class="text-transparent bg-gradient-to-r from-violet-400 via-cyan-400 to-blue-500 bg-clip-text">
              System Compatibility Checker
            </span>
          </h1>
          <p class="text-xl text-cyan-100/80 max-w-3xl mx-auto mb-8">
            Check if your system is ready for Davant Studio's AI-powered creative tools.
            Test your current device or enter specs for any system you're considering.
          </p>
        </div>

        <!-- Main Content Area -->
        <div class="max-w-4xl mx-auto">
          <!-- Initial Choice Phase -->
          <div id="choice-phase" class="mb-12">
            <!-- Big GO Button Container -->
            <div class="text-center mb-12">
              <div class="relative inline-block">
                <!-- Glow effect -->
                <div class="absolute inset-0 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full blur-2xl opacity-50 animate-pulse"></div>
                
                <!-- Main GO button -->
                <button id="auto-detect-button" 
                  class="relative w-48 h-48 rounded-full bg-gradient-to-br from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-bold text-3xl transition-all duration-300 hover:scale-105 hover:shadow-2xl hover:shadow-purple-500/30 group">
                  <span class="block transition-all duration-300 group-hover:scale-110">GO</span>
                  <span class="block text-sm font-normal mt-1 opacity-80">Start Scan</span>
                </button>
              </div>
              
              <p class="text-lg text-cyan-100/60 mt-8">
                Click to analyze your current system
              </p>
            </div>

            <!-- Manual input option - subtle button -->
            <div class="text-center">
              <button id="manual-input-button" 
                class="px-6 py-2.5 text-sm text-purple-300/80 border border-purple-800/30 rounded-full hover:border-purple-700/50 hover:bg-purple-900/20 hover:text-purple-200 transition-all duration-200">
                Check a different system manually
              </button>
            </div>
          </div>

          <!-- Detection Phase -->
          <div id="detection-phase" class="mb-12 hidden">
            <div class="relative border rounded-2xl bg-gradient-to-br from-purple-900/20 to-transparent border-purple-800/30 p-8">
              <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                Detecting Your System
              </h2>
              
              <!-- Progress indicator -->
              <div class="mb-8">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-sm text-cyan-100/70" id="detection-status">Analyzing hardware...</span>
                  <span class="text-xs text-purple-300">Scanning...</span>
                </div>
                <div class="relative h-3 bg-purple-900/30 rounded-full overflow-hidden">
                  <div id="progress-bar" class="absolute inset-y-0 left-0 w-0 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full transition-all duration-500"></div>
                  <div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 to-pink-500/20 animate-pulse"></div>
                </div>
              </div>

              <!-- Detected Specs -->
              <div id="detected-specs" class="space-y-4">
                <div id="platform-row" class="p-4 bg-purple-900/10 rounded-lg border border-purple-800/20 opacity-30 transition-opacity duration-300">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-purple-300 flex items-center gap-2">
                      <span id="platform-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="platform-spinner" class="animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      Platform
                    </span>
                    <span id="detected-platform" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
                <div id="gpu-row" class="p-4 bg-purple-900/10 rounded-lg border border-purple-800/20 opacity-30 transition-opacity duration-300">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-purple-300 flex items-center gap-2">
                      <span id="gpu-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="gpu-spinner" class="hidden animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      GPU Info
                    </span>
                    <span id="detected-gpu" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
                <div id="cpu-row" class="p-4 bg-purple-900/10 rounded-lg border border-purple-800/20 opacity-30 transition-opacity duration-300">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-purple-300 flex items-center gap-2">
                      <span id="cpu-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="cpu-spinner" class="hidden animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      CPU Cores
                    </span>
                    <span id="detected-cpu" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
                <div id="display-row" class="p-4 bg-purple-900/10 rounded-lg border border-purple-800/20 opacity-30 transition-opacity duration-300">
                  <div class="flex items-center justify-between">
                    <span class="text-sm font-medium text-purple-300 flex items-center gap-2">
                      <span id="display-check" class="hidden">
                        <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                      </span>
                      <span id="display-spinner" class="hidden animate-spin">
                        <svg class="w-4 h-4 text-purple-400" fill="none" viewBox="0 0 24 24">
                          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                      </span>
                      Display
                    </span>
                    <span id="detected-display" class="text-sm text-cyan-100/50">Waiting...</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- User Input Phase -->
          <div id="input-phase" class="mb-12 hidden">
            <div class="relative border rounded-2xl bg-gradient-to-br from-purple-900/20 to-transparent border-purple-800/30 p-8">
              <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
                <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Enter System Information
              </h2>
              <p class="text-cyan-100/70 mb-4">
                Please provide your system specifications to check compatibility with Davant Studio.
              </p>
              
              <!-- Auto-scan option -->
              <div class="mb-6 text-center">
                <button type="button" id="switch-to-auto" 
                  class="text-sm text-purple-300/80 hover:text-purple-300 underline underline-offset-4 transition-colors duration-200">
                  Try auto-detection instead
                </button>
              </div>

              <form id="specs-form" class="space-y-6">
                <!-- Two column grid for compact layout -->
                <div class="grid md:grid-cols-2 gap-4">
                  <!-- Operating System -->
                  <div>
                    <label for="os-select" class="block text-sm font-medium text-purple-300 mb-2">
                      Operating System
                    </label>
                    <select id="os-select" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                      <option value="">Select OS...</option>
                      <option value="windows-11">Windows 11</option>
                      <option value="windows-10">Windows 10</option>
                      <option value="macos-sonoma">macOS Sonoma</option>
                      <option value="macos-ventura">macOS Ventura</option>
                      <option value="macos-monterey">macOS Monterey</option>
                      <option value="linux">Linux</option>
                    </select>
                  </div>

                  <!-- CPU Model -->
                  <div>
                    <label for="cpu-model" class="block text-sm font-medium text-purple-300 mb-2">
                      Processor (CPU)
                    </label>
                    <select id="cpu-model" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                      <option value="">Select OS first...</option>
                    </select>
                  </div>
                </div>

                <!-- GPU Brand and Model in two columns -->
                <div class="grid md:grid-cols-2 gap-4">
                  <!-- GPU Brand -->
                  <div>
                    <label for="gpu-brand" class="block text-sm font-medium text-purple-300 mb-2">
                      Graphics Card Brand
                    </label>
                    <select id="gpu-brand" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                      <option value="">Select brand...</option>
                      <option value="nvidia">NVIDIA</option>
                      <option value="amd">AMD Radeon</option>
                      <option value="intel">Intel</option>
                      <option value="apple">Apple (Integrated)</option>
                    </select>
                  </div>

                  <!-- GPU Model -->
                  <div>
                    <label for="gpu-model" class="block text-sm font-medium text-purple-300 mb-2">
                      Graphics Card Model
                    </label>
                    <select id="gpu-model" 
                      class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20" disabled>
                      <option value="">Select brand first...</option>
                    </select>
                  </div>
                </div>

                <!-- System RAM -->
                <div>
                  <label for="system-ram" class="block text-sm font-medium text-purple-300 mb-2">
                    Memory (RAM)
                  </label>
                  <select id="system-ram" 
                    class="w-full px-3 py-2.5 pr-10 bg-purple-900/20 border border-purple-800/30 rounded-lg text-white text-sm focus:border-purple-600/50 focus:ring-2 focus:ring-purple-600/20">
                    <option value="">Select RAM...</option>
                    <option value="8">8 GB</option>
                    <option value="16">16 GB</option>
                    <option value="24">24 GB</option>
                    <option value="32">32 GB</option>
                    <option value="48">48 GB</option>
                    <option value="64">64 GB</option>
                    <option value="128">128 GB</option>
                  </select>
                </div>

                <!-- Submit Button -->
                <button type="submit" 
                  class="w-full px-6 py-3 bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-semibold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/20 mt-2">
                  Check Compatibility
                </button>
              </form>
            </div>
          </div>


          <!-- Results Phase -->
          <div id="results-phase" class="hidden">
            <!-- Auto-detection notice -->
            <div id="auto-detect-notice" class="mb-8 p-4 bg-green-500/10 border border-green-500/30 rounded-lg hidden">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-sm text-green-300">
                  <span class="font-medium">Auto-detection successful!</span> 
                  <span id="detected-info" class="text-cyan-100/70"></span>
                </p>
              </div>
            </div>
            
            <!-- Compatibility Score -->
            <div class="text-center mb-12">
              <div class="relative inline-block">
                <!-- Glow effect for score -->
                <div class="absolute inset-0 w-48 h-48 bg-gradient-to-r from-purple-500 to-pink-500 rounded-full blur-xl opacity-30"></div>
                <div class="w-48 h-48 relative">
                  <!-- Background circle -->
                  <svg class="w-full h-full transform -rotate-90">
                    <circle cx="96" cy="96" r="88" 
                      stroke="currentColor" 
                      stroke-width="12" 
                      fill="none" 
                      class="text-purple-900/30"></circle>
                    <!-- Progress circle -->
                    <circle id="score-circle" 
                      cx="96" cy="96" r="88" 
                      stroke="url(#gradient)" 
                      stroke-width="12" 
                      fill="none"
                      stroke-dasharray="553"
                      stroke-dashoffset="553"
                      class="transition-all duration-1000"></circle>
                    <defs>
                      <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#8b5cf6" />
                        <stop offset="100%" style="stop-color:#ec4899" />
                      </linearGradient>
                    </defs>
                  </svg>
                  <!-- Score text -->
                  <div class="absolute inset-0 flex flex-col items-center justify-center">
                    <span id="score-value" class="text-6xl font-bold text-white">0</span>
                    <span class="text-sm text-purple-300 uppercase tracking-wider">Score</span>
                  </div>
                </div>
              </div>
              <h2 id="compatibility-tier" class="text-3xl font-bold mt-6 text-white">Checking...</h2>
              <p id="compatibility-message" class="text-lg text-cyan-100/70 mt-2"></p>
            </div>

            <!-- Operating System Info -->
            <div class="mb-8 p-4 bg-purple-900/20 border border-purple-800/30 rounded-lg">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <p class="text-sm">
                  <span class="font-medium text-purple-300">Operating System:</span> 
                  <span id="os-display" class="text-cyan-100"></span>
                </p>
              </div>
            </div>

            <!-- Component Breakdown -->
            <div class="grid gap-6 md:grid-cols-3 mb-12">
              <!-- GPU Status -->
              <div class="p-6 bg-gradient-to-br from-purple-900/20 to-transparent border border-purple-800/30 rounded-xl">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="p-2 bg-purple-500/20 rounded-lg">
                      <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                      </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Graphics Card</h3>
                  </div>
                  <span id="gpu-status" class="text-xs px-2 py-1 rounded"></span>
                </div>
                <p id="gpu-details" class="text-sm text-cyan-100/70"></p>
              </div>

              <!-- RAM Status -->
              <div class="p-6 bg-gradient-to-br from-purple-900/20 to-transparent border border-purple-800/30 rounded-xl">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="p-2 bg-purple-500/20 rounded-lg">
                      <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                      </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Memory (RAM)</h3>
                  </div>
                  <span id="ram-status" class="text-xs px-2 py-1 rounded"></span>
                </div>
                <p id="ram-details" class="text-sm text-cyan-100/70"></p>
              </div>

              <!-- CPU Status -->
              <div class="p-6 bg-gradient-to-br from-purple-900/20 to-transparent border border-purple-800/30 rounded-xl">
                <div class="flex items-start justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="p-2 bg-purple-500/20 rounded-lg">
                      <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"></path>
                      </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-white">Processor</h3>
                  </div>
                  <span id="cpu-status" class="text-xs px-2 py-1 rounded"></span>
                </div>
                <p id="cpu-details" class="text-sm text-cyan-100/70"></p>
              </div>
            </div>

            <!-- Recommendations -->
            <div id="recommendations" class="hidden">
              <div class="p-6 bg-gradient-to-br from-amber-900/20 to-transparent border border-amber-800/30 rounded-xl">
                <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
                  <svg class="w-6 h-6 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  Recommendations
                </h3>
                <ul id="recommendation-list" class="space-y-2 text-sm text-cyan-100/70">
                </ul>
              </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4 mt-8">
              <button id="recheck-button" 
                class="flex-1 px-6 py-3 border border-purple-800/50 text-purple-300 rounded-lg hover:bg-purple-800/20 transition-all duration-300 flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                Check Another System
              </button>
              <a href="/davant-studio/#signup" 
                class="flex-1 px-6 py-3 bg-gradient-to-r from-purple-500 to-pink-500 hover:from-purple-600 hover:to-pink-600 text-white font-semibold rounded-lg text-center transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/20">
                Get Davant Studio
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline>
  // GPU Database
  // CPU options by OS
  const CPU_OPTIONS_BY_OS = {
    windows: [
      { group: 'Intel Core (13th Gen)', options: [
        { value: 'i9-13th', text: 'Core i9-13900K' },
        { value: 'i7-13th', text: 'Core i7-13700K' },
        { value: 'i5-13th', text: 'Core i5-13600K' }
      ]},
      { group: 'Intel Core (12th Gen)', options: [
        { value: 'i9-12th', text: 'Core i9-12900K' },
        { value: 'i7-12th', text: 'Core i7-12700K' },
        { value: 'i5-12th', text: 'Core i5-12600K' }
      ]},
      { group: 'AMD Ryzen 7000', options: [
        { value: 'ryzen-9-7000', text: 'Ryzen 9 7950X' },
        { value: 'ryzen-7-7000', text: 'Ryzen 7 7700X' },
        { value: 'ryzen-5-7000', text: 'Ryzen 5 7600X' }
      ]},
      { group: 'AMD Ryzen 5000', options: [
