  // Hardware detection functions
  function detectPlatform() {
    const userAgent = navigator.userAgent.toLowerCase();
    const platform = navigator.platform.toLowerCase();

    if (platform.includes('win') || userAgent.includes('windows')) {
      return 'windows';
    } else if (platform.includes('mac') || userAgent.includes('macintosh')) {
      return 'mac';
    } else if (platform.includes('linux') || userAgent.includes('linux')) {
      return 'linux';
    }
    return 'unknown';
  }
  
  function detectOSVersion() {
    const userAgent = navigator.userAgent;
    let os = 'Unknown OS';
    let version = '';
    let versionNumber = '';
    
    // Windows detection
    if (userAgent.includes('Windows')) {
      os = 'Windows';
      if (userAgent.includes('Windows NT 10.0')) {
        // Could be Windows 10 or 11
        // Windows 11 has specific build numbers, but hard to detect reliably from UA
        version = '10/11';
      } else if (userAgent.includes('Windows NT 6.3')) {
        version = '8.1';
      } else if (userAgent.includes('Windows NT 6.2')) {
        version = '8';
      } else if (userAgent.includes('Windows NT 6.1')) {
        version = '7';
      }
    }
    // macOS detection
    else if (userAgent.includes('Mac OS X')) {
      os = 'macOS';
      const match = userAgent.match(/Mac OS X ([\d_]+)/);
      if (match) {
        const versionParts = match[1].split('_');
        const major = parseInt(versionParts[0]);
        const minor = parseInt(versionParts[1]) || 0;
        const patch = parseInt(versionParts[2]) || 0;
        
        // Format version number
        if (major >= 11) {
          versionNumber = patch > 0 ? `${major}.${minor}.${patch}` : `${major}.${minor}`;
        } else {
          versionNumber = `10.${minor}${patch > 0 ? '.' + patch : ''}`;
        }
        
        // Convert to macOS version names with numbers
        if (major >= 14) {
          version = `Sonoma ${versionNumber}`;
        } else if (major === 13) {
          version = `Ventura ${versionNumber}`;
        } else if (major === 12) {
          version = `Monterey ${versionNumber}`;
        } else if (major === 11) {
          version = `Big Sur ${versionNumber}`;
        } else if (major === 10) {
          if (minor >= 15) version = `Catalina ${versionNumber}`;
          else if (minor === 14) version = `Mojave ${versionNumber}`;
          else if (minor === 13) version = `High Sierra ${versionNumber}`;
          else version = versionNumber;
        }
      }
    }
    // Linux detection
    else if (userAgent.includes('Linux')) {
      os = 'Linux';
      if (userAgent.includes('Ubuntu')) {
        const ubuntuMatch = userAgent.match(/Ubuntu[\/\s]?([\d\.]+)?/);
        version = ubuntuMatch && ubuntuMatch[1] ? `Ubuntu ${ubuntuMatch[1]}` : 'Ubuntu';
      } else if (userAgent.includes('Fedora')) {
        const fedoraMatch = userAgent.match(/Fedora[\/\s]?([\d\.]+)?/);
        version = fedoraMatch && fedoraMatch[1] ? `Fedora ${fedoraMatch[1]}` : 'Fedora';
      } else if (userAgent.includes('Debian')) {
        const debianMatch = userAgent.match(/Debian[\/\s]?([\d\.]+)?/);
        version = debianMatch && debianMatch[1] ? `Debian ${debianMatch[1]}` : 'Debian';
      }
    }
    
    return version ? `${os} ${version}` : os;
  }

  function detectGPU() {
    let canvas = document.createElement('canvas');
    let gl = canvas.getContext('webgl2') || canvas.getContext('webgl');
    
    if (!gl) {
      return { renderer: 'Unknown', version: 0 };
    }

    let renderer = 'Unknown GPU';
    let version = gl instanceof WebGL2RenderingContext ? 2 : 1;

    try {
      const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
      if (debugInfo) {
        renderer = gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) || 'Unknown GPU';
        // Clean up renderer string
        renderer = renderer.replace(/ANGLE \(/, '').replace(/\)$/, '');
      }
    } catch (e) {
      console.error('GPU detection error:', e);
    }

    // Enhanced Apple Silicon detection
    if (renderer === 'Apple GPU' || renderer.toLowerCase().includes('apple gpu')) {
      const appleModel = detectAppleSiliconModel(gl);
      if (appleModel) {
        renderer = `Apple ${appleModel}`;
      }
    }

    return { renderer, version };
  }

  function detectAppleSiliconModel(gl) {
    const platform = navigator.platform;
    const cores = navigator.hardwareConcurrency || 0;
    
    if (!platform.includes('Mac')) {
      return null;
    }

    // Try Chrome's detailed renderer string first
    if (gl) {
      try {
        const debugInfo = gl.getExtension('WEBGL_debug_renderer_info');
        if (debugInfo) {
          const renderer = gl.getParameter(debugInfo.UNMASKED_RENDERER_WEBGL) || '';
          const appleMatch = renderer.match(/Apple\s*(M\d+(?:\s*(?:Pro|Max|Ultra))?)/i);
          if (appleMatch) {
            return appleMatch[1];
          }
        }
      } catch (e) {}
    }

    // Fallback based on core count
    const year = new Date().getFullYear();
    const isRecent = year >= 2023;

    if (cores >= 20) {
      return isRecent ? 'M3 Max' : 'M2 Ultra';
    } else if (cores >= 16) {
      return isRecent ? 'M3 Pro' : 'M2 Max';
    } else if (cores >= 12) {
      return 'M2 Pro';
    } else if (cores >= 10) {
      return 'M2';
    } else if (cores >= 8) {
      return 'M2';
    }

    return 'Apple Silicon';
  }

  function detectScreen() {
    return {
      width: window.screen.width * (window.devicePixelRatio || 1),
      height: window.screen.height * (window.devicePixelRatio || 1),
    };
  }

  function detectCPU() {
    const cores = navigator.hardwareConcurrency || 4;
    let model = 'Unknown CPU';
    
    // Try to infer CPU model based on platform and core count
    const platform = detectPlatform();
    const gpuInfo = detectGPU();
    
    if (platform === 'mac' && gpuInfo.renderer.toLowerCase().includes('apple')) {
      // Apple Silicon detection based on GPU renderer and cores
      const appleModel = detectAppleSiliconModel(null);
      if (appleModel && appleModel !== 'Apple Silicon') {
        model = `Apple ${appleModel}`;
      } else {
        model = 'Apple Silicon';
      }
    } else if (platform === 'windows' || platform === 'linux') {
      // For Windows/Linux, we can make educated guesses based on core count
      if (cores >= 24) {
        model = 'High-end CPU (24+ cores)';
      } else if (cores >= 16) {
        model = 'Performance CPU (16 cores)';
      } else if (cores >= 12) {
        model = 'Mid-range CPU (12 cores)';
      } else if (cores >= 8) {
        model = 'Standard CPU (8 cores)';
      } else if (cores >= 6) {
        model = 'Entry CPU (6 cores)';
      } else {
        model = 'Basic CPU (4 cores)';
      }
    }
    
    return { cores, model };
  }

  // Scoring functions
  function calculateGPUScore(specs) {
    if (specs.userProvided.gpuModel) {
      const gpuInfo = GPU_DATABASE[specs.userProvided.gpuModel];
      if (gpuInfo) {
        return (gpuInfo.minScore + gpuInfo.maxScore) / 2;
      }
    }

    // Check detected GPU renderer
    const renderer = specs.detected.gpuRenderer.toLowerCase();
    
    // Try to match against known Apple Silicon models
    if (renderer.includes('apple')) {
      // Extract model from renderer string like "Apple M2"
      const modelMatch = renderer.match(/apple\s*(m\d+(?:\s*(?:pro|max|ultra))?)/i);
      if (modelMatch) {
        const modelKey = modelMatch[1].toLowerCase().replace(/\s+/g, '-');
        const gpuInfo = GPU_DATABASE[modelKey];
        if (gpuInfo) {
          return (gpuInfo.minScore + gpuInfo.maxScore) / 2;
        }
      }
      
      // Generic Apple Silicon score
      if (renderer.includes('apple silicon')) {
        return 60; // Base M1 level performance
      }
    }

    // Check for integrated graphics
    if (renderer.includes('intel') && !renderer.includes('arc')) {
      return 10;
    }

    return 25;
  }

  function calculateRAMScore(specs) {
    const ram = specs.userProvided.systemRAM || 0;
    if (ram === 0) return 0;
    
    const { minimum, recommended, optimal } = REQUIREMENTS.ram;
    
    if (ram >= optimal) return 100;
    if (ram >= recommended) return 80 + ((ram - recommended) / (optimal - recommended)) * 20;
    if (ram >= minimum) return 50 + ((ram - minimum) / (recommended - minimum)) * 30;
    
    return Math.max(0, (ram / minimum) * 50);
  }

  function calculateCPUScore(specs) {
    const cores = specs.detected.cpuCores;
    const { minimum, recommended, optimal } = REQUIREMENTS.cpu;
    
    if (cores >= optimal) return 100;
    if (cores >= recommended) return 80 + ((cores - recommended) / (optimal - recommended)) * 20;
    if (cores >= minimum) return 50 + ((cores - minimum) / (recommended - minimum)) * 30;
    
    return Math.max(0, (cores / minimum) * 50);
  }


  function calculateCompatibility(specs) {
    const scores = {
      gpu: calculateGPUScore(specs),
      ram: calculateRAMScore(specs),
      cpu: calculateCPUScore(specs)
    };

    const overallScore = Math.round(
      scores.gpu * COMPONENT_WEIGHTS.gpu +
      scores.ram * COMPONENT_WEIGHTS.ram +
      scores.cpu * COMPONENT_WEIGHTS.cpu
    );

    const minScore = Math.min(scores.gpu, scores.ram);
    let tier = 'recommended';
    
    if (minScore < 30 || overallScore < 40) {
      tier = 'incompatible';
    } else if (minScore < 50 || overallScore < 60) {
      tier = 'minimum';
    } else if (overallScore >= 80 && minScore >= 70) {
      tier = 'optimal';
    }

    const recommendations = generateRecommendations(scores, specs);

    return { score: overallScore, tier, scores, recommendations };
  }

  function generateRecommendations(scores, specs) {
    const recommendations = [];
    
    if (scores.gpu < 50) {
      recommendations.push('Upgrade to at least an NVIDIA RTX 3060 or Apple M1 for basic functionality');
    } else if (scores.gpu < 80) {
      recommendations.push('Consider upgrading to an RTX 4070 or M2 Pro for optimal performance');
    }
    
    const currentRAM = specs.userProvided.systemRAM || 0;
    if (currentRAM > 0 && currentRAM < REQUIREMENTS.ram.minimum) {
      recommendations.push(`Upgrade RAM from ${currentRAM}GB to at least ${REQUIREMENTS.ram.minimum}GB`);
    } else if (currentRAM < REQUIREMENTS.ram.recommended) {
      recommendations.push(`Consider upgrading to ${REQUIREMENTS.ram.recommended}GB RAM for better multitasking`);
    }
    
    // Storage recommendation (always show)
    recommendations.push('Note: We recommend at least 40GB of free storage for Stable Diffusion models');
    
    if (recommendations.length === 0) {
      recommendations.push('Your system exceeds recommended specifications!');
      recommendations.push('Enable GPU acceleration in Davant Studio for maximum performance');
    }
    
    return recommendations;
  }

  // UI update functions
  function updateDetectionStatus(message) {
    document.getElementById('detection-status').textContent = message;
  }

  function animateScore(targetScore) {
    const scoreElement = document.getElementById('score-value');
    const circle = document.getElementById('score-circle');
    const circumference = 2 * Math.PI * 88;
    
    let currentScore = 0;
    const increment = targetScore / 50;
    
    const interval = setInterval(() => {
      currentScore += increment;
      if (currentScore >= targetScore) {
        currentScore = targetScore;
        clearInterval(interval);
      }
      
      scoreElement.textContent = Math.round(currentScore).toString();
      const offset = circumference - (currentScore / 100) * circumference;
      circle.style.strokeDashoffset = offset.toString();
    }, 20);
  }

  function updateTierDisplay(tier) {
    const tierElement = document.getElementById('compatibility-tier');
    const messageElement = document.getElementById('compatibility-message');
    
    const tierMessages = {
      optimal: {
        title: 'Optimal Performance',
        message: 'Your system will deliver exceptional AI generation performance!',
        class: 'text-emerald-400'
      },
      recommended: {
        title: 'Recommended Specs',
        message: 'Your system meets recommended requirements for smooth operation.',
        class: 'text-cyan-400'
      },
      minimum: {
        title: 'Minimum Requirements',
        message: 'Your system meets minimum requirements. Some features may be limited.',
        class: 'text-amber-400'
      },
      incompatible: {
        title: 'Below Minimum',
        message: 'Your system needs upgrades to run Davant Studio effectively.',
        class: 'text-red-400'
      }
    };
    
    const config = tierMessages[tier];
    tierElement.textContent = config.title;
    tierElement.className = `text-3xl font-bold mt-6 ${config.class}`;
    messageElement.textContent = config.message;
  }

  function updateComponentStatus(component, score, specs) {
    const statusElement = document.getElementById(`${component}-status`);
    const detailsElement = document.getElementById(`${component}-details`);
    
    let status = 'Optimal';
    let statusClass = 'bg-emerald-500/20 text-emerald-300';
    
    if (score < 50) {
      status = 'Below Minimum';
      statusClass = 'bg-red-500/20 text-red-300';
    } else if (score < 70) {
      status = 'Minimum';
      statusClass = 'bg-amber-500/20 text-amber-300';
    } else if (score < 85) {
      status = 'Recommended';
      statusClass = 'bg-cyan-500/20 text-cyan-300';
    }
    
    statusElement.textContent = status;
    statusElement.className = `text-xs px-2 py-1 rounded ${statusClass}`;
    
    switch (component) {
      case 'gpu':
        const gpuModel = specs.userProvided.gpuModel ? 
          GPU_DATABASE[specs.userProvided.gpuModel]?.model || 'Unknown GPU' :
          specs.detected.gpuRenderer || 'Unknown GPU';
        detailsElement.textContent = `${gpuModel} - Score: ${Math.round(score)}/100`;
        break;
      case 'ram':
        const ram = specs.userProvided.systemRAM || 0;
        detailsElement.textContent = `${ram}GB - Score: ${Math.round(score)}/100`;
        break;
      case 'cpu':
        const cpuDisplay = specs.detected.cpuModel ? 
          `${specs.detected.cpuModel} (${specs.detected.cpuCores} cores)` : 
          `${specs.detected.cpuCores} cores`;
        detailsElement.textContent = `${cpuDisplay} - Score: ${Math.round(score)}/100`;
        break;
    }
  }

  // Function to update progress bar
  function updateProgressBar(percent) {
    const progressBar = document.getElementById('progress-bar');
    progressBar.style.width = percent + '%';
  }

  // Function to show results
  function showResults() {
    // Calculate compatibility
    const result = calculateCompatibility(systemSpecs);
    
    // Show results
    document.getElementById('results-phase').classList.remove('hidden');
    
    // Display OS version
    const osDisplay = document.getElementById('os-display');
    if (osDisplay) {
      osDisplay.textContent = systemSpecs.detected.osVersion || 'Unknown OS';
    }
    
    // Animate score
    animateScore(result.score);
    updateTierDisplay(result.tier);
    
    // Update components
    updateComponentStatus('gpu', result.scores.gpu, systemSpecs);
    updateComponentStatus('ram', result.scores.ram, systemSpecs);
    updateComponentStatus('cpu', result.scores.cpu, systemSpecs);
    
    // Show recommendations
    if (result.recommendations.length > 0) {
      document.getElementById('recommendations').classList.remove('hidden');
      const list = document.getElementById('recommendation-list');
      list.innerHTML = result.recommendations
        .map(rec => `<li class="flex items-start">
          <svg class="w-4 h-4 text-amber-400 mt-0.5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <span>${rec}</span>
        </li>`)
        .join('');
    }
  }

  // Helper function to show component detection
  function showComponentDetection(componentId, value) {
    const row = document.getElementById(`${componentId}-row`);
    const spinner = document.getElementById(`${componentId}-spinner`);
    const check = document.getElementById(`${componentId}-check`);
    const valueSpan = document.getElementById(`detected-${componentId}`);
    
    // Activate row
    row.classList.remove('opacity-30');
    row.classList.add('opacity-100');
    
    // Show spinner if not already shown
    if (spinner && spinner.classList.contains('hidden')) {
      spinner.classList.remove('hidden');
    }
    
    // Update value
    valueSpan.textContent = 'Detecting...';
    valueSpan.classList.remove('text-cyan-100/50');
    valueSpan.classList.add('text-cyan-100/70');
    
    // After a short delay, show the result
    setTimeout(() => {
      valueSpan.textContent = value;
      valueSpan.classList.remove('text-cyan-100/70');
      valueSpan.classList.add('text-cyan-100');
      
      // Hide spinner and show check
      if (spinner) spinner.classList.add('hidden');
      if (check) check.classList.remove('hidden');
    }, 400);
  }

  // Function to start auto-detection
  function startAutoDetection() {
    // Hide choice phase and show detection phase
    document.getElementById('choice-phase').classList.add('hidden');
    document.getElementById('detection-phase').classList.remove('hidden');
    
    // Reset all rows to initial state
    ['platform', 'gpu', 'cpu', 'display'].forEach(comp => {
      const row = document.getElementById(`${comp}-row`);
      const check = document.getElementById(`${comp}-check`);
      const spinner = document.getElementById(`${comp}-spinner`);
      const value = document.getElementById(`detected-${comp}`);
      
      row.classList.add('opacity-30');
      row.classList.remove('opacity-100');
      check.classList.add('hidden');
      if (comp !== 'platform') spinner.classList.add('hidden');
      value.textContent = 'Waiting...';
      value.classList.add('text-cyan-100/50');
      value.classList.remove('text-cyan-100');
    });
    
    // Start detection with progress animation
    updateDetectionStatus('Initializing hardware detection...');
    updateProgressBar(10);
    
    // Detect platform first
    setTimeout(() => {
      updateProgressBar(25);
      updateDetectionStatus('Detecting operating system...');
      systemSpecs.detected.platform = detectPlatform();
      systemSpecs.detected.osVersion = detectOSVersion();
      showComponentDetection('platform', systemSpecs.detected.osVersion);
    }, 500);
    
    // Then GPU
    setTimeout(() => {
      updateProgressBar(50);
      updateDetectionStatus('Analyzing graphics processor...');
      document.getElementById('gpu-spinner').classList.remove('hidden');
      
      const gpuInfo = detectGPU();
      systemSpecs.detected.gpuRenderer = gpuInfo.renderer;
      systemSpecs.detected.webglVersion = gpuInfo.version;
      showComponentDetection('gpu', systemSpecs.detected.gpuRenderer || 'Unknown');
    }, 1200);
    
    // Then CPU
    setTimeout(() => {
      updateProgressBar(70);
      updateDetectionStatus('Checking processor cores...');
      document.getElementById('cpu-spinner').classList.remove('hidden');
      
      const cpuInfo = detectCPU();
      systemSpecs.detected.cpuCores = cpuInfo.cores;
      systemSpecs.detected.cpuModel = cpuInfo.model;
      showComponentDetection('cpu', cpuInfo.model);
    }, 2000);
    
    // Finally display
    setTimeout(() => {
      updateProgressBar(90);
      updateDetectionStatus('Reading display information...');
      document.getElementById('display-spinner').classList.remove('hidden');
      
      systemSpecs.detected.screenResolution = detectScreen();
      showComponentDetection('display', 
        `${systemSpecs.detected.screenResolution.width} × ${systemSpecs.detected.screenResolution.height}`);
    }, 2800);
    
    // Complete detection
    setTimeout(() => {
      updateProgressBar(100);
      updateDetectionStatus('Detection complete!');
      
      // Small delay before processing results
      setTimeout(() => {
      
      // Check if we detected enough information to skip manual input
      const hasGPUInfo = systemSpecs.detected.gpuRenderer && 
                        systemSpecs.detected.gpuRenderer !== 'Unknown' &&
                        systemSpecs.detected.gpuRenderer !== 'Unknown GPU';
      
      const isAppleSilicon = systemSpecs.detected.gpuRenderer.toLowerCase().includes('apple');
      
      if (hasGPUInfo && isAppleSilicon) {
        // For Apple Silicon, we can estimate RAM based on the model
        const renderer = systemSpecs.detected.gpuRenderer.toLowerCase();
        let estimatedRAM = 16; // Default
        
        if (renderer.includes('max') || renderer.includes('ultra')) {
          estimatedRAM = 32; // M1/M2/M3 Max typically have 32GB+
        } else if (renderer.includes('pro')) {
          estimatedRAM = 16; // M1/M2/M3 Pro typically have 16GB+
        } else {
          estimatedRAM = 8; // Base models typically have 8GB+
        }
        
        // Set defaults for Apple Silicon
        systemSpecs.userProvided.systemRAM = estimatedRAM;
        
        // Map detected GPU to our database
        const modelMatch = renderer.match(/apple\s*(m\d+(?:\s*(?:pro|max|ultra))?)/i);
        if (modelMatch) {
          const modelKey = modelMatch[1].toLowerCase().replace(/\s+/g, '-');
          if (GPU_DATABASE[modelKey]) {
            systemSpecs.userProvided.gpuModel = modelKey;
          }
        }
        
        // Skip to results
        setTimeout(() => {
          document.getElementById('detection-phase').classList.add('hidden');
          
          // Show auto-detection notice
          const notice = document.getElementById('auto-detect-notice');
          const info = document.getElementById('detected-info');
          notice.classList.remove('hidden');
          info.textContent = `We detected your ${systemSpecs.detected.gpuRenderer} with ${systemSpecs.userProvided.systemRAM}GB RAM (estimated).`;
          
          showResults();
        }, 1500);
      } else {
        // Show input phase for manual entry
        setTimeout(() => {
          document.getElementById('detection-phase').classList.add('hidden');
          document.getElementById('input-phase').classList.remove('hidden');
        }, 1500);
      }
      }, 500);
    }, 3600);
  }
  
  // Main execution
  document.addEventListener('DOMContentLoaded', async () => {
    // Handle auto-detect button
    document.getElementById('auto-detect-button').addEventListener('click', () => {
      startAutoDetection();
    });
    
    // Handle manual input button
    document.getElementById('manual-input-button').addEventListener('click', () => {
      // Hide choice phase and show input phase directly
      document.getElementById('choice-phase').classList.add('hidden');
      document.getElementById('input-phase').classList.remove('hidden');
    });
    
    // Handle OS selection and CPU options
    const osSelect = document.getElementById('os-select');
    const cpuModelSelect = document.getElementById('cpu-model');
    const gpuBrandSelect = document.getElementById('gpu-brand');
    const gpuModelSelect = document.getElementById('gpu-model');
    
    if (osSelect && cpuModelSelect) {
      osSelect.addEventListener('change', (e) => {
        const osValue = e.target.value;
        
        // Clear CPU options
        cpuModelSelect.innerHTML = '<option value="">Select CPU...</option>';
        
        if (!osValue) {
          return;
        }
        
        // Determine OS type
        let osType = 'windows';
        if (osValue.includes('macos')) {
          osType = 'mac';
        } else if (osValue === 'linux') {
          osType = 'linux';
        }
        
        // Populate CPU options based on OS
        const cpuOptions = CPU_OPTIONS_BY_OS[osType];
        if (cpuOptions) {
          cpuOptions.forEach(group => {
            const optgroup = document.createElement('optgroup');
            optgroup.label = group.group;
            
            group.options.forEach(option => {
              const opt = document.createElement('option');
              opt.value = option.value;
              opt.textContent = option.text;
              optgroup.appendChild(opt);
            });
            
            cpuModelSelect.appendChild(optgroup);
          });
        }
        
        // Add "Other" option
        const otherOption = document.createElement('option');
        otherOption.value = 'other';
        otherOption.textContent = 'Other/Older CPU';
        cpuModelSelect.appendChild(otherOption);
        
        // Handle macOS GPU auto-selection
        if (osType === 'mac') {
          // Check if an Apple Silicon CPU will be selected
          cpuModelSelect.addEventListener('change', function handleCPUChange(e) {
            const cpuValue = e.target.value;
            if (cpuValue && cpuValue.startsWith('m')) {
              // It's Apple Silicon - auto-select Apple GPU
              gpuBrandSelect.value = 'apple';
              gpuBrandSelect.dispatchEvent(new Event('change'));
              
              // After GPU models load, select the matching GPU
              setTimeout(() => {
                if (gpuModelSelect) {
                  gpuModelSelect.value = cpuValue; // CPU and GPU values match for Apple Silicon
                }
              }, 100);
            }
            
            // Remove this listener after first use
            cpuModelSelect.removeEventListener('change', handleCPUChange);
          });
        }
      });
    }
    
    // Handle GPU brand selection
    if (gpuBrandSelect && gpuModelSelect) {
      gpuBrandSelect.addEventListener('change', (e) => {
        const brand = e.target.value;
        
        // Clear current options
        gpuModelSelect.innerHTML = '';
        
        if (!brand) {
          gpuModelSelect.innerHTML = '<option value="">Select brand first...</option>';
          gpuModelSelect.disabled = true;
          return;
        }
        
        // Enable the model select
        gpuModelSelect.disabled = false;
        
        // Add default option
        gpuModelSelect.innerHTML = '<option value="">Select model...</option>';
        
        // Add models for selected brand
        const brandModels = GPU_MODELS_BY_BRAND[brand];
        if (brandModels) {
          Object.entries(brandModels).forEach(([series, models]) => {
            const optgroup = document.createElement('optgroup');
            optgroup.label = series;
            
            models.forEach(model => {
              const option = document.createElement('option');
              option.value = model.value;
              option.textContent = model.text;
              optgroup.appendChild(option);
            });
            
            gpuModelSelect.appendChild(optgroup);
          });
        }
        
        // Add "Other" option
        const otherOption = document.createElement('option');
        otherOption.value = 'other';
        otherOption.textContent = 'Other/Not Listed';
        gpuModelSelect.appendChild(otherOption);
      });
    }
    
    // Handle switch to auto-detection
    const switchToAutoBtn = document.getElementById('switch-to-auto');
    if (switchToAutoBtn) {
      switchToAutoBtn.addEventListener('click', () => {
        // Hide input phase and go back to choice or start auto-detection
        document.getElementById('input-phase').classList.add('hidden');
        startAutoDetection();
      });
    }
    
    // Handle form submission
    document.getElementById('specs-form').addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Get form values
      const osSelect = document.getElementById('os-select').value;
      if (osSelect) {
        // Map OS selection to platform and version
        if (osSelect.includes('windows')) {
          systemSpecs.detected.platform = 'windows';
          if (osSelect === 'windows-11') systemSpecs.detected.osVersion = 'Windows 11';
          else if (osSelect === 'windows-10') systemSpecs.detected.osVersion = 'Windows 10';
        } else if (osSelect.includes('macos')) {
          systemSpecs.detected.platform = 'mac';
          if (osSelect === 'macos-sonoma') systemSpecs.detected.osVersion = 'macOS Sonoma';
          else if (osSelect === 'macos-ventura') systemSpecs.detected.osVersion = 'macOS Ventura';
          else if (osSelect === 'macos-monterey') systemSpecs.detected.osVersion = 'macOS Monterey';
        } else if (osSelect === 'linux') {
          systemSpecs.detected.platform = 'linux';
          systemSpecs.detected.osVersion = 'Linux';
        }
      }
      
      const cpuModel = document.getElementById('cpu-model').value;
      if (cpuModel) {
        systemSpecs.detected.cpuCores = CPU_CORES_MAP[cpuModel] || 4;
        
        // Map CPU selection to model name
        const cpuOption = document.querySelector(`#cpu-model option[value="${cpuModel}"]`);
        if (cpuOption) {
          systemSpecs.detected.cpuModel = cpuOption.textContent || 'Unknown CPU';
        }
      }
      
      systemSpecs.userProvided.gpuModel = document.getElementById('gpu-model').value || undefined;
      systemSpecs.userProvided.systemRAM = parseInt(document.getElementById('system-ram').value) || 0;
      
      // Hide input phase and show results
      document.getElementById('input-phase').classList.add('hidden');
      showResults();
    });
    
    
    // Handle recheck
    document.getElementById('recheck-button').addEventListener('click', () => {
      // Reset everything and go back to choice screen
      document.getElementById('results-phase').classList.add('hidden');
      document.getElementById('detection-phase').classList.add('hidden');
      document.getElementById('input-phase').classList.add('hidden');
      document.getElementById('choice-phase').classList.remove('hidden');
      document.getElementById('auto-detect-notice').classList.add('hidden');
      
      // Reset system specs
      systemSpecs = {
        detected: {
          platform: 'unknown',
          osVersion: '',
          gpuRenderer: '',
          webglVersion: 0,
          cpuCores: 0,
          cpuModel: '',
          screenResolution: { width: 0, height: 0 }
        },
        userProvided: {}
      };
      
      // Reset form
      document.getElementById('specs-form').reset();
      
      // Reset GPU model dropdown
      const gpuModelSelect = document.getElementById('gpu-model');
      if (gpuModelSelect) {
        gpuModelSelect.innerHTML = '<option value="">Select brand first...</option>';
        gpuModelSelect.disabled = true;
      }
    });
  });
</script>