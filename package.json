{
  "name": "davantsystems.github.io",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev --port 3100 > logs/astro-dev.log 2>&1 &",
    "log": "tail -f logs/astro-dev.log",
    "log:last": "tail -n ${LINES:-20} logs/astro-dev.log",

    "log:clear": "rm -f logs/astro-dev.log && echo 'Astro dev log cleared'",
    "kill": "(lsof -ti:3100 -sTCP:LISTEN | xargs kill -9) 2>/dev/null || true",
    "restart": "npm run kill && npm run dev",
    "status": "(lsof -i:3100 >/dev/null 2>&1 && echo '✅ Running on port 3100' || echo '❌ Not running')",
    
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/react": "^4.2.5",
    "@tailwindcss/vite": "^4.1.4",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "astro": "^5.7.5",
    "daisyui": "^5.0.28",
    "exifr": "^7.1.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16"
  }
}
